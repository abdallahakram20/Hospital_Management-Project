@model IEnumerable<Hospital_Management_Project.Models.Department>

@{
    ViewData["Title"] = "Hospital Departments";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 bg-light p-3 rounded shadow-sm">
        <div>
            <h2 class="text-primary mb-0"><i class="bi bi-building"></i> Hospital Departments</h2>
            <small class="text-muted">Browse and manage active medical departments and clinic locations</small>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <i class="bi bi-plus-circle"></i> Create New Department
            </a>
        }
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th><i class="bi bi-tag"></i> Department Name</th>
                            <th><i class="bi bi-layers"></i> Floor Location</th>
                            <th class="text-center" style="min-width: 220px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="bi bi-folder-x display-4 block mb-2"></i>
                                    <p class="mb-0 fw-bold">No hospital departments registered yet.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-secondary">
                                        @Html.DisplayFor(modelItem => item.DeptName)
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary px-2 py-1">
                                            @Html.DisplayFor(modelItem => item.DeptFloor) Floor
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group gap-1">
                                            <a asp-action="Details" asp-route-id="@item.DepartmentId" class="btn btn-sm btn-outline-info rounded">
                                                <i class="bi bi-eye"></i> Details
                                            </a>

                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.DepartmentId" class="btn btn-sm btn-outline-primary rounded">
                                                    <i class="bi bi-pencil-square"></i> Edit
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.DepartmentId" class="btn btn-sm btn-outline-danger rounded">
                                                    <i class="bi bi-trash"></i> Delete
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>