                            </div>
                        </div>
                        <a href="@Url.Action("Index", "Appointments")" class="status-btn-link bg-pending">Pending</a>
                    </div>

                    <div class="d-flex align-items-center justify-content-between p-2 border-bottom pb-3">
                        <div class="d-flex align-items-center">
                            <div class="text-center me-3" style="min-width: 65px;">
                                <div class="fw-bold text-dark m-0" style="font-size: 0.95rem;">02:30 PM</div>
                                <small class="text-muted d-block" style="font-size: 0.75rem; font-weight: 600;">PM</small>
                            </div>
                            <div class="timeline-dot" style="border-left: 2px solid #eef5ff; padding-left: 15px;">
                                <div class="fw-bold text-dark" style="font-size: 0.95rem;">Emily Davis</div>
                                <small class="text-muted d-block" style="font-size: 0.85rem;">Dermatology</small>
                            </div>
                        </div>
                        <a href="@Url.Action("Index", "Appointments")" class="status-btn-link bg-confirmed">Confirmed</a>
                    </div>

                    <div class="d-flex align-items-center justify-content-between p-2 pb-1">
                        <div class="d-flex align-items-center">
                            <div class="text-center me-3" style="min-width: 65px;">
                                <div class="fw-bold text-dark m-0" style="font-size: 0.95rem;">04:00 PM</div>
                                <small class="text-muted d-block" style="font-size: 0.75rem; font-weight: 600;">PM</small>
                            </div>
                            <div class="timeline-dot" style="border-left: 2px solid #eef5ff; padding-left: 15px;">
                                <div class="fw-bold text-dark" style="font-size: 0.95rem;">David Wilson</div>
                                <small class="text-muted d-block" style="font-size: 0.85rem;">Neurology</small>
                            </div>
                        </div>
                        <a href="@Url.Action("Index", "Appointments")" class="status-btn-link bg-pending">Pending</a>
                    </div>
                </div>
            </div>
        </div>*@

    </div>

    <footer class="d-flex justify-content-between align-items-center mt-5 pt-3 text-muted small border-top" style="position: relative; z-index: 2;">
        <div>© 2026 Medicare Hospital. All rights reserved.</div>
        <div class="d-flex gap-3">
            <a href="#" class="text-muted text-decoration-none">Privacy Policy</a>
            <a href="#" class="text-muted text-decoration-none">Terms of Service</a>
        </div>
    </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
        if (window.history.pushState) {
        window.history.pushState(null, null, window.location.href);

        window.addEventListener('popstate', function () {
        window.location.href = '/Home/Index'; // التوجيه المباشر للرئيسية
        });
        }

        window.addEventListener('pageshow', function (event) {
        if (event.persisted || (typeof window.performance != "undefined" && window.performance.getEntriesByType("navigation")[0]?.type === "back_forward")) {
        window.location.reload(true);
        }
        });
        })();
    </script>
</body>
</html>