@model IEnumerable<Hospital_Management_Project.Models.Department>

@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clinic Departments - Medicare</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body {
            background-color: #f3f8ff;
            background-image: 
                radial-gradient(circle at 5% 15%, #d1e3ff 0%, transparent 35%),
                radial-gradient(circle at 95% 25%, #dae7ff 0%, transparent 30%),
                radial-gradient(circle at 85% 80%, #cbdfff 0%, transparent 40%),
                radial-gradient(circle at 10% 85%, #e2eeff 0%, transparent 35%);
            background-attachment: fixed;
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #1e293b;
            overflow-x: hidden;
        }

        .bg-glow-1 {
            position: absolute;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(195, 219, 255, 0.7) 0%, rgba(255,255,255,0) 70%);
            top: -100px;
            right: -150px;
            z-index: 0;
            pointer-events: none;
            filter: blur(20px);
        }

        .bg-glow-2 {
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(204, 224, 255, 0.6) 0%, rgba(255,255,255,0) 70%);
            bottom: -50px;
            left: -150px;
            z-index: 0;
            pointer-events: none;
            filter: blur(20px);
        }

        .custom-card {
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.7);
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0, 82, 204, 0.03);
            position: relative;
            z-index: 1;
        }

        .header-box {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.8);
            position: relative;
            overflow: hidden;
            z-index: 1;
            box-shadow: 0 12px 30px rgba(0, 82, 204, 0.02);
        }

        .table-thead {
            background: #0052cc !important;
        }

        .table-thead th {
            color: white !important;
            padding: 16px !important;
            font-size: 0.85rem !important;
            letter-spacing: 0.5px !important;
            border: none !important;
            font-weight: 600 !important;
        }

        .btn-action-view {
            border: 1px solid #b4d3ff;
            background-color: #fff;
            color: #0052cc;
            border-radius: 20px;
            font-size: 0.85rem;
            padding: 5px 16px;
            font-weight: 500;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .btn-action-view:hover {
            background-color: #0052cc;
            color: #fff;
            border-color: #0052cc;
        }

        .btn-action-icon {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #f2f4f7;
            background-color: #fff;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .btn-edit-icon { color: #eab308; border-color: #fef08a; }
        .btn-edit-icon:hover { background-color: #eab308; color: #fff; border-color: #eab308; }

        .btn-delete-icon { color: #ef4444; border-color: #fee2e2; }
        .btn-delete-icon:hover { background-color: #ef4444; color: #fff; border-color: #ef4444; }

        .floor-badge {
            background-color: #eef5ff; 
            color: #0052cc; 
            border-radius: 20px; 
            font-size: 0.85rem;
            padding: 6px 16px;
            font-weight: 600;
            display: inline-block;
            border: none;
        }

        /* تنسيقات الفوتر الأزرق العريض المعتمد */
        .custom-hospital-footer {
            background-color: #1565c0; 
            color: #ffffff !important;
            font-family: system-ui, -apple-system, sans-serif;
            margin-top: 60px;
            width: 100%;
        }

        .hospital-footer-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .hospital-footer-top {
            padding: 60px 0 40px 0;
        }

        .hospital-footer-row {
            display: flex;
            flex-wrap: wrap;
            gap: 30px;
        }

        .hospital-footer-col {
            flex: 1;
            min-width: 220px;
        }

        .hospital-footer-heading {
            color: #ffffff;
            font-size: 19px;
            font-weight: 700;
            margin-bottom: 25px;
            position: relative;
            padding-bottom: 10px;
        }

        .hospital-footer-heading::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0;
            width: 40px;
            height: 2px;
            background-color: #ffffff;
        }

        .hospital-footer-text {
            color: rgba(255, 255, 255, 0.8);
            font-size: 14px;
            line-height: 1.6;
        }

        .hospital-footer-socials {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .h-social-btn {
            width: 36px;
            height: 36px;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ffffff !important;
            text-decoration: none;
            transition: background 0.2s;
        }

        .h-social-btn:hover {
            background-color: rgba(255, 255, 255, 0.25);
        }

        .hospital-footer-links {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .hospital-footer-links li {
            margin-bottom: 12px;
        }

        .hospital-footer-links a {
            color: rgba(255, 255, 255, 0.8) !important;
            text-decoration: none;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: transform 0.2s, color 0.2s;
        }

        .hospital-footer-links a i {
            font-size: 10px;
        }

        .hospital-footer-links a:hover {
            color: #ffffff !important;
            transform: translateX(5px);
        }

        .hospital-footer-hours {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .hours-line {
            display: flex;
            justify-content: space-between;
            font-size: 14px;
            color: rgba(255, 255, 255, 0.8);
            border-bottom: 1px dashed rgba(255, 255, 255, 0.15);
            padding-bottom: 6px;
        }

        .hours-line strong {
            color: #ffffff;
            font-weight: 500;
        }

        .emergency-line {
            border-bottom: none;
        }

        .emergency-line strong {
            font-weight: 700;
            border-bottom: 1px solid #ffffff;
        }

        .hospital-footer-bottom {
            background-color: rgba(0, 0, 0, 0.1);
            padding: 20px 0;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .bottom-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .copyright-text {
            font-size: 13.5px;
            color: rgba(255, 255, 255, 0.7);
            margin: 0;
        }

        .copyright-text i {
            color: #ffffff;
            font-size: 12px;
        }

        .h-scroll-top {
            width: 36px;
            height: 36px;
            background-color: rgba(255, 255, 255, 0.15);
            color: #ffffff !important;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            transition: transform 0.2s, background 0.2s;
        }

        .h-scroll-top:hover {
            background-color: rgba(255, 255, 255, 0.3);
            transform: translateY(-3px);
        }

        @@media (max-width: 768px) {
            .hospital-footer-row {
                flex-direction: column;
            }
            .bottom-flex {
                flex-direction: column;
                text-align: center;
            }
        }
    </style>
</head>
<body>

<div class="container py-5 position-relative">
    <div class="bg-glow-1"></div>

    <div class="text-center p-5 mb-4 header-box shadow-sm">
        <div class="position-relative" style="z-index: 2;">
            <span class="text-primary fw-semibold" style="letter-spacing: 1.5px;">— Welcome to CarePlus Hospital —</span>
            <h1 class="display-4 fw-bold my-2" style="color: #0a1931; font-weight: 850;">Clinic Departments</h1>
            <p class="text-muted fs-5">Manage hospital departments and their locations efficiently.</p>
            
            <a href="@Url.Action("Create", "Departments")" class="btn btn-primary px-4 py-2 mt-2 shadow-sm fw-medium" style="border-radius: 12px; background-color: #1a73e8; border: none;">
                <i class="bi bi-plus-lg me-1"></i> Add Department
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card p-3 border-0 custom-card d-flex flex-row align-items-center">
                <div class="p-3 bg-primary-subtle rounded-circle me-3 text-primary d-flex align-items-center justify-content-center" style="width: 52px; height: 52px;">
                    <i class="bi bi-building fs-4"></i>
                </div>
                <div>
                    <small class="text-muted d-block" style="font-size: 0.85rem; font-weight: 500;">Total Departments</small>
                    <span class="fs-3 fw-bold text-dark">@Model.Count()</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 border-0 custom-card d-flex flex-row align-items-center">
                <div class="p-3 bg-primary-subtle rounded-circle me-3 text-primary d-flex align-items-center justify-content-center" style="width: 52px; height: 52px;">
                    <i class="bi bi-hospital fs-4"></i>
                </div>
                <div>
                    <small class="text-muted d-block" style="font-size: 0.85rem; font-weight: 500;">Hospital</small>
                    <span class="fs-4 fw-bold text-primary">CarePlus</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 border-0 custom-card d-flex flex-row align-items-center">
                <div class="p-3 bg-success-subtle rounded-circle me-3 text-success d-flex align-items-center justify-content-center" style="width: 52px; height: 52px;">
                    <i class="bi bi-check-circle fs-4"></i>
                </div>
                <div>
                    <small class="text-muted d-block" style="font-size: 0.85rem; font-weight: 500;">Status</small>
                    <span class="fs-4 fw-bold text-success">Active</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 border-0 custom-card d-flex flex-row align-items-center">
                <div class="p-3 bg-info-subtle rounded-circle me-3 text-info d-flex align-items-center justify-content-center" style="width: 52px; height: 52px;">
                    <i class="bi bi-clock-history fs-4"></i>
                </div>
                <div>
                    <small class="text-muted d-block" style="font-size: 0.85rem; font-weight: 500;">Service</small>
                    <span class="fs-4 fw-bold text-dark">24/7</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 position-relative">
        <div class="bg-glow-2"></div>

        <div class="col-lg-12">
            <div class="card p-4 border-0 custom-card h-100 d-flex flex-column" style="min-height: 520px;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold m-0" style="color: #0a1931; font-size: 1.4rem;">Departments</h4>
                    <a href="@Url.Action("Create", "Departments")" class="btn btn-sm text-white px-3 py-2 fw-medium" style="background-color: #0052cc; border-radius: 10px; border: none;">
                        <i class="bi bi-plus"></i> Add Department
                    </a>
                </div>
                
                <div class="table-responsive" style="border-radius: 12px; overflow: hidden;">
                    <table class="table align-middle">
                        <thead>
                            <tr class="table-thead">
                                <th style="width: 40%;">DEPARTMENT NAME</th>
                                <th style="width: 30%;">LOCATION FLOOR</th>
                                <th class="text-center" style="width: 30%;">ACTIONS</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="border-bottom" style="background-color: transparent;">
                                    <td class="p-3 fw-semibold text-dark" style="font-size: 0.95rem;">
                                        @Html.DisplayFor(modelItem => item.DeptName)
                                    </td>
                                    <td class="p-3">
                                        <span class="floor-badge">
                                            @Html.DisplayFor(modelItem => item.DeptFloor)
                                        </span>
                                    </td>
                                    <td class="p-3">
                                        <div class="d-flex justify-content-center align-items-center gap-2">
                                            <a href="@Url.Action("Details", "Departments", new { id = item.DepartmentId })" class="btn-action-view">
                                                <i class="bi bi-eye me-1"></i> Details
                                            </a>
                                            <a href="@Url.Action("Edit", "Departments", new { id = item.DepartmentId })" class="btn-action-icon btn-edit-icon" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="@Url.Action("Delete", "Departments", new { id = item.DepartmentId })" class="btn-action-icon btn-delete-icon" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-auto pt-4 border-top">
                    <small class="text-muted fw-medium">Showing 1 to @Model.Count() of @Model.Count() departments</small>
                    <nav>
                        <ul class="pagination pagination-sm m-0 gap-1">
                            <li class="page-item disabled"><a class="page-link border rounded-3 bg-transparent text-muted" href="#"><i class="bi bi-chevron-left"></i></a></li>
                            <li class="page-item active"><a class="page-link px-3 rounded-3 shadow-sm" href="#" style="background-color: #0052cc; border-color: #0052cc;">1</a></li>
                            <li class="page-item"><a class="page-link px-3 rounded-3 border bg-transparent text-dark" href="#">2</a></li>
                            <li class="page-item"><a class="page-link px-3 rounded-3 border bg-transparent text-dark" href="#">3</a></li>
                            <li class="page-item"><a class="page-link border rounded-3 bg-transparent text-dark" href="#"><i class="bi bi-chevron-right"></i></a></li>
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<footer class="custom-hospital-footer">
    <div class="hospital-footer-top">
        <div class="hospital-footer-container">
            <div class="hospital-footer-row">
                
                <div class="hospital-footer-col">
                    <h5 class="hospital-footer-heading">CarePlus Medical</h5>
                    <p class="hospital-footer-text">Providing compassionate, high-quality healthcare to patients and families since 2010. Your health is our highest priority.</p>
                    <div class="hospital-footer-socials">
                        <a href="#" class="h-social-btn"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="h-social-btn"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="h-social-btn"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="h-social-btn"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>

                <div class="hospital-footer-col">
                    <h5 class="hospital-footer-heading">Quick Links</h5>
                    <ul class="hospital-footer-links">
                        <li><a asp-controller="Home" asp-action="Index"><i class="fas fa-chevron-right"></i> Home</a></li>
                        <li><a asp-controller="Departments" asp-action="Index"><i class="fas fa-chevron-right"></i> Departments</a></li>
                        <li><a asp-controller="Staffs" asp-action="Index"><i class="fas fa-chevron-right"></i> Doctors</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Patients</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Appointments</a></li>
                    </ul>
                </div>

                <div class="hospital-footer-col">
                    <h5 class="hospital-footer-heading">Services</h5>
                    <ul class="hospital-footer-links">
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Medical Profiles</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Book Appointment</a></li>
                        <li><a href="#"><i class="fas fa-chevron-right"></i> Find a Doctor</a></li>
                    </ul>
                </div>

                <div class="hospital-footer-col">
                    <h5 class="hospital-footer-heading">Working Hours</h5>
                    <div class="hospital-footer-hours">
                        <div class="hours-line">
                            <span>Mon – Fri</span>
                            <strong>08:00 – 20:00</strong>
                        </div>
                        <div class="hours-line">
                            <span>Saturday</span>
                            <strong>08:00 – 18:00</strong>
                        </div>
                        <div class="hours-line">
                            <span>Sunday</span>
                            <strong>10:00 – 14:00</strong>
                        </div>
                        <div class="hours-line emergency-line">
                            <span>Emergency</span>
                            <strong>24 / 7</strong>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div class="hospital-footer-bottom">
    <div class="container text-center small text-white-50 position-relative py-2">
        <p class="m-0" style="font-size: 13.5px; color: rgba(255,255,255,0.5);">&copy; 2026 CarePlus Medical Center. All Rights Reserved. Designed with <i class="fas fa-heart text-white mx-1" style="font-size: 12px;"></i> for better healthcare.</p>
        <a href="#" class="h-scroll-top position-absolute end-0 top-50 translate-middle-y px-3" style="color: #fff;"><i class="fas fa-arrow-up"></i></a>
    </div>
</div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>