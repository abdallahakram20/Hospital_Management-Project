@model Hospital_Management_Project.Models.Department

@{
    ViewData["Title"] = "Edit Department";
    Layout = null;
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    /* نفس كلاسات التنسيق في Create مع استخدام Edit Icon */
    :root {
        --primary: #2563eb;
        --primary-dk: #1d4ed8;
        --dark: #1e293b;
        --muted: #64748b;
        --body-bg: #f1f5f9;
        --light-bg: #f8fafc;
        --white: #ffffff;
        --danger: #ef4444;
        --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        --radius: 8px;
        --tr: all 0.3s ease;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        color: var(--muted);
        background-color: var(--body-bg);
    }

    .mp-page {
        padding: 40px 30px;
        max-width: 1280px;
        margin: 0 auto;
    }

    .mp-page-header {
        background: linear-gradient(to right, var(--white), var(--light-bg));
        border-radius: var(--radius);
        padding: 28px 36px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--shadow);
        border-left: 5px solid var(--primary);
    }

        .mp-page-header .ph-left h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 6px;
        }

            .mp-page-header .ph-left h2 i {
                color: var(--primary);
                background: #eff6ff;
                padding: 10px;
                border-radius: 8px;
                font-size: 18px;
            }

        .mp-page-header .ph-left p {
            font-size: 14px;
            color: var(--muted);
        }

    .mp-breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13.5px;
        margin-bottom: 20px;
        font-weight: 500;
    }

        .mp-breadcrumb a {
            color: var(--primary);
            text-decoration: none;
        }

    .mp-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 30px;
        box-shadow: var(--shadow);
        margin-bottom: 24px;
        border: 1px solid #e2e8f0;
    }

    .mp-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 22px;
        border-radius: var(--radius);
        font-size: 13.5px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--tr);
    }

    .mp-btn-primary {
        background: var(--primary);
        color: #fff;
    }

        .mp-btn-primary:hover {
            background: var(--primary-dk);
            transform: translateY(-2px);
        }

    .mp-btn-secondary {
        background: #f1f5f9;
        color: var(--dark);
        border: 1px solid #cbd5e1;
    }

        .mp-btn-secondary:hover {
            background: #e2e8f0;
        }

    .mp-form-group {
        margin-bottom: 20px;
    }

    .mp-label {
        display: block;
        font-weight: 500;
        margin-bottom: 8px;
        color: var(--dark);
        font-size: 14px;
    }

    .mp-input {
        width: 100%;
        height: 44px;
        border: 1px solid #cbd5e1;
        border-radius: var(--radius);
        padding: 0 16px;
        font-size: 14px;
        font-family: inherit;
        background-color: var(--light-bg);
        transition: var(--tr);
    }

        .mp-input:focus {
            outline: none;
            border-color: var(--primary);
            background-color: var(--white);
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
        }

    .text-danger {
        color: var(--danger);
        font-size: 12.5px;
        margin-top: 5px;
        display: block;
    }
</style>

<div class="mp-page">
    <div class="mp-breadcrumb">
        <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <a asp-action="Index">Departments</a>
        <i class="fas fa-chevron-right"></i>
        <span>Edit</span>
    </div>

    <div class="mp-page-header">
        <div class="ph-left">
            <h2><i class="fas fa-edit"></i> Edit Department</h2>
            <p>Update the information of an existing department</p>
        </div>
        <a asp-action="Index" class="mp-btn mp-btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="mp-card" style="max-width: 600px; margin: 0 auto;">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="DepartmentId" />

            <div class="mp-form-group">
                <label asp-for="DeptName" class="mp-label">Department Name</label>
                <input asp-for="DeptName" class="mp-input" />
                <span asp-validation-for="DeptName" class="text-danger"></span>
            </div>

            <div class="mp-form-group">
                <label asp-for="DeptFloor" class="mp-label">Department Floor</label>
                <input asp-for="DeptFloor" class="mp-input" />
                <span asp-validation-for="DeptFloor" class="text-danger"></span>
            </div>

            <div class="mp-form-group" style="margin-top: 32px; margin-bottom: 0;">
                <button type="submit" class="mp-btn mp-btn-primary" style="width: 100%; justify-content: center; height: 46px;">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>
        </form>
    </div>
</div>