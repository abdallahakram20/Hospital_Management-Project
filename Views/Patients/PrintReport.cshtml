@model Hospital_Management_Project.Models.Patient

@{
    ViewData["Title"] = "Patient Profile";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    :root {
        --primary: #1A76D1;
        --primary-dk: #1560ad;
        --dark: #2C2D3F;
        --muted: #64748b;
        --light-bg: #f8fafc;
        --white: #fff;
        --border: #e2e8f0;
        --shadow: 0 4px 15px rgba(0,0,0,.05);
        --radius: 8px;
        --tr: all 0.3s ease;
    }

    .profile-page {
        padding: 40px 30px;
        max-width: 900px;
        margin: 0 auto;
        font-family: 'Poppins', sans-serif;
    }

    /* Breadcrumb */
    .profile-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        margin-bottom: 20px;
    }

        .profile-breadcrumb a {
            color: var(--primary);
            text-decoration: none;
            transition: var(--tr);
        }

            .profile-breadcrumb a:hover {
                text-decoration: underline;
                color: var(--primary-dk);
            }

        .profile-breadcrumb i {
            font-size: 10px;
            color: var(--muted);
        }

    /* Page Header */
    .profile-header {
        background: var(--white);
        border-radius: var(--radius);
        padding: 28px 36px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        box-shadow: var(--shadow);
        border-left: 4px solid var(--primary);
    }

        .profile-header h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0 0 4px 0;
        }

            .profile-header h2 i {
                color: var(--primary);
            }

        .profile-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    .header-actions {
        display: flex;
        gap: 12px;
    }

    /* Card & Grid */
    .profile-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 35px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
    }

    .profile-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 25px;
    }

    .info-group {
        background: var(--light-bg);
        padding: 18px 20px;
        border-radius: var(--radius);
        border-left: 4px solid var(--primary);
        transition: var(--tr);
    }

        .info-group:hover {
            box-shadow: 0 4px 10px rgba(26, 118, 209, 0.1);
            transform: translateY(-2px);
        }

    .info-label {
        font-size: 12px;
        color: var(--muted);
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .info-label i {
            color: var(--primary);
            font-size: 14px;
        }

    .info-value {
        font-size: 16px;
        font-weight: 600;
        color: var(--dark);
        margin: 0;
    }

    .full-width {
        grid-column: 1 / -1;
    }

    /* Buttons */
    .btn-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: var(--radius);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--tr);
    }

    .btn-back {
        background: #f1f5f9;
        color: #475569;
    }

        .btn-back:hover {
            background: #e2e8f0;
            color: #1e293b;
        }

    .btn-print {
        background: var(--primary);
        color: var(--white);
    }

        .btn-print:hover {
            background: var(--primary-dk);
            box-shadow: 0 4px 12px rgba(26, 118, 209, 0.2);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .profile-page {
            padding: 20px 15px;
        }

        .profile-header {
            padding: 20px;
        }

        .profile-card {
            padding: 20px;
        }
    }

    /* Printing Adjustments */
    @@media print {
        @@page {
            size: A4 portrait;
            margin: 20mm;
        }

        body {
            background: #fff !important;
        }

        .profile-breadcrumb,
        .header-actions {
            display: none !important; /* يخفي الأزرار والروابط عند الطباعة */
        }

        .profile-header {
            border: 1px solid var(--border) !important;
            border-left: 4px solid var(--primary) !important;
            box-shadow: none !important;
        }

        .profile-card {
            box-shadow: none !important;
            border: 1px solid var(--border) !important;
        }

        .info-group {
            background: #f8fafc !important;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            page-break-inside: avoid;
        }
    }
</style>

<div class="profile-page">

    <div class="profile-breadcrumb">
        <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <a asp-action="Index">Patients</a>
        <i class="fas fa-chevron-right"></i>
        <span>Personal Profile</span>
    </div>

    <div class="profile-header">
        <div>
            <h2><i class="fas fa-id-card"></i> Patient Profile</h2>
            <p>Personal and contact information details</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn-action btn-back">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
            <button onclick="window.print()" class="btn-action btn-print">
                <i class="fas fa-print"></i> Print Profile
            </button>
        </div>
    </div>

    <div class="profile-card">
        <div class="profile-grid">

            <div class="info-group">
                <div class="info-label"><i class="fas fa-user"></i> First Name</div>
                <div class="info-value">@Model.FName</div>
            </div>

            <div class="info-group">
                <div class="info-label"><i class="fas fa-user-tag"></i> Last Name</div>
                <div class="info-value">@Model.LName</div>
            </div>

            <div class="info-group">
                <div class="info-label"><i class="fas fa-phone-alt"></i> Contact Phone</div>
                <div class="info-value">@Model.Phone</div>
            </div>

            <div class="info-group">
                <div class="info-label"><i class="fas fa-venus-mars"></i> Gender</div>
                <div class="info-value">@Model.Gender</div>
            </div>

            <div class="info-group full-width">
                <div class="info-label"><i class="fas fa-map-marker-alt"></i> Residential Address</div>
                <div class="info-value">@Model.Address</div>
            </div>

        </div>
    </div>

</div>