@model Hospital_Management_Project.Models.Patient

@{
    ViewData["Title"] = "Patient Profile";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    /* Base Variables & Theme Settings */
    :root {
        --primary: #1A76D1;
        --primary-dk: #1560ad;
        --dark: #2C2D3F;
        --muted: #64748b;
        --light-bg: #f8fafc;
        --white: #fff;
        --border: #e2e8f0;
        --shadow: 0 4px 15px rgba(0,0,0,.05);
        --radius: 8px;
        --tr: all 0.3s ease;
    }

    /* Global Box Sizing Control */
    * {
        box-sizing: border-box;
    }

    .profile-page {
        padding: 40px 30px;
        max-width: 900px;
        margin: 0 auto;
        font-family: 'Poppins', sans-serif;
    }

    /* Breadcrumb Component */
    .profile-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        margin-bottom: 20px;
    }

    .profile-breadcrumb a {
        color: var(--primary);
        text-decoration: none;
        transition: var(--tr);
    }

    .profile-breadcrumb a:hover {
        text-decoration: underline;
        color: var(--primary-dk);
    }

    .profile-breadcrumb i {
        font-size: 10px;
        color: var(--muted);
    }

    /* Page Header Component */
    .profile-header {
        background: var(--white);
        border-radius: var(--radius);
        padding: 28px 36px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        box-shadow: var(--shadow);
        border-left: 4px solid var(--primary);
    }

    .profile-header h2 {
        font-size: 22px;
        font-weight: 700;
        color: var(--dark);
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 4px 0;
    }

    .profile-header h2 i {
        color: var(--primary);
    }

    .profile-header p {
        font-size: 13px;
        color: var(--muted);
        margin: 0;
    }

    .header-actions {
        display: flex;
        gap: 12px;
    }

    /* Content Card & Grid Layout (Normal Screen View) */
    .profile-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 35px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
    }

    .profile-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 25px;
    }

    /* Information Groups */
    .info-group {
        background: var(--light-bg);
        padding: 18px 20px;
        border-radius: var(--radius);
        border-left: 4px solid var(--primary);
        transition: var(--tr);
    }

    .info-group:hover {
        box-shadow: 0 4px 10px rgba(26, 118, 209, 0.1);
        transform: translateY(-2px);
    }

    .info-label {
        font-size: 12px;
        color: var(--muted);
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .info-label i {
        color: var(--primary);
        font-size: 14px;
    }

    .info-value {
        font-size: 16px;
        font-weight: 600;
        color: var(--dark);
        margin: 0;
    }

    .full-width {
        grid-column: 1 / -1;
    }

    /* Action Buttons */
    .btn-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: var(--radius);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--tr);
    }

    .btn-back {
        background: #f1f5f9;
        color: #475569;
    }

    .btn-back:hover {
        background: #e2e8f0;
        color: #1e293b;
    }

    .btn-print {
        background: var(--primary);
        color: var(--white);
    }

    .btn-print:hover {
        background: var(--primary-dk);
        box-shadow: 0 4px 12px rgba(26, 118, 209, 0.2);
    }

    /* Screen Responsiveness Modifications */
    @@media (max-width: 768px) {
        .profile-page {
            padding: 20px 15px;
        }

        .profile-header {
            padding: 20px;
        }

        .profile-card {
            padding: 20px;
        }
    }

    /* ===================================================
       ✅ DEFINITIVE PROFESSIONAL PRINT STYLESHEET
       =================================================== */
    @@media print {
        @@page {
            size: A4 portrait;
            margin: 15mm 15mm 15mm 15mm; /* Balanced standard page padding */
        }

        /* Color rendering safety flags */
        * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            box-sizing: border-box !important;
        }

        /* 🔒 1. ROOT RESET: Bypass system layout containers to prevent horizontal bleeding and right clipping */
        html, body, main, .container, .wrapper, [class*="container"], #main-content, .container-fluid {
            background: #fff !important;
            color: #000 !important;
            width: 100% !important;
            max-width: 100% !important;
            min-width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            overflow: visible !important;
            display: block !important;
            float: none !important;
            position: static !important;
            visibility: visible !important;
        }

        /* 🔒 2. COMPLETE HIDDEN: Force elimination of peripheral interface wrappers */
        footer, #footer, .footer, header, #header, .header, nav, .navbar, [class*="navbar"], 
        sidebar, #sidebar, .header-actions, .profile-breadcrumb, [class*="breadcrumb"],
        .scrollToTop, #scrollUp, #fixed-buttons, .admin-sidebar, .sidebar {
            display: none !important;
            opacity: 0 !important;
            visibility: hidden !important;
            height: 0 !important;
            overflow: hidden !important;
        }

        /* Recalibrate print area container scope */
        .profile-page {
            padding: 0 !important;
            margin: 0 auto !important;
            width: 100% !important;
            max-width: 100% !important;
            display: block !important;
            box-sizing: border-box !important;
        }

        /* Sanitize Header Element Properties */
        .profile-header {
            border: 1px solid #cbd5e1 !important;
            border-left: 6px solid #1A76D1 !important;
            box-shadow: none !important;
            margin-bottom: 25px !important;
            padding: 20px !important;
            background: #fff !important;
            display: block !important;
            width: 100% !important;
            box-sizing: border-box !important;
        }

        .profile-card {
            box-shadow: none !important;
            border: none !important;
            padding: 0 !important;
            background: transparent !important;
            display: block !important;
            width: 100% !important;
        }

        /* 🛠️ Deconstruct flexbox / grid into a single, cohesive vertical layout pipeline */
        .profile-grid {
            display: block !important;
            width: 100% !important;
            box-sizing: border-box !important;
        }

        /* 🔒 3. WIDTH LOCK: Force rows to remain strictly bound within 100% boundary limits */
        .info-group {
            display: block !important;
            width: 100% !important;
            max-width: 100% !important;
            min-width: 100% !important;
            box-sizing: border-box !important;
            background: #f8fafc !important;
            border: 1px solid #cbd5e1 !important;
            border-left: 4px solid #1A76D1 !important;
            margin: 0 0 10px 0 !important;
            padding: 15px 20px !important;
            page-break-inside: avoid !important;
            float: none !important;
            clear: both !important;
        }

        /* Text Customization for Print Optimization */
        .info-label {
            color: #475569 !important;
            margin-bottom: 6px !important;
            display: flex !important;
            align-items: center !important;
        }

        .info-value {
            color: #000 !important;
            font-size: 16px !important;
            word-wrap: break-word !important;
        }
    }
</style>

<div class="profile-page">

    <div class="profile-breadcrumb">
        <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <a asp-action="Index">Patients</a>
        <i class="fas fa-chevron-right"></i>
        <span>Personal Profile</span>
    </div>

    <div class="profile-header">
        <div>
            <h2><i class="fas fa-id-card"></i> Patient Profile</h2>
            <p>Personal and contact information details</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn-action btn-back">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
            <button type="button" onclick="triggerProfilePrint()" class="btn-action btn-print">
                <i class="fas fa-print"></i> Print Profile
            </button>
        </div>
    </div>

    <div class="profile-card">
        <div class="profile-grid">

            <div class="info-group">
                <div class="info-label"><i class="fas fa-user"></i> First Name</div>
                <div class="info-value">@Model.FName</div>
            </div>

            <div class="info-group">
                <div class="info-label"><i class="fas fa-user-tag"></i> Last Name</div>
                <div class="info-value">@Model.LName</div>
            </div>

            <div class="info-group">
                <div class="info-label"><i class="fas fa-phone-alt"></i> Contact Phone</div>
                <div class="info-value">@Model.Phone</div>
            </div>

            <div class="info-group">
                <div class="info-label"><i class="fas fa-venus-mars"></i> Gender</div>
                <div class="info-value">@Model.Gender</div>
            </div>

            <div class="info-group full-width">
                <div class="info-label"><i class="fas fa-map-marker-alt"></i> Residential Address</div>
                <div class="info-value">@Model.Address</div>
            </div>

        </div>
    </div>
</div>

<script>
    function triggerProfilePrint() {
        // Safe timeout execution frame ensures the layout engine calculates page boundaries properly
        setTimeout(function() {
            window.print();
        }, 150);
    }
</script>