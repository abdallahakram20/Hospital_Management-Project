@model Hospital_Management_Project.Models.Patient

@{
    ViewData["Title"] = "Edit Patient";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    :root {
        --primary: #1A76D1;
        --primary-dk: #1560ad;
        --dark: #2C2D3F;
        --muted: #888;
        --light-bg: #f9f9f9;
        --white: #fff;
        --danger: #e74c3c;
        --warning: #f39c12;
        --shadow: 0 4px 15px rgba(0,0,0,.07);
        --radius: 6px;
        --tr: all .3s ease;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Poppins',sans-serif;
        font-size: 14px;
        color: var(--muted);
    }

    .mp-page {
        padding: 40px 30px;
        max-width: 900px;
        margin: 0 auto;
    }

    .mp-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        margin-bottom: 20px;
    }

        .mp-breadcrumb a {
            color: var(--primary);
            text-decoration: none;
        }

            .mp-breadcrumb a:hover {
                text-decoration: underline;
            }

        .mp-breadcrumb i {
            font-size: 10px;
            color: var(--muted);
        }

    .mp-page-header {
        background: var(--white);
        border-radius: var(--radius);
        padding: 28px 36px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        box-shadow: var(--shadow);
        border-left: 4px solid var(--warning);
    }

        .mp-page-header h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 4px;
        }

            .mp-page-header h2 i {
                color: var(--warning);
            }

        .mp-page-header p {
            font-size: 13px;
        }

    .mp-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 36px;
        box-shadow: var(--shadow);
    }

    .mp-form-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 22px;
        margin-bottom: 32px;
    }

    .mp-form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .mp-form-group.full {
            grid-column: span 2;
        }

    .mp-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--dark);
        text-transform: uppercase;
        letter-spacing: .5px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .mp-label i {
            color: var(--primary);
            font-size: 13px;
        }

    .mp-input, .mp-select {
        height: 46px;
        border: 1px solid #e0e0e0;
        border-radius: var(--radius);
        padding: 0 16px;
        font-size: 14px;
        font-family: 'Poppins',sans-serif;
        color: var(--dark);
        background: var(--white);
        transition: var(--tr);
        width: 100%;
    }

        .mp-input:focus, .mp-select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(26,118,209,.1);
        }

    .mp-select {
        cursor: pointer;
    }

    .mp-field-error {
        color: var(--danger);
        font-size: 12px;
        font-weight: 500;
    }

    .mp-divider {
        border: none;
        border-top: 1px solid #f0f0f0;
        margin-bottom: 28px;
    }

    .mp-form-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .mp-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 12px 28px;
        border-radius: var(--radius);
        font-size: 14px;
        font-weight: 600;
        font-family: 'Poppins',sans-serif;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--tr);
        white-space: nowrap;
    }

    .mp-btn-primary {
        background: var(--primary);
        color: #fff;
    }

        .mp-btn-primary:hover {
            background: var(--primary-dk);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(26,118,209,.3);
        }

    .mp-btn-secondary {
        background: var(--light-bg);
        color: var(--dark);
        border: 1px solid #e0e0e0;
    }

        .mp-btn-secondary:hover {
            background: #eee;
            color: var(--dark);
        }

    @@media (max-width:768px) {
        .mp-page {
            padding: 20px 16px;
        }

        .mp-card {
            padding: 22px;
        }

        .mp-form-grid {
            grid-template-columns: 1fr;
        }

        .mp-form-group.full {
            grid-column: span 1;
        }

        .mp-form-actions {
            flex-direction: column;
        }

        .mp-btn {
            justify-content: center;
        }
    }
</style>

<div class="mp-page">

    <div class="mp-breadcrumb">
        <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <a asp-action="Index">Patients</a>
        <i class="fas fa-chevron-right"></i>
        <span>Edit</span>
    </div>

    <div class="mp-page-header">
        <div>
            <h2><i class="fas fa-user-edit"></i> Edit Patient Profile</h2>
            <p>Modify and update the patient's registered information</p>
        </div>
    </div>

    <div class="mp-card">
        <form asp-controller="Patients" asp-action="Edit" asp-route-id="@Model.PatientId" method="post">
            <div asp-validation-summary="ModelOnly" class="mp-field-error" style="margin-bottom:18px;"></div>
            <input type="hidden" asp-for="PatientId" />
            <input type="hidden" asp-for="Password" />
            <input type="hidden" asp-for="user_name" />

            <div class="mp-form-grid">
                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-user"></i> First Name</label>
                    <input asp-for="FName" class="mp-input" placeholder="First name" />
                    <span asp-validation-for="FName" class="mp-field-error"></span>
                </div>
                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-user"></i> Last Name</label>
                    <input asp-for="LName" class="mp-input" placeholder="Last name" />
                    <span asp-validation-for="LName" class="mp-field-error"></span>
                </div>
                <div class="mp-form-group full">
                    <label class="mp-label"><i class="fas fa-map-marker-alt"></i> Address</label>
                    <input asp-for="Address" class="mp-input" placeholder="Full address" />
                    <span asp-validation-for="Address" class="mp-field-error"></span>
                </div>
                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-phone"></i> Phone Number</label>
                    <input asp-for="Phone" class="mp-input" placeholder="Phone number" />
                    <span asp-validation-for="Phone" class="mp-field-error"></span>
                </div>
                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-venus-mars"></i> Gender</label>
                    <select asp-for="Gender" class="mp-select">
                        <option value="">-- Select Gender --</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                    </select>
                    <span asp-validation-for="Gender" class="mp-field-error"></span>
                </div>

            </div>

            <hr class="mp-divider" />

            <div class="mp-form-actions">
                <button type="submit" class="mp-btn mp-btn-primary">
                    <i class="fas fa-save"></i> Save Changes
                </button>
                <a asp-action="Index" class="mp-btn mp-btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </form>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
<script>
    if (window.history.replaceState) {
    window.history.replaceState(null, null, window.location.href);
    }
</script>
