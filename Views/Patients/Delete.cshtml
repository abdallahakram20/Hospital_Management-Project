@model Hospital_Management_Project.Models.Patient

@{
    ViewData["Title"] = "Delete Patient";
    Layout = null;
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    :root {
        --danger: #ef4444;
        --danger-dk: #dc2626;
        --dark: #1e293b;
        --muted: #64748b;
        --body-bg: #f1f5f9;
        --white: #ffffff;
        --shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        --radius: 8px;
    }

    body {
        font-family: 'Poppins', sans-serif;
        background-color: var(--body-bg);
        color: var(--dark);
        margin: 0;
        padding: 0;
    }

    .mp-page {
        padding: 40px 30px;
        max-width: 600px;
        margin: 0 auto;
    }

    .mp-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 36px;
        box-shadow: var(--shadow);
        text-align: center;
    }

    .mp-danger-icon {
        width: 80px;
        height: 80px;
        background: #fef2f2;
        color: var(--danger);
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        margin-bottom: 20px;
    }

    h3 {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 10px;
        color: #111827;
    }

    .mp-warning-text {
        color: var(--muted);
        font-size: 14px;
        margin-bottom: 24px;
    }

    .mp-patient-box {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 16px;
        border-radius: var(--radius);
        text-align: left;
        margin-bottom: 30px;
    }

        .mp-patient-box p {
            margin: 6px 0;
            font-size: 14px;
        }

    .mp-actions {
        display: flex;
        justify-content: center;
        gap: 12px;
    }

    .mp-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 24px;
        border-radius: var(--radius);
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: all .3s;
    }

    .mp-btn-secondary {
        background: #e2e8f0;
        color: var(--dark);
    }

    .mp-btn-danger {
        background: var(--danger);
        color: #fff;
    }

        .mp-btn-danger:hover {
            background: var(--danger-dk);
        }
</style>

<div class="mp-page">
    <div class="mp-card">
        <div class="mp-danger-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>

        <h3>Are you absolutely sure?</h3>
        <p class="mp-warning-text">You are about to permanently delete this patient record. This action cannot be undone.</p>

        <div class="mp-patient-box">
            <p><strong>Name:</strong> @Model.FName @Model.LName</p>
            <p><strong>Phone:</strong> @Model.Phone</p>
            <p><strong>Address:</strong> @Model.Address</p>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="PatientId" />
            <div class="mp-actions">
                <a asp-action="Index" class="mp-btn mp-btn-secondary">No, Keep Record</a>
                <button type="submit" class="mp-btn mp-btn-danger">
                    <i class="fas fa-trash"></i> Yes, Delete Patient
                </button>
            </div>
        </form>
    </div>
</div>