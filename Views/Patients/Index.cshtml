@model IEnumerable<Hospital_Management_Project.Models.Patient>

@{
    ViewData["Title"] = "Patients Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Patients List</h2>
        @if (!User.IsInRole("Patient"))
        {
            <a asp-action="Create" class="btn btn-primary">Create New</a>
        }
    </div>

    <form asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="searchString" placeholder="Search by name or ID..." value="@ViewData["CurrentFilter"]" class="form-control" style="max-width: 350px;" />
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-bordered text-center align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.FName)</th>
                    <th>@Html.DisplayNameFor(model => model.LName)</th>
                    <th>@Html.DisplayNameFor(model => model.Address)</th>
                    <th>@Html.DisplayNameFor(model => model.Phone)</th>
                    <th>@Html.DisplayNameFor(model => model.Gender)</th>
                    @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                    {
                        <th>@Html.DisplayNameFor(model => model.user_name)</th>
                    }
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.FName)</td>
                        <td>@Html.DisplayFor(modelItem => item.LName)</td>
                        <td>@Html.DisplayFor(modelItem => item.Address)</td>
                        <td>@Html.DisplayFor(modelItem => item.Phone)</td>
                        <td>@Html.DisplayFor(modelItem => item.Gender)</td>

                        @if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Admin"))
                        {
                            <td class="text-primary fw-bold">@Html.DisplayFor(modelItem => item.user_name)</td>
                        }

                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.PatientId" class="btn btn-sm btn-warning">Edit</a>
                                <a asp-action="Details" asp-route-id="@item.PatientId" class="btn btn-sm btn-info text-white">Details</a>
                                <a asp-controller="Patients" asp-action="ManageAccount" asp-route-id="@item.PatientId" class="btn btn-sm btn-secondary">Manage Login</a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.PatientId" class="btn btn-sm btn-danger">Delete</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>