@model Hospital_Management_Project.Models.Patient

@{
    ViewData["Title"] = "Manage Login Info";
    Layout = null;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center">
                    <h4 class="mb-0"><i class="bi bi-shield-lock"></i> Account Security</h4>
                    <small>Updating for: @Model.FName @Model.LName</small>
                </div>
                <div class="card-body p-4">
                    <form asp-action="ManageAccount" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <input type="hidden" asp-for="PatientId" />

                        <div class="form-group mb-3">
                            <label class="form-label fw-bold">Current Username</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="user_name" class="form-control" placeholder="Enter username" />
                            </div>
                            <span asp-validation-for="user_name" class="text-danger small"></span>
                        </div>@@model Hospital_Management_Project.Models.Patient

@{
    ViewData["Title"] = "Manage Login Info";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    :root {
        --primary:#1A76D1; --primary-dk:#1560ad; --dark:#2C2D3F;
        --muted:#888; --light-bg:#f9f9f9; --white:#fff;
        --success:#27ae60; --success-dk:#1e8449;
        --danger:#e74c3c;
        --shadow:0 4px 15px rgba(0,0,0,.07); --radius:6px; --tr:all .3s ease;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Poppins',sans-serif; font-size:14px; color:var(--muted); }
    .mp-page { padding:40px 30px; max-width:560px; margin:0 auto; }
    .mp-breadcrumb { display:flex; align-items:center; gap:6px; font-size:13px; margin-bottom:20px; }
    .mp-breadcrumb a { color:var(--primary); text-decoration:none; }
    .mp-breadcrumb a:hover { text-decoration:underline; }
    .mp-breadcrumb i { font-size:10px; color:var(--muted); }

    /* Header card */
    .mp-header-card {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dk) 100%);
        border-radius: var(--radius);
        padding: 28px 32px;
        margin-bottom: 24px;
        box-shadow: 0 6px 20px rgba(26,118,209,.25);
        text-align: center;
    }
    .mp-header-card i { font-size:36px; color:rgba(255,255,255,.8); margin-bottom:12px; display:block; }
    .mp-header-card h2 { font-size:20px; font-weight:700; color:#fff; margin-bottom:6px; }
    .mp-header-card p  { font-size:13px; color:rgba(255,255,255,.8); }

    /* Form card */
    .mp-card { background:var(--white); border-radius:var(--radius); padding:32px; box-shadow:var(--shadow); }
    .mp-form-group { margin-bottom:20px; }
    .mp-label { font-size:12px; font-weight:600; color:var(--dark); text-transform:uppercase; letter-spacing:.5px; display:flex; align-items:center; gap:7px; margin-bottom:8px; }
    .mp-label i { color:var(--primary); font-size:13px; }
    .mp-input-wrap { position:relative; }
    .mp-input {
        width:100%; height:46px; border:1px solid #e0e0e0; border-radius:var(--radius);
        padding:0 46px 0 16px; font-size:14px; font-family:'Poppins',sans-serif;
        color:var(--dark); background:var(--white); transition:var(--tr);
    }
    .mp-input:focus { outline:none; border-color:var(--primary); box-shadow:0 0 0 3px rgba(26,118,209,.1); }
    .mp-input-icon {
        position:absolute; left:14px; top:50%; transform:translateY(-50%);
        color:var(--muted); font-size:14px;
    }
    .mp-input { padding-left:40px; }
    .mp-eye-btn {
        position:absolute; right:12px; top:50%; transform:translateY(-50%);
        background:none; border:none; cursor:pointer; color:var(--muted); font-size:14px;
    }
    .mp-eye-btn:hover { color:var(--primary); }
    .mp-field-error { color:var(--danger); font-size:12px; font-weight:500; display:block; margin-top:5px; }
    .mp-hint { font-size:12px; color:var(--muted); margin-top:5px; display:block; }

    .mp-divider { border:none; border-top:1px solid #f0f0f0; margin:24px 0; }
    .mp-form-actions { display:flex; flex-direction:column; gap:10px; }
    .mp-btn {
        display:flex; align-items:center; justify-content:center; gap:8px; width:100%;
        padding:13px 20px; border-radius:var(--radius); font-size:14px; font-weight:600;
        font-family:'Poppins',sans-serif; cursor:pointer; text-decoration:none;
        border:none; transition:var(--tr);
    }
    .mp-btn-success   { background:var(--success); color:#fff; }
    .mp-btn-success:hover { background:var(--success-dk); color:#fff; transform:translateY(-1px); box-shadow:0 4px 12px rgba(39,174,96,.3); }
    .mp-btn-secondary { background:var(--light-bg); color:var(--dark); border:1px solid #e0e0e0; }
    .mp-btn-secondary:hover { background:#eee; color:var(--dark); }

    @@media (max-width:600px) {
        .mp-page { padding:20px 16px; }
        .mp-card { padding:22px; }
    }
</style>

<div class="mp-page">

    <div class="mp-breadcrumb">
        <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <a asp-action="Index">Patients</a>
        <i class="fas fa-chevron-right"></i>
        <span>Account Security</span>
    </div>

    <!-- Header -->
    <div class="mp-header-card">
        <i class="fas fa-shield-alt"></i>
        <h2>Account Security</h2>
        <p>Updating credentials for: <strong style="color:#fff;">@Model.FName @Model.LName</strong></p>
    </div>

    <!-- Form -->
    <div class="mp-card">
        <form asp-action="ManageAccount" method="post">
            <div asp-validation-summary="ModelOnly" class="mp-field-error" style="margin-bottom:16px;"></div>
            <input type="hidden" asp-for="PatientId" />

            <!-- Username -->
            <div class="mp-form-group">
                <label class="mp-label"><i class="fas fa-user"></i> Username</label>
                <div class="mp-input-wrap">
                    <i class="fas fa-user mp-input-icon"></i>
                    <input asp-for="user_name" class="mp-input" placeholder="Enter username" />
                </div>
                <span asp-validation-for="user_name" class="mp-field-error"></span>
            </div>

            <!-- Password -->
            <div class="mp-form-group">
                <label class="mp-label"><i class="fas fa-key"></i> New Password</label>
                <div class="mp-input-wrap">
                    <i class="fas fa-lock mp-input-icon"></i>
                    <input name="Password" type="password" id="passInput" class="mp-input"
                           placeholder="Leave blank to keep current password" value="" />
                    <button type="button" class="mp-eye-btn" onclick="togglePass()">
                        <i class="fas fa-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="mp-field-error"></span>
                <span class="mp-hint"><i class="fas fa-info-circle" style="margin-right:4px;"></i>Leave blank to keep the current password unchanged.</span>
            </div>

            <hr class="mp-divider" />

            <div class="mp-form-actions">
                <button type="submit" class="mp-btn mp-btn-success">
                    <i class="fas fa-check-circle"></i> Save Login Credentials
                </button>
                <a asp-action="Index" class="mp-btn mp-btn-secondary">
                    <i class="fas fa-times"></i> Cancel & Go Back
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function togglePass() {
            var x = document.getElementById("passInput");
            var icon = document.getElementById("eyeIcon");
            if (x.type === "password") {
                x.type = "text";
                icon.classList.replace("fa-eye", "fa-eye-slash");
            } else {
                x.type = "password";
                icon.classList.replace("fa-eye-slash", "fa-eye");
            }
        }
    </script>
}


                        <div class="form-group mb-4">
                            <label class="form-label fw-bold">New Secure Password</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-key"></i></span>
                             
                                <input name="Password" type="password" id="passInput" class="form-control"
                                       placeholder="Leave blank to keep current password" value="" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePass()">
                                    <i id="eyeIcon" class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Save Login Credentials
                            </button>
                            <a asp-action="Index" class="btn btn-light border">Cancel & Go Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function togglePass() {
            var x = document.getElementById("passInput");
            var icon = document.getElementById("eyeIcon");
            if (x.type === "password") {
                x.type = "text";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            } else {
                x.type = "password";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            }
        }
    </script>
}