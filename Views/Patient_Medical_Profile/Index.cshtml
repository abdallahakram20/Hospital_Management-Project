@model IEnumerable<Hospital_Management_Project.Models.Patient_Medical_Profile>
@{
    ViewData["Title"] = "Patient Medical Profiles";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --primary: #1A76D1;
        --primary-dk: #1560ad;
        --primary-light: #e8f2fc;
        --input-border: #dbe2ea; /* لون حدود متناسق ونظيف */
        --dark: #2C2D3F;
        --muted: #888;
        --light-bg: #f9f9f9;
        --white: #fff;
        --danger: #e74c3c;
        --warning: #f39c12;
        --success: #27ae60;
        --shadow: 0 4px 15px rgba(0,0,0,.07);
        --radius: 6px;
        --radius-round: 30px; /* الحواف الدائرية المطابقة تماماً */
        --tr: all .3s ease;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Poppins',sans-serif;
        font-size: 14px;
        color: var(--muted);
    }

    .mp-page {
        padding: 40px 30px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .mp-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        margin-bottom: 20px;
    }

        .mp-breadcrumb a {
            color: var(--primary);
            text-decoration: none;
        }

            .mp-breadcrumb a:hover {
                text-decoration: underline;
            }

        .mp-breadcrumb i {
            font-size: 10px;
            color: var(--muted);
        }

    .mp-page-header {
        background: var(--white);
        border-radius: var(--radius);
        padding: 28px 36px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        box-shadow: var(--shadow);
        border-left: 4px solid var(--primary);
    }

        .mp-page-header h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 4px;
        }

            .mp-page-header h2 i {
                color: var(--primary);
            }

        .mp-page-header p {
            font-size: 13px;
        }

    /* ==========================================================================
           تعديل صندوق البحث ليمتد بعرض الجدول بالكامل ويأخذ المظهر الدائري
           ========================================================================== */
    .mp-search-box {
        position: relative;
        margin-bottom: 24px;
        width: 100%; /* تمديد الصندوق بعرض الحاوية والجدول بالكامل */
        max-width: 100%; /* إلغاء الحد الأقصى القديم */
    }

    .mp-search-input {
        width: 100%;
        height: 50px; /* نفس طول حقل الـ Create */
        padding: 0 20px 0 45px; /* مسافة من اليسار للأيقونة */
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        color: var(--dark);
        background: var(--white);
        border: 1px solid var(--input-border);
        border-radius: var(--radius-round); /* حواف دائرية انسيابية 30px */
        transition: var(--tr);
    }

        .mp-search-input:focus {
            outline: none;
            border-color: #b5c7dc;
            box-shadow: 0 0 0 4px rgba(26,118,209,.05);
        }

        .mp-search-input::placeholder {
            color: #a0aab5;
        }

    .mp-search-icon {
        position: absolute;
        left: 18px; /* ضبط موضع العدسة المماثل تماماً */
        top: 50%;
        transform: translateY(-50%);
        color: #7c8ba1;
        font-size: 15px;
        pointer-events: none;
    }
    /* ========================================================================== */

    .mp-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 30px;
        box-shadow: var(--shadow);
    }

    .mp-table-wrap {
        overflow-x: auto;
        border-radius: var(--radius);
        border: 1px solid #eee;
    }

    .mp-table {
        width: 100%;
        border-collapse: collapse;
    }

        .mp-table thead th {
            background: var(--dark);
            color: #fff;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .5px;
            padding: 15px 18px;
            white-space: nowrap;
        }

        .mp-table tbody td {
            padding: 15px 18px;
            font-size: 14px;
            color: var(--dark);
            border-bottom: 1px solid #f5f5f5;
            background: var(--white);
            vertical-align: middle;
        }

        .mp-table tbody tr:last-child td {
            border-bottom: none;
        }

        .mp-table tbody tr:hover td {
            background: #f8fbff;
        }

    .mp-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
    }

    .mp-badge-blood {
        background: rgba(231,76,60,.1);
        color: var(--danger);
    }

    .mp-badge-abnormal {
        background: rgba(231,76,60,.1);
        color: var(--danger);
    }

    .mp-badge-normal {
        background: rgba(39,174,96,.1);
        color: var(--success);
    }

    .mp-badge-diabetic {
        background: rgba(243,156,18,.1);
        color: var(--warning);
    }

    .mp-truncate {
        max-width: 140px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: inline-block;
        vertical-align: bottom;
    }

    .mp-actions {
        display: flex;
        gap: 6px;
        flex-wrap: nowrap;
        justify-content: center;
    }

    .mp-empty {
        text-align: center;
        padding: 60px 20px;
    }

        .mp-empty i {
            font-size: 48px;
            color: #ddd;
            display: block;
            margin-bottom: 16px;
        }

        .mp-empty p {
            font-size: 15px;
        }

    .mp-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 10px 20px;
        border-radius: var(--radius);
        font-size: 13px;
        font-weight: 600;
        font-family: 'Poppins',sans-serif;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--tr);
        white-space: nowrap;
    }

    .mp-btn-primary {
        background: var(--primary);
        color: #fff;
    }

        .mp-btn-primary:hover {
            background: var(--primary-dk);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(26,118,209,.3);
        }

    .mp-btn-sm {
        padding: 6px 12px;
        font-size: 12px;
        border-radius: 6px;
        gap: 5px;
    }

    .mp-btn-info {
        background: #e0f2fe;
        color: #0284c7;
    }

        .mp-btn-info:hover {
            background: #0284c7;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(2, 132, 199, 0.2);
        }

    .mp-btn-print {
        background: #f3f4f6;
        color: #4b5563;
    }

        .mp-btn-print:hover {
            background: #4b5563;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(75, 85, 99, 0.2);
        }

    .mp-btn-warning {
        background: #fff8e1;
        color: #d97706;
    }

        .mp-btn-warning:hover {
            background: #d97706;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(217, 119, 6, 0.2);
        }

    .mp-btn-danger {
        background: #fdf2f2;
        color: #dc2626;
    }

        .mp-btn-danger:hover {
            background: #dc2626;
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(220, 38, 38, 0.2);
        }

    .pagination-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 30px;
    }

    .page-btn {
        border: 1px solid #cbd5e1;
        background: var(--white);
        color: var(--dark);
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .page-btn:hover:not(:disabled) {
            background: var(--primary-light);
            color: var(--primary);
            border-color: var(--primary);
        }

        .page-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            box-shadow: 0 4px 10px rgba(26, 118, 209, 0.3);
        }

        .page-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            background: #f8fafc;
        }

    .paginated-item {
        display: none;
    }

    @@media(max-width:768px) {
        .mp-page {
            padding: 20px 16px;
        }

        .mp-page-header {
            padding: 20px;
        }

        .mp-card {
            padding: 20px;
        }
    }
</style>

<div class="mp-page">
    <div class="mp-breadcrumb">
        <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <span>Medical Profiles</span>
    </div>
    <div class="mp-page-header">
        <div>
            <h2><i class="fas fa-file-medical-alt"></i> Patient Medical Records</h2>
            <p>Confidential clinical health summary data and metrics</p>
        </div>
        @if (!User.IsInRole("Patient"))
        {
            <a asp-action="Create" class="mp-btn mp-btn-primary">
                <i class="fas fa-plus-circle"></i> Create Medical Profile
            </a>
        }
    </div>
    <div class="mp-card">
        @if (!Model.Any())
        {
            <div class="mp-empty">
                <i class="fas fa-shield-virus"></i>
                <p>No medical profiles found for your account context.</p>
            </div>
        }
        else
        {
            @if (!User.IsInRole("Patient"))
            {
                <div class="mp-search-box">
                    <i class="fas fa-search mp-search-icon"></i>
                    <input type="text" id="tableSearchInput" class="mp-search-input" placeholder="Search by name, blood type, chronic disease..." />
                </div>
            }

            <div class="mp-table-wrap">
                <table class="mp-table">
                    <thead>
                        <tr>
                            <th><i class="fas fa-user" style="margin-right:6px;"></i>Patient Name</th>
                            <th><i class="fas fa-tint" style="margin-right:6px;"></i>Blood Type</th>
                            <th><i class="fas fa-heartbeat" style="margin-right:6px;"></i>Blood Pressure</th>
                            <th><i class="fas fa-procedures" style="margin-right:6px;"></i>Chronic Diseases</th>
                            <th><i class="fas fa-exclamation-triangle" style="margin-right:6px;"></i>Allergies</th>
                            <th><i class="fas fa-weight" style="margin-right:6px;"></i>Weight</th>
                            <th><i class="fas fa-pills" style="margin-right:6px;"></i>Diabetes</th>
                            <th style="text-align:center;"><i class="fas fa-cogs" style="margin-right:6px;"></i>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="medicalTableBody">
                        @foreach (var item in Model)
                        {
                            <tr class="paginated-item">
                                <td style="font-weight:700;" class="searchable-name">
                                    @(item.Patient != null ? $"{item.Patient.FName} {item.Patient.LName}" : "Unknown Patient")
                                </td>
                                <td class="searchable-blood"><span class="mp-badge mp-badge-blood"><i class="fas fa-tint"></i>@item.Blood_Type</span></td>
                                <td>
                                    @if (item.Blood_Pressure)
                                    {
                                        <span class="mp-badge mp-badge-abnormal"><i class="fas fa-arrow-up"></i> Abnormal</span>
                                    }
                                    else
                                    {
                                        <span class="mp-badge mp-badge-normal"><i class="fas fa-check"></i> Normal</span>
                                    }
                                </td>
                                <td class="searchable-disease"><span class="mp-truncate" title="@item.Chronic_Disease">@(string.IsNullOrEmpty(item.Chronic_Disease) ? "None" : item.Chronic_Disease)</span></td>
                                <td><span class="mp-truncate" title="@item.Allergies">@(string.IsNullOrEmpty(item.Allergies) ? "None" : item.Allergies)</span></td>
                                <td style="font-weight:600;">@item.Weight <span style="font-size:12px;color:var(--muted);">kg</span></td>
                                <td>
                                    @if (item.Diabets)
                                    {
                                        <span class="mp-badge mp-badge-diabetic"><i class="fas fa-exclamation-triangle"></i> Diabetic</span>
                                    }
                                    else
                                    {
                                        <span class="mp-badge mp-badge-normal"><i class="fas fa-shield-alt"></i> Normal</span>
                                    }
                                </td>
                                <td>
                                    <div class="mp-actions">
                                        <a asp-action="Details" asp-route-id="@item.ProfileId" class="mp-btn mp-btn-info mp-btn-sm">
                                            <i class="fas fa-eye"></i> Details
                                        </a>
                                        <a asp-action="PrintReport" asp-route-id="@item.ProfileId" class="mp-btn mp-btn-print mp-btn-sm">
                                            <i class="fas fa-print"></i> Print
                                        </a>
                                        @if (!User.IsInRole("Patient"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.ProfileId" class="mp-btn mp-btn-warning mp-btn-sm">
                                                <i class="fas fa-edit"></i> Edit
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.ProfileId" class="mp-btn mp-btn-danger mp-btn-sm">
                                                <i class="fas fa-trash"></i> Delete
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div id="paginationControls" class="pagination-container"></div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            if (window.history.pushState) {
                window.history.pushState(null, null, window.location.href);
                window.addEventListener('popstate', function () {
                    window.location.href = '@Url.Action("Index", "Home")';
                });
            }
            window.addEventListener('pageshow', function (event) {
                if (event.persisted || (typeof window.performance != "undefined" && window.performance.getEntriesByType("navigation")[0]?.type === "back_forward")) {
                    window.location.reload(true);
                }
            });
        })();
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const itemsPerPage = 10;
            const items = Array.from(document.querySelectorAll('.paginated-item'));
            const paginationControls = document.getElementById('paginationControls');
            const searchInput = document.getElementById('tableSearchInput');

            let filteredItems = [...items];
            let currentPage = 1;
            let totalPages = Math.ceil(filteredItems.length / itemsPerPage);

            if (items.length === 0) return;

            function displayPage(page) {
                currentPage = page;
                const start = (page - 1) * itemsPerPage;
                const end = start + itemsPerPage;

                items.forEach(item => item.style.display = 'none');

                filteredItems.forEach((item, index) => {
                    if (index >= start && index < end) {
                        item.style.display = 'table-row';
                    }
                });

                updatePaginationButtons();
            }

            function updatePaginationButtons() {
                if (!paginationControls) return;
                paginationControls.innerHTML = '';

                if (totalPages <= 1) return;

                const prevBtn = document.createElement('button');
                prevBtn.className = 'page-btn';
                prevBtn.innerHTML = '<i class="bi bi-chevron-left"></i>';
                prevBtn.disabled = currentPage === 1;
                prevBtn.onclick = () => displayPage(currentPage - 1);
                paginationControls.appendChild(prevBtn);

                for (let i = 1; i <= totalPages; i++) {
                    const pageBtn = document.createElement('button');
                    pageBtn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                    pageBtn.innerText = i;
                    pageBtn.onclick = () => displayPage(i);
                    paginationControls.appendChild(pageBtn);
                }

                const nextBtn = document.createElement('button');
                nextBtn.className = 'page-btn';
                nextBtn.innerHTML = '<i class="bi bi-chevron-right"></i>';
                nextBtn.disabled = currentPage === totalPages;
                nextBtn.onclick = () => displayPage(currentPage + 1);
                paginationControls.appendChild(nextBtn);
            }

            if (searchInput) {
                searchInput.addEventListener('input', function (e) {
                    const query = e.target.value.toLowerCase().trim();

                    filteredItems = items.filter(item => {
                        const name = item.querySelector('.searchable-name')?.textContent.toLowerCase() || '';
                        const blood = item.querySelector('.searchable-blood')?.textContent.toLowerCase() || '';
                        const disease = item.querySelector('.searchable-disease')?.textContent.toLowerCase() || '';

                        return name.includes(query) || blood.includes(query) || disease.includes(query);
                    });

                    totalPages = Math.ceil(filteredItems.length / itemsPerPage);
                    displayPage(1);
                });
            }

            displayPage(1);
        });
    </script>
}