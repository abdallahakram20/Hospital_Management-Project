@model Hospital_Management_Project.Models.Patient_Medical_Profile

@{
    ViewData["Title"] = "Clinical Profile Details";
}

<div class="container mt-4">
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Directory
        </a>

        @if (!User.IsInRole("Patient"))
        {
            <a asp-action="Edit" asp-route-id="@Model?.ProfileId" class="btn btn-sm btn-primary">
                <i class="bi bi-pencil-square"></i> Modify This Record
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 mx-auto" style="max-width: 850px;">
        <div class="card-header bg-dark text-white p-3 d-flex align-items-center justify-content-between">
            <div>
                <h4 class="mb-0"><i class="bi bi-file-earmark-medical"></i> Confidential Medical Summary</h4>
                <small class="text-white-50">Patient physiological diagnostics and clinical monitoring database</small>
            </div>
            <span class="badge bg-secondary p-2">ID: #@Model?.ProfileId</span>
        </div>

        <div class="card-body p-4">
            <div class="bg-light p-3 rounded mb-4 border-start border-primary border-4">
                <h5 class="text-primary mb-2"><i class="bi bi-person-card-heading"></i> Patient Identification</h5>
                <div class="row fs-5">
                    <div class="col-sm-3 fw-bold text-muted">Full Name:</div>
                    <div class="col-sm-9 fw-bold text-dark">
                        @(Model?.Patient != null ? $"{Model.Patient.FName} {Model.Patient.LName}" : "N/A")
                    </div>
                </div>
            </div>

            <h5 class="text-secondary mb-3 pb-2 border-bottom"><i class="bi bi-heart-pulse text-danger"></i> Physiological Metrics & Vitals</h5>
            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="p-3 border rounded text-center bg-white shadow-xs">
                        <div class="text-muted small fw-bold mb-1">BLOOD TYPE</div>
                        <span class="fs-3 fw-bold text-danger"><i class="bi bi-droplet-fill"></i> @Html.DisplayFor(model => model.Blood_Type)</span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="p-3 border rounded text-center bg-white shadow-xs">
                        <div class="text-muted small fw-bold mb-1">BLOOD PRESSURE</div>
                        <span class="fs-4 fw-bold text-info"><i class="bi bi-speedometer"></i> @Html.DisplayFor(model => model.Blood_Pressure)</span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="p-3 border rounded text-center bg-white shadow-xs">
                        <div class="text-muted small fw-bold mb-1">PATIENT WEIGHT</div>
                        <span class="fs-4 fw-bold text-dark"><i class="bi bi-person-lines-fill"></i> @Html.DisplayFor(model => model.Weight) <small class="text-muted fs-6">kg</small></span>
                    </div>
                </div>
            </div>

            <h5 class="text-secondary mb-3 pb-2 border-bottom"><i class="bi bi-shield-exclamation text-warning"></i> Pathological & Systemic Analysis</h5>
            <div class="row border rounded p-3 bg-white g-3">
                <div class="col-12 d-flex align-items-center py-2 border-bottom">
                    <div class="fw-bold text-secondary" style="min-width: 180px;"><i class="bi bi-capsule-hormone"></i> Diabetes Diagnosis:</div>
                    <div>
                        @if (Model != null && Model.Diabets)
                        {
                            <span class="badge bg-warning text-dark px-2 py-1 fs-6"><i class="bi bi-exclamation-triangle"></i> Confirmed Diabetic Case</span>
                        }
                        else
                        {
                            <span class="badge bg-success px-2 py-1 fs-6"><i class="bi bi-shield-check"></i> Non-Diabetic / Normal</span>
                        }
                    </div>
                </div>

                <div class="col-12 py-2 border-bottom">
                    <div class="fw-bold text-secondary mb-1"><i class="bi bi-activity"></i> Chronic Illnesses & Medical Conditions:</div>
                    <div class="p-2 bg-light rounded text-dark">
                        @(string.IsNullOrEmpty(Model?.Chronic_Disease) ? "No active chronic conditions declared on system." : Model.Chronic_Disease)
                    </div>
                </div>

                <div class="col-12 py-2">
                    <div class="fw-bold text-secondary mb-1"><i class="bi bi-shield-fill-x text-danger"></i> Environmental or Drug Allergies:</div>
                    <div class="p-2 bg-light rounded text-dark fw-bold @(string.IsNullOrEmpty(Model?.Allergies) ? "text-muted" : "text-danger")">
                        @(string.IsNullOrEmpty(Model?.Allergies) ? "No known allergen reactions or food/drug hypersensitivity." : Model.Allergies)
                    </div>
                </div>
            </div>
        </div>

        <div class="card-footer bg-light text-end p-2 text-muted small px-3">
            <i class="bi bi-lock-fill"></i> Authorized Clinical Network Environment Access Only.
        </div>
    </div>
</div>