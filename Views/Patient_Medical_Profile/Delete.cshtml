@model Hospital_Management_Project.Models.Patient_Medical_Profile

@{
    ViewData["Title"] = "Remove Medical Record";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Cancel and Go Back
        </a>
    </div>

    <div class="alert alert-danger d-flex align-items-center shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill fs-3 me-3"></i>
        <div>
            <h5 class="alert-heading mb-1 fw-bold">Critical Action Request</h5>
            <p class="mb-0">Are you completely sure you want to permanently delete this patient's medical profile? This action is irreversible and clinical history parameters will be lost.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mx-auto" style="max-width: 800px;">
        <div class="card-header bg-danger text-white p-3">
            <h5 class="mb-0"><i class="bi bi-file-earmark-x"></i> Medical Record Pending Deletion</h5>
        </div>

        <div class="card-body p-4">
            <div class="bg-light p-3 rounded mb-4 border-start border-danger border-4">
                <span class="text-muted small fw-bold block mb-1">PATIENT IDENTITY</span>
                <h5 class="text-dark mb-0 fw-bold">
                    @(Model?.Patient != null ? $"{Model.Patient.FName} {Model.Patient.LName}" : "N/A")
                </h5>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="p-2 border rounded text-center bg-white">
                        <small class="text-muted fw-bold d-block mb-1">BLOOD TYPE</small>
                        <span class="fw-bold text-danger">@Html.DisplayFor(model => model.Blood_Type)</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-2 border rounded text-center bg-white">
                        <small class="text-muted fw-bold d-block mb-1">BLOOD PRESSURE</small>
                        <span class="fw-bold text-info">@Html.DisplayFor(model => model.Blood_Pressure)</span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="p-2 border rounded text-center bg-white">
                        <small class="text-muted fw-bold d-block mb-1">WEIGHT</small>
                        <span class="fw-bold text-dark">@Html.DisplayFor(model => model.Weight) kg</span>
                    </div>
                </div>
            </div>

            <div class="border rounded p-3 bg-white">
                <div class="row g-2">
                    <div class="col-12 py-1 border-bottom d-flex align-items-center">
                        <span class="fw-bold text-secondary me-2" style="min-width: 150px;">Diabetes Diagnosis:</span>
                        <div>
                            @if (Model != null && Model.Diabets)
                            {
                                <span class="badge bg-warning text-dark"><i class="bi bi-exclamation-triangle"></i> Diabetic</span>
                            }
                            else
                            {
                                <span class="badge bg-success"><i class="bi bi-shield-check"></i> Normal / Non-Diabetic</span>
                            }
                        </div>
                    </div>
                    <div class="col-12 py-1 border-bottom">
                        <span class="fw-bold text-secondary d-block mb-1">Chronic Diseases:</span>
                        <p class="mb-0 text-dark ps-2 bg-light rounded py-1">@(string.IsNullOrEmpty(Model?.Chronic_Disease) ? "None" : Model.Chronic_Disease)</p>
                    </div>
                    <div class="col-12 py-1">
                        <span class="fw-bold text-secondary d-block mb-1">Allergies:</span>
                        <p class="mb-0 text-danger ps-2 bg-light rounded py-1">@(string.IsNullOrEmpty(Model?.Allergies) ? "No known allergies" : Model.Allergies)</p>
                    </div>
                </div>
            </div>

            <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                <form asp-action="Delete">
                    <input type="hidden" asp-for="ProfileId" />
                    <a asp-action="Index" class="btn btn-light border">Cancel and Keep Record</a>
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash-fill"></i> Confirm Absolute Deletion
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>