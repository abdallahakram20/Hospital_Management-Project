@model Hospital_Management_Project.Models.Patient_Medical_Profile

@{
    ViewData["Title"] = "Remove Medical Record";
    Layout = null;
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    :root {
        --primary: #1A76D1;
        --primary-dk: #1560ad;
        --dark: #2C2D3F;
        --muted: #888;
        --light-bg: #f9f9f9;
        --white: #fff;
        --danger: #e74c3c;
        --shadow: 0 4px 15px rgba(0,0,0,.07);
        --radius: 6px;
        --tr: all .3s ease;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Poppins',sans-serif;
        font-size: 14px;
        color: var(--muted);
    }

    .mp-page {
        padding: 40px 30px;
        max-width: 900px;
        margin: 0 auto;
    }

    .mp-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        margin-bottom: 20px;
    }

        .mp-breadcrumb a {
            color: var(--primary);
            text-decoration: none;
        }

            .mp-breadcrumb a:hover {
                text-decoration: underline;
            }

        .mp-breadcrumb i {
            font-size: 10px;
            color: var(--muted);
        }

    .mp-page-header {
        background: var(--white);
        border-radius: var(--radius);
        padding: 28px 36px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        box-shadow: var(--shadow);
        border-left: 4px solid var(--danger);
    }

        .mp-page-header h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 4px;
        }

            .mp-page-header h2 i {
                color: var(--danger);
            }

        .mp-page-header p {
            font-size: 13px;
        }

    .mp-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 36px;
        box-shadow: var(--shadow);
    }

    /* Form grid */
    .mp-form-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 22px;
        margin-bottom: 32px;
    }

    .mp-form-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

        .mp-form-group.full {
            grid-column: span 2;
        }

    .mp-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--dark);
        text-transform: uppercase;
        letter-spacing: .5px;
        display: flex;
        align-items: center;
        gap: 7px;
    }

        .mp-label i {
            color: var(--primary);
            font-size: 13px;
        }

    .mp-input, .mp-select {
        height: 46px;
        border: 1px solid #e0e0e0;
        border-radius: var(--radius);
        padding: 0 16px;
        font-size: 14px;
        font-family: 'Poppins',sans-serif;
        color: var(--dark);
        background: var(--white);
        transition: var(--tr);
        width: 100%;
    }

        .mp-input:focus, .mp-select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(26,118,209,.1);
        }

    .mp-select {
        cursor: pointer;
    }

    .mp-pass-wrap {
        position: relative;
    }

        .mp-pass-wrap .mp-input {
            padding-right: 44px;
        }

    .mp-eye-btn {
        position: absolute;
        right: 12px;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        color: var(--muted);
        font-size: 15px;
        padding: 4px;
    }

        .mp-eye-btn:hover {
            color: var(--primary);
        }

    .mp-field-error {
        color: var(--danger);
        font-size: 12px;
        font-weight: 500;
    }

    .mp-divider {
        border: none;
        border-top: 1px solid #f0f0f0;
        margin-bottom: 28px;
    }

    /* Buttons */
    .mp-form-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .mp-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 12px 28px;
        border-radius: var(--radius);
        font-size: 14px;
        font-weight: 600;
        font-family: 'Poppins',sans-serif;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--tr);
        white-space: nowrap;
    }

    .mp-btn-primary {
        background: var(--primary);
        color: #fff;
    }

        .mp-btn-primary:hover {
            background: var(--primary-dk);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(26,118,209,.3);
        }

    .mp-btn-secondary {
        background: var(--light-bg);
        color: var(--dark);
        border: 1px solid #e0e0e0;
    }

        .mp-btn-secondary:hover {
            background: #eee;
            color: var(--dark);
        }

    @@media (max-width:768px) {
        .mp-page {
            padding: 20px 16px;
        }

        .mp-page-header {
            padding: 20px;
        }

        .mp-card {
            padding: 22px;
        }

        .mp-form-grid {
            grid-template-columns: 1fr;
        }

        .mp-form-group.full {
            grid-column: span 1;
        }

        .mp-form-actions {
            flex-direction: column;
        }

        .mp-btn {
            justify-content: center;
        }
    }
</style>

<div class="mp-page">

    <div class="mp-breadcrumb">
        <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <a asp-action="Index">Medical Records</a>
        <i class="fas fa-chevron-right"></i>
        <span>Delete</span>
    </div>

    <div class="mp-page-header">
        <div>
            <h2><i class="fas fa-exclamation-triangle"></i> Critical Action Request</h2>
            <p>Are you completely sure you want to permanently delete this patient's medical profile? This action is irreversible.</p>
        </div>
    </div>

    <div class="mp-card">
        <form asp-action="Delete">
            <input type="hidden" asp-for="ProfileId" />

            <div class="mp-form-grid">
                <div class="mp-form-group full">
                    <label class="mp-label"><i class="fas fa-user"></i> Patient Identity</label>
                    <input class="mp-input" readonly value="@(Model?.Patient != null ? $"{Model.Patient.FName} {Model.Patient.LName}" : "N/A")" />
                </div>

                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-tint" style="color: var(--danger);"></i> Blood Type</label>
                    <input class="mp-input" readonly value="@Html.DisplayFor(model => model.Blood_Type)" style="font-weight: 600; color: var(--danger);" />
                </div>

                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-heartbeat"></i> Blood Pressure</label>
                    <input class="mp-input" readonly value="@Html.DisplayFor(model => model.Blood_Pressure)" />
                </div>

                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-weight"></i> Weight</label>
                    <input class="mp-input" readonly value="@Html.DisplayFor(model => model.Weight) kg" />
                </div>

                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-capsules"></i> Diabetes Diagnosis</label>
                    <input class="mp-input" readonly value="@(Model != null && Model.Diabets ? "Diabetic" : "Normal / Non-Diabetic")" />
                </div>

                <div class="mp-form-group full">
                    <label class="mp-label"><i class="fas fa-notes-medical"></i> Chronic Diseases</label>
                    <input class="mp-input" readonly value="@(string.IsNullOrEmpty(Model?.Chronic_Disease) ? "None" : Model.Chronic_Disease)" />
                </div>

                <div class="mp-form-group full">
                    <label class="mp-label"><i class="fas fa-allergies"></i> Allergies</label>
                    <input class="mp-input" readonly value="@(string.IsNullOrEmpty(Model?.Allergies) ? "No known allergies" : Model.Allergies)" style="color: var(--danger);" />
                </div>
            </div>

            <hr class="mp-divider" />

            <div class="mp-form-actions">
                <button type="submit" class="mp-btn mp-btn-primary" style="background: var(--danger);">
                    <i class="fas fa-trash-alt"></i> Confirm Absolute Deletion
                </button>
                <a asp-action="Index" class="mp-btn mp-btn-secondary">
                    <i class="fas fa-arrow-left"></i> Cancel and Keep Record
                </a>
            </div>
        </form>
    </div>
</div>