@model Hospital_Management_Project.Models.Patient_Medical_Profile

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>
<h4>Patient Medical Profile</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="PatientId" class="control-label">Patient Name</label>
                <select asp-for="PatientId" class="form-control" asp-items="ViewBag.PatientId">
                    <option value="">-- Select Patient --</option>
                </select>
                <span asp-validation-for="PatientId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Blood_Type" class="control-label"></label>
                <input asp-for="Blood_Type" class="form-control" />
                <span asp-validation-for="Blood_Type" class="text-danger"></span>
            </div>

            <div class="form-group form-check mb-3">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Blood_Pressure" /> @Html.DisplayNameFor(model => model.Blood_Pressure)
                </label>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Chronic_Disease" class="control-label"></label>
                <input asp-for="Chronic_Disease" class="form-control" />
                <span asp-validation-for="Chronic_Disease" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Allergies" class="control-label"></label>
                <input asp-for="Allergies" class="form-control" />
                <span asp-validation-for="Allergies" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Weight" class="control-label"></label>
                <input asp-for="Weight" class="form-control" />
                <span asp-validation-for="Weight" class="text-danger"></span>
            </div>

            <div class="form-group form-check mb-3">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Diabets" /> @Html.DisplayNameFor(model => model.Diabets)
                </label>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}