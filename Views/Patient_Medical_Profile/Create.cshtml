@model Hospital_Management_Project.Models.Patient_Medical_Profile

@{
    ViewData["Title"] = "Create Medical Profile";
}

<div class="container mt-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Record Directory
        </a>
    </div>

    <div class="card shadow-sm border-0 mx-auto" style="max-width: 750px;">
        <div class="card-header bg-primary text-white p-3">
            <h4 class="mb-0"><i class="bi bi-file-earmark-medical-fill"></i> Create New Patient Medical Profile</h4>
            <small class="text-white-50">Register baseline physiological metrics, vitals, and chronic diagnostic parameters</small>
        </div>

        <div class="card-body p-4">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="PatientId" class="form-label fw-bold"><i class="bi bi-person-fill"></i> Select Patient</label>
                            <select asp-for="PatientId" class="form-select border-primary" asp-items="ViewBag.PatientId">
                                <option value="">-- Select Patient --</option>
                            </select>
                            <span asp-validation-for="PatientId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Blood_Type" class="form-label fw-bold"><i class="bi bi-droplet-fill text-danger"></i> Blood Type</label>
                            <select asp-for="Blood_Type" class="form-select">
                                <option value="">Select Blood Type...</option>
                                <option value="A+">A+</option>
                                <option value="A-">A-</option>
                                <option value="B+">B+</option>
                                <option value="B-">B-</option>
                                <option value="O+">O+</option>
                                <option value="O-">O-</option>
                                <option value="AB+">AB+</option>
                                <option value="AB-">AB-</option>
                            </select>
                            <span asp-validation-for="Blood_Type" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Weight" class="form-label fw-bold"><i class="bi bi-speedometer2"></i> Patient Weight</label>
                            <div class="input-group">
                                <input asp-for="Weight" class="form-control" type="number" step="0.1" placeholder="e.g. 70.0" />
                                <span class="input-group-text">kg</span>
                            </div>
                            <span asp-validation-for="Weight" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Blood_Pressure" class="form-label fw-bold"><i class="bi bi-heart-pulse-fill text-warning"></i> Blood Pressure</label>
                            <input asp-for="Blood_Pressure" class="form-control" placeholder="e.g. 120/80 mmHg" />
                            <span asp-validation-for="Blood_Pressure" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check form-switch p-3 border rounded w-100 bg-light" style="padding-left: 3.5rem !important;">
                            <input class="form-check-input" type="checkbox" asp-for="Diabets" id="diabetsSwitch" />
                            <label class="form-check-label fw-bold text-dark" for="diabetsSwitch">
                                <i class="bi bi-capsule-hormone text-primary"></i> Is Diabetic? (Diabetes Mellitus (DM) )
                            </label>
                        </div>
                    </div>

                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="Chronic_Disease" class="form-label fw-bold"><i class="bi bi-activity"></i> Chronic Illnesses & Medical Conditions</label>
                            <textarea asp-for="Chronic_Disease" class="form-control" rows="2" placeholder="List chronic conditions (e.g. Asthma, Hypertension) or write 'None'"></textarea>
                            <span asp-validation-for="Chronic_Disease" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="Allergies" class="form-label fw-bold"><i class="bi bi-exclamation-triangle-fill text-danger"></i> Environmental or Drug Allergies</label>
                            <textarea asp-for="Allergies" class="form-control" rows="2" placeholder="List known allergies (e.g. Penicillin, Peanuts) or write 'None'"></textarea>
                            <span asp-validation-for="Allergies" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <a asp-action="Index" class="btn btn-light border">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-plus-circle"></i> Create Medical Profile
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}