@model Hospital_Management_Project.Models.Patient_Medical_Profile
@{
    ViewData["Title"] = "Create Medical Profile";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
<link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.css" rel="stylesheet" />

<style>
    :root {
        --primary: #1A76D1;
        --primary-dk: #1560ad;
        --dark: #2C2D3F;
        --muted: #888;
        --light-bg: #f9f9f9;
        --white: #fff;
        --danger: #e74c3c;
        --shadow: 0 4px 15px rgba(0,0,0,.07);
        --radius: 6px;
        --radius-round: 30px; /* الحواف الدائرية المطابقة للصورة */
        --tr: all .3s ease
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box
    }

    body {
        font-family: 'Poppins',sans-serif;
        font-size: 14px;
        color: var(--muted)
    }

    .mp-page {
        padding: 40px 30px;
        max-width: 860px;
        margin: 0 auto
    }

    .mp-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        margin-bottom: 20px
    }

        .mp-breadcrumb a {
            color: var(--primary);
            text-decoration: none
        }

            .mp-breadcrumb a:hover {
                text-decoration: underline
            }

        .mp-breadcrumb i {
            font-size: 10px;
            color: var(--muted)
        }

    .mp-page-header {
        background: var(--white);
        border-radius: var(--radius);
        padding: 28px 36px;
        margin-bottom: 28px;
        box-shadow: var(--shadow);
        border-left: 4px solid var(--primary)
    }

        .mp-page-header h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 4px
        }

            .mp-page-header h2 i {
                color: var(--primary)
            }

        .mp-page-header p {
            font-size: 13px
        }

    .mp-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 36px;
        box-shadow: var(--shadow)
    }

    .mp-form-grid {
        display: grid;
        grid-template-columns: repeat(2,1fr);
        gap: 22px;
        margin-bottom: 32px
    }

    .mp-form-group {
        display: flex;
        flex-direction: column;
        gap: 6px
    }

        .mp-form-group.full {
            grid-column: span 2
        }

    .mp-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--dark);
        text-transform: uppercase;
        letter-spacing: .5px;
        display: flex;
        align-items: center;
        gap: 7px
    }

        .mp-label i {
            color: var(--primary);
            font-size: 13px
        }

    .mp-input, .mp-select, .mp-textarea {
        border: 1px solid #e0e0e0;
        border-radius: var(--radius);
        padding: 0 16px;
        font-size: 14px;
        font-family: 'Poppins',sans-serif;
        color: var(--dark);
        background: var(--white);
        transition: var(--tr);
        width: 100%
    }

    .mp-input, .mp-select {
        height: 46px
    }

    .mp-textarea {
        padding: 12px 16px;
        min-height: 90px;
        resize: vertical
    }

        .mp-input:focus, .mp-select:focus, .mp-textarea:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(26,118,209,.1)
        }

    /* ==========================================================================
           تعديل ستايل Tom Select السحري ليصبح مطابقاً لشريط بحث الـ Index تماماً
           ========================================================================== */

    /* الحاوية الخارجية وعلامة البحث المخصصة */
    .mp-search-wrapper {
        position: relative;
        width: 100%;
    }

        /* إجبار التغليف الخاص بـ Tom Select على أخذ المظهر الدائري النظيف */
        .mp-search-wrapper .ts-wrapper.single .ts-control {
            border: 1px solid #dbe2ea !important;
            border-radius: var(--radius-round) !important; /* حواف دائرية 30px */
            height: 50px !important;
            padding: 0 20px 0 45px !important; /* ترك مساحة للأيقونة على اليسار */
            font-family: 'Poppins', sans-serif !important;
            font-size: 14px !important;
            box-shadow: none !important;
            background-color: var(--white) !important;
            display: flex !important;
            align-items: center !important;
            transition: var(--tr);
        }

        /* تأثير التركيز (Focus) على الحقل الدائري */
        .mp-search-wrapper .ts-wrapper.single.focus .ts-control {
            border-color: #b5c7dc !important;
            box-shadow: 0 0 0 4px rgba(26, 118, 209, 0.05) !important;
        }

        /* تنسيق النص المكتوب داخل الحقل */
        .mp-search-wrapper .ts-wrapper.single .ts-control input {
            font-family: 'Poppins', sans-serif !important;
            font-size: 14px !important;
            color: var(--dark) !important;
        }

        .mp-search-wrapper .ts-wrapper.single .ts-control .item {
            color: var(--dark) !important;
        }

        /* وضع أيقونة العدسة في نفس مكان الصورة الثابتة */
        .mp-search-wrapper .custom-search-icon {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #7c8ba1;
            font-size: 15px;
            z-index: 10;
            pointer-events: none;
        }

        /* إلغاء سهم القائمة المنسدلة الافتراضي لكي يظهر كأنه حقل بحث عادي فقط */
        .mp-search-wrapper .ts-wrapper.single .ts-control::after {
            display: none !important;
        }

    /* تنسيق قائمة الاقتراحات المنسدلة الناتجة عن البحث */
    .ts-dropdown {
        border-radius: var(--radius) !important;
        border: 1px solid #e0e0e0 !important;
        box-shadow: var(--shadow) !important;
        font-family: 'Poppins', sans-serif !important;
        margin-top: 6px !important;
        z-index: 1000 !important;
    }

        .ts-dropdown .option {
            padding: 12px 16px !important;
            font-size: 13.5px !important;
            color: var(--dark) !important;
        }

            .ts-dropdown .option.active {
                background-color: var(--primary) !important;
                color: white !important;
            }

            .ts-dropdown .option:hover {
                background-color: #f8fbff !important;
            }

            /* إخفاء خيار الـ Placeholder الفارغ تماماً من القائمة */
            .ts-dropdown .option[data-value=""] {
                display: none !important;
            }

    /* ========================================================================== */

    .mp-input-group {
        display: flex
    }

        .mp-input-group .mp-input {
            border-radius: var(--radius) 0 0 var(--radius)
        }

    .mp-addon {
        background: #f0f0f0;
        border: 1px solid #e0e0e0;
        border-left: none;
        border-radius: 0 var(--radius) var(--radius) 0;
        padding: 0 14px;
        display: flex;
        align-items: center;
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        white-space: nowrap
    }

    .mp-switch-row {
        display: flex;
        align-items: center;
        gap: 12px;
        height: 46px;
        padding: 0 4px
    }

    .mp-switch {
        position: relative;
        width: 44px;
        height: 24px;
        flex-shrink: 0
    }

        .mp-switch input {
            opacity: 0;
            width: 0;
            height: 0;
            position: absolute
        }

    .mp-slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: #ccc;
        border-radius: 24px;
        transition: .3s
    }

        .mp-slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background: #fff;
            border-radius: 50%;
            transition: .3s
        }

    input:checked + .mp-slider {
        background: var(--primary)
    }

        input:checked + .mp-slider:before {
            transform: translateX(20px)
        }

    .mp-switch-label {
        font-size: 13px;
        font-weight: 500;
        color: var(--dark)
    }

    .mp-field-error {
        color: var(--danger);
        font-size: 12px;
        font-weight: 500
    }

    .mp-divider {
        border: none;
        border-top: 1px solid #f0f0f0;
        margin-bottom: 28px
    }

    .mp-form-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap
    }

    .mp-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        padding: 12px 28px;
        border-radius: var(--radius);
        font-size: 14px;
        font-weight: 600;
        font-family: 'Poppins',sans-serif;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--tr);
        white-space: nowrap
    }

    .mp-btn-primary {
        background: var(--primary);
        color: #fff
    }

        .mp-btn-primary:hover {
            background: var(--primary-dk);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(26,118,209,.3)
        }

    .mp-btn-secondary {
        background: var(--light-bg);
        color: var(--dark);
        border: 1px solid #e0e0e0
    }

        .mp-btn-secondary:hover {
            background: #eee;
            color: var(--dark)
        }

    @@media(max-width:768px) {
        .mp-page {
            padding: 20px 16px
        }

        .mp-card {
            padding: 22px
        }

        .mp-form-grid {
            grid-template-columns: 1fr
        }

        .mp-form-group.full {
            grid-column: span 1
        }

        .mp-form-actions {
            flex-direction: column
        }

        .mp-btn {
            justify-content: center
        }
    }
</style>

<div class="mp-page">
    <div class="mp-breadcrumb">
        <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <a asp-action="Index">Medical Profiles</a>
        <i class="fas fa-chevron-right"></i>
        <span>Create</span>
    </div>

    <div class="mp-page-header">
        <h2><i class="fas fa-file-medical"></i> Create Medical Profile</h2>
        <p>Register baseline physiological metrics, vitals, and chronic diagnostic parameters</p>
    </div>

    <div class="mp-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="mp-field-error" style="margin-bottom:18px;"></div>

            <div class="mp-form-grid">

                <div class="mp-form-group full">
                    <div class="mp-search-wrapper">
                        <i class="fas fa-search custom-search-icon"></i>
                        <select asp-for="PatientId" id="patientSearchSelect" asp-items="ViewBag.PatientId" style="width: 100%;">
                            <option value="" disabled selected hidden>Search by Patient Name...</option>
                        </select>
                    </div>
                    <span asp-validation-for="PatientId" class="mp-field-error"></span>
                </div>

                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-tint"></i> Blood Type</label>
                    <select asp-for="Blood_Type" class="mp-select">
                        <option value="">Select Blood Type...</option>
                        <option value="A+">A+</option>
                        <option value="A-">A-</option>
                        <option value="B+">B+</option>
                        <option value="B-">B-</option>
                        <option value="O+">O+</option>
                        <option value="O-">O-</option>
                        <option value="AB+">AB+</option>
                        <option value="AB-">AB-</option>
                    </select>
                    <span asp-validation-for="Blood_Type" class="mp-field-error"></span>
                </div>

                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-weight"></i> Patient Weight</label>
                    <div class="mp-input-group">
                        <input asp-for="Weight" class="mp-input" type="number" step="0.1" placeholder="e.g. 70.0" />
                        <span class="mp-addon">kg</span>
                    </div>
                    <span asp-validation-for="Weight" class="mp-field-error"></span>
                </div>

                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-heartbeat"></i> Blood Pressure</label>
                    <div class="mp-switch-row">
                        <label class="mp-switch">
                            <input asp-for="Blood_Pressure" type="checkbox" />
                            <span class="mp-slider"></span>
                        </label>
                        <span class="mp-switch-label">Abnormal Blood Pressure?</span>
                    </div>
                    <span asp-validation-for="Blood_Pressure" class="mp-field-error"></span>
                </div>

                <div class="mp-form-group">
                    <label class="mp-label"><i class="fas fa-pills"></i> Diabetes Status</label>
                    <div class="mp-switch-row">
                        <label class="mp-switch">
                            <input asp-for="Diabets" type="checkbox" />
                            <span class="mp-slider"></span>
                        </label>
                        <span class="mp-switch-label">Is Diabetic?</span>
                    </div>
                </div>

                <div class="mp-form-group full">
                    <label class="mp-label"><i class="fas fa-procedures"></i> Chronic Illnesses &amp; Medical Conditions</label>
                    <textarea asp-for="Chronic_Disease" class="mp-textarea" placeholder="List chronic conditions (e.g. Asthma, Hypertension) or write 'None'"></textarea>
                    <span asp-validation-for="Chronic_Disease" class="mp-field-error"></span>
                </div>

                <div class="mp-form-group full">
                    <label class="mp-label"><i class="fas fa-exclamation-triangle"></i> Environmental or Drug Allergies</label>
                    <textarea asp-for="Allergies" class="mp-textarea" placeholder="List known allergies (e.g. Penicillin, Peanuts) or write 'None'"></textarea>
                    <span asp-validation-for="Allergies" class="mp-field-error"></span>
                </div>
            </div>

            <hr class="mp-divider" />

            <div class="mp-form-actions">
                <button type="submit" class="mp-btn mp-btn-primary"><i class="fas fa-plus-circle"></i> Create Medical Profile</button>
                <a asp-action="Index" class="mp-btn mp-btn-secondary"><i class="fas fa-arrow-left"></i> Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script type="text/javascript">
        document.addEventListener('DOMContentLoaded', function() {
        new TomSelect('#patientSearchSelect', {
        create: false,
        sortField: 'text',
        searchField: ['text'],
        placeholder: 'Search by Patient Name...',
        allowEmptyOption: false,
        closeAfterSelect: true,
        maxOptions: 10,
        hideSelected: false,
        persist: false,
        render: {
        option: function(data, escape) {
        if (data.value === '') {
        return '';
        }
        return '<div>' + escape(data.text) + '</div>';
        }
        }
        });
        });
    </script>
}