@model Hospital_Management_Project.Models.Patient_Medical_Profile

@{
    ViewData["Title"] = "Patient Medical Profile";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    :root {
        --primary: #1A76D1;
        --primary-dk: #1560ad;
        --dark: #2C2D3F;
        --muted: #64748b;
        --light-bg: #f8fafc;
        --white: #fff;
        --border: #e2e8f0;
        --danger: #e74c3c;
        --warning: #f39c12;
        --success: #27ae60;
        --shadow: 0 4px 15px rgba(0,0,0,.05);
        --radius: 8px;
        --tr: all 0.3s ease;
    }

    .profile-page {
        padding: 40px 30px;
        max-width: 950px;
        margin: 0 auto;
        font-family: 'Poppins', sans-serif;
    }

    /* Breadcrumb */
    .profile-breadcrumb {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        margin-bottom: 20px;
    }

        .profile-breadcrumb a {
            color: var(--primary);
            text-decoration: none;
            transition: var(--tr);
        }

            .profile-breadcrumb a:hover {
                text-decoration: underline;
                color: var(--primary-dk);
            }

        .profile-breadcrumb i {
            font-size: 10px;
            color: var(--muted);
        }

    /* Page Header */
    .profile-header {
        background: var(--white);
        border-radius: var(--radius);
        padding: 28px 36px;
        margin-bottom: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 16px;
        box-shadow: var(--shadow);
        border-left: 4px solid var(--primary);
    }

        .profile-header h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0 0 4px 0;
        }

            .profile-header h2 i {
                color: var(--primary);
            }

        .profile-header p {
            font-size: 13px;
            color: var(--muted);
            margin: 0;
        }

    .header-actions {
        display: flex;
        gap: 12px;
    }

    /* Card & Grid */
    .profile-card {
        background: var(--white);
        border-radius: var(--radius);
        padding: 35px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
    }

    .profile-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 25px;
    }

    .info-group {
        background: var(--light-bg);
        padding: 18px 20px;
        border-radius: var(--radius);
        border-left: 4px solid var(--primary);
        transition: var(--tr);
    }

        .info-group:hover {
            box-shadow: 0 4px 10px rgba(26, 118, 209, 0.08);
            transform: translateY(-2px);
        }

    .info-label {
        font-size: 12px;
        color: var(--muted);
        text-transform: uppercase;
        font-weight: 600;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .info-label i {
            color: var(--primary);
            font-size: 14px;
        }

    .info-value {
        font-size: 16px;
        font-weight: 600;
        color: var(--dark);
        margin: 0;
    }

    .full-width {
        grid-column: 1 / -1;
    }

    /* Badges */
    .mp-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
    }

    .mp-badge-blood, .mp-badge-abnormal {
        background: #fdf2f2;
        color: var(--danger);
    }

    .mp-badge-normal {
        background: #f0fdf4;
        color: var(--success);
    }

    .mp-badge-diabetic {
        background: #fffbeb;
        color: var(--warning);
    }

    /* Buttons */
    .btn-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 20px;
        border-radius: var(--radius);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        border: none;
        transition: var(--tr);
    }

    .btn-back {
        background: #f1f5f9;
        color: #475569;
    }

        .btn-back:hover {
            background: #e2e8f0;
            color: #1e293b;
        }

    .btn-print {
        background: var(--primary);
        color: var(--white);
    }

        .btn-print:hover {
            background: var(--primary-dk);
            box-shadow: 0 4px 12px rgba(26, 118, 209, 0.2);
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .profile-page {
            padding: 20px 15px;
        }

        .profile-header {
            padding: 20px;
        }

        .profile-card {
            padding: 20px;
        }
    }

    @@media print {
        @@page {
            size: A4 portrait;
            margin: 15mm;
        }
        html, body, main, .container, .wrapper, #main-content {
            background: #fff !important;
            color: #000 !important;
            height: auto !important;
            overflow: visible !important;
            position: static !important;
            visibility: visible !important;
        }
        .profile-breadcrumb,
        .header-actions,
        nav, sidebar, footer, .navbar {
            display: none !important;
        }

        .profile-page {
            padding: 0 !important;
            margin: 0 !important;
            width: 100% !important;
            max-width: 100% !important;
        }

        .profile-header {
            border: 1px solid #cbd5e1 !important;
            border-left: 6px solid #1A76D1 !important;
            box-shadow: none !important;
            margin-bottom: 20px !important;
            padding: 20px !important;
        }

        .profile-card {
            box-shadow: none !important;
            border: none !important;
            padding: 0 !important;
        }
        .profile-grid {
            display: block !important;
        }

        .info-group {
            display: block !important;
            background: #f8fafc !important;
            border: 1px solid #e2e8f0 !important;
            border-left: 4px solid #1A76D1 !important;
            margin-bottom: 12px !important;
            padding: 12px 15px !important;
            page-break-inside: avoid;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        .info-value, .info-label {
            color: #000 !important;
        }
    }
</style>

<div class="profile-page">

    <div class="profile-breadcrumb">
        <a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a>
        <i class="fas fa-chevron-right"></i>
        <span>Medical Profile Details</span>
    </div>

    <div class="profile-header">
        <div>
            <h2><i class="fas fa-file-medical-alt"></i> Patient Medical Record</h2>
            <p>Confidential clinical health summary data and metrics</p>
        </div>
        <div class="header-actions">
            <a asp-action="Index" class="btn-action btn-back">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
            <button onclick="window.print()" class="btn-action btn-print">
                <i class="fas fa-print"></i> Print Report
            </button>
        </div>
    </div>

    <div class="profile-card">
        <div class="profile-grid">

            <div class="info-group full-width" style="border-left-color: var(--dark);">
                <div class="info-label"><i class="fas fa-user"></i> Patient Name</div>
                <div class="info-value" style="font-size: 18px; color: var(--dark);">
                    @(Model.Patient != null ? $"{Model.Patient.FName} {Model.Patient.LName}" : "Unknown Patient")
                </div>
            </div>

            <div class="info-group">
                <div class="info-label"><i class="fas fa-tint"></i> Blood Type</div>
                <div class="info-value">
                    <span class="mp-badge mp-badge-blood"><i class="fas fa-tint"></i> @Model.Blood_Type</span>
                </div>
            </div>

            <div class="info-group">
                <div class="info-label"><i class="fas fa-heartbeat"></i> Blood Pressure</div>
                <div class="info-value">
                    @if (Model.Blood_Pressure)
                    {
                        <span class="mp-badge mp-badge-abnormal"><i class="fas fa-arrow-up"></i> Abnormal</span>
                    }
                    else
                    {
                        <span class="mp-badge mp-badge-normal"><i class="fas fa-check"></i> Normal</span>
                    }
                </div>
            </div>

            <div class="info-group">
                <div class="info-label"><i class="fas fa-weight"></i> Weight</div>
                <div class="info-value">
                    @Model.Weight <span style="font-size:13px; color:var(--muted); font-weight:normal;">kg</span>
                </div>
            </div>

            <div class="info-group">
                <div class="info-label"><i class="fas fa-pills"></i> Diabetes Status</div>
                <div class="info-value">
                    @if (Model.Diabets)
                    {
                        <span class="mp-badge mp-badge-diabetic"><i class="fas fa-exclamation-triangle"></i> Diabetic</span>
                    }
                    else
                    {
                        <span class="mp-badge mp-badge-normal"><i class="fas fa-shield-alt"></i> Normal</span>
                    }
                </div>
            </div>

            <div class="info-group full-width">
                <div class="info-label"><i class="fas fa-procedures"></i> Chronic Diseases</div>
                <div class="info-value" style="font-weight: 500;">
                    @(string.IsNullOrEmpty(Model.Chronic_Disease) ? "None Reported" : Model.Chronic_Disease)
                </div>
            </div>

            <div class="info-group full-width">
                <div class="info-label"><i class="fas fa-exclamation-triangle"></i> Allergies</div>
                <div class="info-value" style="font-weight: 500;">
                    @(string.IsNullOrEmpty(Model.Allergies) ? "None Reported" : Model.Allergies)
                </div>
            </div>

        </div>
    </div>

</div>