@model Hospital_Management_Project.Models.Appointment
@{
    ViewData["Title"] = "Confirm Booking";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #f4f8fc;
    }

    .confirm-card {
        max-width: 500px;
        margin: 60px auto;
        background: white;
        padding: 40px;
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.03);
        text-align: center;
        border: 1px solid #e2e8f0;
    }

    .icon-box {
        width: 64px;
        height: 64px;
        background: #e8f2fc;
        color: #1A76D1;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        font-size: 28px;
    }

    .btn-confirm {
        background: #1A76D1;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 12px;
        font-weight: 600;
        width: 100%;
        margin-top: 20px;
        transition: all 0.2s;
    }

        .btn-confirm:hover {
            background: #145db3;
        }
</style>

<div class="confirm-card">
    <div class="icon-box"><i class="bi bi-calendar2-check"></i></div>
    <h3>Confirm Your Appointment</h3>
    <p class="text-muted">Are you sure you want to reserve this slot?</p>

    <div class="p-3 my-3 bg-light rounded-3 text-start">
        <p class="mb-1"><strong>Date:</strong> @Model.Visit_Date.ToString("dd MMMM yyyy")</p>
        <p class="mb-0"><strong>Time:</strong> @Model.Visit_Date.ToString("hh:mm tt")</p>
    </div>

    <form asp-action="ConfirmBookAppointment">
        <input type="hidden" asp-for="AppointmentId" />
        <button type="submit" class="btn-confirm">Yes, Book Now</button>
    </form>
    <a asp-action="Details" asp-route-id="@Model.StaffId" class="btn btn-link w-100 mt-2 text-decoration-none text-muted">Cancel</a>
</div>