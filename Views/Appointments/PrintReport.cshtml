@model Hospital_Management_Project.Models.Appointment
@{
    Layout = null;
}<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Medical Report - @Model.Patient?.FName @Model.Patient?.LName</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        :root {
            --primary: #1A76D1;
            --primary-dk: #1560ad;
            --dark: #2C2D3F;
            --muted: #64748b;
            --light-bg: #f8fafc;
            --white: #fff;
            --border: #e2e8f0;
            --shadow: 0 4px 15px rgba(0,0,0,.05);
            --radius: 8px;
            --tr: all 0.3s ease;
        }

        * {
            box-sizing: border-box;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        body, h1, h2, h3, h4, h5, h6, .btn-action, table, th, td, span, div, p {
            font-family: 'Cairo', sans-serif !important;
        }

        body {
            color: var(--dark);
            background-color: #e4ecee; 
            margin: 0;
            padding: 40px 0;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .profile-page {
            width: 100%;
            max-width: 900px;
            padding: 0 20px;
        }

        .profile-card {
            background: var(--white);
            border-radius: var(--radius);
            padding: 50px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
        }

        .hospital-branding {
            text-align: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--primary);
        }

        .hospital-branding h1 {
            color: var(--primary-dk);
            margin: 0 0 6px 0;
            font-size: 32px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .hospital-branding p {
            font-size: 14px;
            color: var(--muted);
            margin: 0;
        }

        .report-title {
            text-align: center;
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 35px;
            color: var(--dark);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .report-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
            border: 1px solid var(--border);
        }

        .report-table th {
            background-color: var(--light-bg);
            color: var(--primary-dk);
            font-weight: 700;
            font-size: 15px;
            padding: 16px;
            text-align: left;
            width: 250px;
            border-bottom: 1px solid var(--border);
            border-right: 1px solid var(--border);
        }

        .report-table td {
            padding: 16px;
            font-size: 15px;
            color: var(--dark);
            border-bottom: 1px solid var(--border);
            text-align: left;
            vertical-align: middle;
            font-weight: 500;
        }

        .signatures {
            margin-top: 80px;
            display: flex;
            justify-content: space-between;
            padding-top: 20px;
        }

        .sign-box {
            text-align: center;
            width: 250px;
        }

        .sign-title {
            font-size: 15px;
            font-weight: 700;
            color: var(--dark);
        }

        .sign-line {
            border-bottom: 1.5px dashed var(--dark);
            height: 50px;
            margin-bottom: 10px;
        }

        /* إصلاحات التنسيق للطباعة الفعلية لحل مشكلة الصفحة الممسوحة */
        @@media print {
            @@page {
                size: A4 portrait;
                margin: 12mm; /* تحديد هوامش مناسبة للورقة */
            }
            body { 
                background: #fff !important; 
                color: #000 !important;
                padding: 0 !important;
                margin: 0 !important;
            }
            .profile-page {
                max-width: 100% !important;
                padding: 0 !important;
                width: 100% !important;
            }
            .profile-card {
                box-shadow: none !important;
                border: none !important;
                padding: 10px 0 !important; /* تقليل بادينج الكارت لمنع اختفاء الجدول */
                width: 100% !important;
            }
            .report-table {
                width: 100% !important;
                page-break-inside: avoid; /* منع انقطاع الجدول */
            }
            .report-table th {
                background-color: #f8fafc !important; /* إجبار الخلفية الملونة على الظهور */
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
        }
    </style>
</head>
<body>
    <div class="profile-page">
        <div class="profile-card">
            <div class="hospital-branding">
                <h1><i class="fas fa-hospital"></i> Grand Hospital</h1>
                <p>123 Health Road, Medical District | Phone: +1 234 567 8900 | info@grandhospital.com</p>
            </div>

            <div class="report-title">
                Patient Medical Report
            </div>

            <table class="report-table">
                <tbody>
                    <tr>
                        <th><i class="fas fa-user"></i> Patient Name</th>
                        <td>@(Model.Patient?.FName) @(Model.Patient?.LName)</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-user-md"></i> Attending Physician</th>
                        <td>Dr. @(Model.Staff?.Fname) @(Model.Staff?.Lname)</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-calendar-alt"></i> Visit Date & Time</th>
                        <td>@Model.Visit_Date.ToString("yyyy-MM-dd | hh:mm tt")</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-comment-medical"></i> Reason for Visit</th>
                        <td>@(string.IsNullOrEmpty(Model.Reason) ? "N/A" : Model.Reason)</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-stethoscope"></i> Official Diagnosis</th>
                        <td style="color: var(--primary-dk); font-weight: 700;">@(string.IsNullOrEmpty(Model.Diagnosis) ? "Pending Clinical Check" : Model.Diagnosis)</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-pills"></i> Prescribed Medication</th>
                        <td>@(string.IsNullOrEmpty(Model.Medication) ? "None" : Model.Medication)</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-vial"></i> Required Tests</th>
                        <td>@(string.IsNullOrEmpty(Model.Common_tests) ? "None Required" : Model.Common_tests)</td>
                    </tr>
                    <tr>
                        <th><i class="fas fa-file-medical-alt"></i> Treatment Plan & Notes</th>
                        <td>
                            <strong>Plan:</strong> @(string.IsNullOrEmpty(Model.Treatment_Plan) ? "None" : Model.Treatment_Plan) <br/><br/>
                            <strong>Notes:</strong> @(string.IsNullOrEmpty(Model.Notes) ? "-" : Model.Notes)
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="signatures">
                <div class="sign-box">
                    <div class="sign-line"></div>
                    <span class="sign-title">Patient Signature</span>
                </div>
                <div class="sign-box">
                    <div class="sign-line"></div>
                    <span class="sign-title">Doctor Signature</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        window.addEventListener('load', function() {
            setTimeout(function() {
                window.print();
            }, 600); // تأخير بسيط بمقدار 600 مللي ثانية لضمان استقرار الأبعاد والنصوص
        });
    </script>
</body>
</html>