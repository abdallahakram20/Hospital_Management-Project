@model Hospital_Management_Project.Models.Appointment
@{
    ViewData["Title"] = "Edit Appointment";
    bool isPatient = User.IsInRole("Patient");
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --primary: #1A76D1;
        --primary-dark: #145db3;
        --primary-light: #e8f2fc;
        --primary-gradient: linear-gradient(135deg, #1A76D1, #3b92ec);
        --bg-page: #f4f8fc;
        --card-bg: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --input-bg: #f8fafc;
        --input-border: #cbd5e1;
        --danger: #ef4444;
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: var(--bg-page);
        color: var(--text-main);
        margin: 0;
        padding: 0;
    }

    .page-container {
        padding: 40px 20px;
        max-width: 950px;
        margin: 0 auto;
    }

    .form-card {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 10px 25px -5px rgba(26, 118, 209, 0.05), 0 4px 12px -2px rgba(0, 0, 0, 0.03);
        border: 1px solid rgba(26, 118, 209, 0.06);
    }

    .form-header {
        margin-bottom: 32px;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 20px;
    }

        .form-header h2 {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            margin: 0 0 6px 0;
        }

        .form-header p {
            color: var(--text-muted);
            margin: 0;
            font-size: 15px;
        }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, 11fr);
        gap: 24px;
    }

    .full-width {
        grid-column: span 2;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .custom-label {
        font-size: 14px;
        font-weight: 600;
        color: #475569;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .custom-input, .custom-select, .custom-textarea {
        background-color: var(--input-bg);
        border: 1px solid var(--input-border);
        border-radius: 12px;
        padding: 14px 16px;
        font-family: inherit;
        font-size: 15px;
        color: var(--text-main);
        transition: all 0.2s ease;
    }

    .custom-textarea {
        resize: vertical;
        min-height: 100px;
    }

        .custom-input:focus, .custom-select:focus, .custom-textarea:focus {
            outline: none;
            border-color: var(--primary);
            background-color: #ffffff;
            box-shadow: 0 0 0 4px var(--primary-light);
        }

    .medical-section {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 24px;
        margin-top: 24px;
    }

    .medical-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--primary-dark);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
        border-bottom: 2px solid var(--primary-light);
        padding-bottom: 8px;
    }

    .btn-submit {
        background: var(--primary-gradient);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 16px 32px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 4px 14px rgba(26, 118, 209, 0.25);
        transition: all 0.2s ease;
        margin-top: 32px;
        width: 100%;
        justify-content: center;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(26, 118, 209, 0.35);
        }

    .text-danger {
        font-size: 13px;
        color: var(--danger);
        font-weight: 500;
    }
</style>

<div class="page-container">
    <div class="form-card">
        <div class="form-header">
            <h2><i class="bi bi-pencil-square text-primary"></i> Edit Appointment</h2>
            <p>Update scheduling metrics, operational metadata, or medical details safely.</p>
        </div>

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="AppointmentId" />

            <div class="form-grid">
                @if (isPatient)
                {
                    <input type="hidden" asp-for="PatientId" />
                    <input type="hidden" asp-for="StaffId" />
                }
                else
                {
                    <div class="form-group">
                        <label asp-for="PatientId" class="custom-label"><i class="bi bi-person-fill"></i> Patient Name</label>
                        <select asp-for="PatientId" class="custom-select" asp-items="ViewBag.PatientId"></select>
                        <span asp-validation-for="PatientId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="StaffId" class="custom-label"><i class="bi bi-person-badge-fill"></i> Assigned Doctor</label>
                        <select asp-for="StaffId" class="custom-select" asp-items="ViewBag.StaffId"></select>
                        <span asp-validation-for="StaffId" class="text-danger"></span>
                    </div>
                }

                <div class="form-group @(isPatient ? "full-width" : "")">
                    <label asp-for="Visit_Date" class="custom-label"><i class="bi bi-calendar-event"></i> Visit Date & Time</label>
                    <input asp-for="Visit_Date" class="custom-input" type="datetime-local" />
                    <span asp-validation-for="Visit_Date" class="text-danger"></span>
                </div>

                @if (!isPatient)
                {
                    <div class="form-group">
                        <label asp-for="Status" class="custom-label"><i class="bi bi-check-circle-fill"></i> Appointment Status</label>
                        <select asp-for="Status" class="custom-select" asp-items="Html.GetEnumSelectList<Hospital_Management_Project.Models.AppointmentStatus>()"></select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                }

                <div class="form-group full-width">
                    <label asp-for="Reason" class="custom-label"><i class="bi bi-chat-left-text-fill"></i> Reason / Current Symptoms</label>
                    <textarea asp-for="Reason" class="custom-textarea" placeholder="Describe the medical motivation or checkup reasons..."></textarea>
                    <span asp-validation-for="Reason" class="text-danger"></span>
                </div>
            </div>

            @if (!isPatient)
            {
                <div class="medical-section">
                    <div class="medical-title">
                        <i class="bi bi-heart-pulse-fill"></i> Clinical Examination Records (Doctor / Staff Input Only)
                    </div>

                    <div class="form-grid">
                        <div class="form-group full-width">
                            <label asp-for="Diagnosis" class="custom-label"><i class="bi bi-clipboard2-pulse-fill text-danger"></i> Diagnosis <span class="text-danger">*</span></label>
                            <input asp-for="Diagnosis" class="custom-input" placeholder="Enter official medical diagnosis summary..." />
                            <span asp-validation-for="Diagnosis" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Medication" class="custom-label"><i class="bi bi-capsule"></i> Prescribed Medication</label>
                            <input asp-for="Medication" class="custom-input" placeholder="e.g., Amoxicillin 500mg, Paracetamol..." />
                            <span asp-validation-for="Medication" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Common_tests" class="custom-label"><i class="bi bi-droplet-fill"></i> Required Lab / Radiology Tests</label>
                            <input asp-for="Common_tests" class="custom-input" placeholder="e.g., Full Blood Count, Chest X-Ray..." />
                            <span asp-validation-for="Common_tests" class="text-danger"></span>
                        </div>

                        <div class="form-group full-width">
                            <label asp-for="Treatment_Plan" class="custom-label"><i class="bi bi-journal-medical"></i> Next Steps & Treatment Plan</label>
                            <textarea asp-for="Treatment_Plan" class="custom-textarea" placeholder="Outline recommendations, follow-up slots, or specialized therapy advice..."></textarea>
                            <span asp-validation-for="Treatment_Plan" class="text-danger"></span>
                        </div>

                        <div class="form-group full-width">
                            <label asp-for="Notes" class="custom-label"><i class="bi bi-sticky-fill"></i> Private Clinical Notes</label>
                            <textarea asp-for="Notes" class="custom-textarea" placeholder="Add additional private medical observations or timeline records..."></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <input type="hidden" asp-for="Diagnosis" />
                <input type="hidden" asp-for="Medication" />
                <input type="hidden" asp-for="Common_tests" />
                <input type="hidden" asp-for="Treatment_Plan" />
                <input type="hidden" asp-for="Notes" />
                <input type="hidden" asp-for="Status" />
            }

            <button type="submit" class="btn-submit">
                <i class="bi bi-save-fill"></i> Save Changes
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}