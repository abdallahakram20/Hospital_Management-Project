@model Hospital_Management_Project.Models.Appointment
@{
    ViewData["Title"] = "Create Appointment Slot";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-calendar-plus text-primary"></i> Create Appointment Slot</h2>
        <a asp-action="Index" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to List</a>
    </div>

    <hr />

    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card shadow-sm p-4">
                <form asp-action="Create">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-3">
                        <label asp-for="Visit_Date" class="control-label fw-bold">Visit Date & Time</label>
                        <input asp-for="Visit_Date" class="form-control" type="datetime-local" />
                        <span asp-validation-for="Visit_Date" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Status" class="control-label fw-bold">Initial Status</label>
                        <input asp-for="Status" class="form-control" placeholder="e.g., Available" />
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Reason" class="control-label fw-bold">Reason for Visit</label>
                        <input asp-for="Reason" class="form-control" placeholder="Optional clinical reason" />
                        <span asp-validation-for="Reason" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Diagnosis" class="control-label fw-bold">Diagnosis</label>
                        <input asp-for="Diagnosis" class="form-control" placeholder="Diagnosis description" />
                        <span asp-validation-for="Diagnosis" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Medication" class="control-label fw-bold">Prescribed Medication</label>
                        <input asp-for="Medication" class="form-control" placeholder="Medication list" />
                        <span asp-validation-for="Medication" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Treatment_Plan" class="control-label fw-bold">Treatment Plan</label>
                        <input asp-for="Treatment_Plan" class="form-control" placeholder="Follow-up treatment plan" />
                        <span asp-validation-for="Treatment_Plan" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Notes" class="control-label fw-bold">Clinical Notes</label>
                        <input asp-for="Notes" class="form-control" placeholder="Any additional notes" />
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Common_tests" class="control-label fw-bold">Required Common Tests</label>
                        <input asp-for="Common_tests" class="form-control" placeholder="e.g., Blood test, X-Ray" />
                        <span asp-validation-for="Common_tests" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3 position-relative">
                        <label class="control-label fw-bold">Patient Name</label>
                        <input type="text" id="patientSearch" class="form-control" placeholder="Type to search patient by name..." autocomplete="off" />
                        <ul id="patientSuggestions" class="list-group mt-1 shadow-sm" style="position: absolute; z-index: 1050; width: 100%; max-height: 200px; overflow-y: auto;"></ul>
                        <input type="hidden" asp-for="PatientId" id="PatientId" />
                        <span asp-validation-for="PatientId" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label class="control-label fw-bold">Assign Doctor</label>
                        <select asp-for="StaffId" class="form-select" asp-items="@(ViewBag.StaffList as SelectList)">
                            <option value="">-- Select Doctor --</option>
                        </select>
                        <span asp-validation-for="StaffId" class="text-danger"></span>
                    </div>

                    <div class="form-group d-grid">
                        <button type="submit" class="btn btn-primary btn-block"><i class="bi bi-check-lg"></i> Create Slot</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById('patientSearch').addEventListener('input', function () {
            const term = this.value;
            if (term.length < 1) {
                document.getElementById('patientSuggestions').innerHTML = '';
                return;
            }

            fetch(`/Appointments/SearchPatients?term=${encodeURIComponent(term)}`)
                .then(res => res.json())
                .then(data => {
                    const list = document.getElementById('patientSuggestions');
                    list.innerHTML = '';
                    data.forEach(p => {
                        const li = document.createElement('li');
                        li.className = 'list-group-item list-group-item-action';
                        li.textContent = p.name;
                        li.style.cursor = 'pointer';
                        li.addEventListener('click', function () {
                            document.getElementById('patientSearch').value = p.name;
                            document.getElementById('PatientId').value = p.id;
                            list.innerHTML = '';
                        });
                        list.appendChild(li);
                    });
                });
        });

        document.addEventListener('click', function (e) {
            if (!e.target.closest('#patientSearch') && !e.target.closest('#patientSuggestions')) {
                document.getElementById('patientSuggestions').innerHTML = '';
            }
        });
    </script>
}