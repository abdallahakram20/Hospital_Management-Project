@model Hospital_Management_Project.Models.Appointment
@{
    ViewData["Title"] = "Reschedule Appointment";
    var alternatives = ViewData["AlternativeAppointments"] as List<Hospital_Management_Project.Models.Appointment>;
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style>
    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #f4f8fc;
    }

    .resched-card {
        max-width: 600px;
        margin: 50px auto;
        background: white;
        padding: 35px;
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.03);
        border: 1px solid #e2e8f0;
    }

    .select-input {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid #cbd5e1;
        background-color: #f8fafc;
        font-weight: 600;
    }

    .btn-submit {
        background: #f59e0b;
        color: white;
        border: none;
        padding: 12px;
        border-radius: 12px;
        font-weight: 600;
        width: 100%;
        margin-top: 20px;
    }
</style>

<div class="resched-card">
    <h3><i class="bi bi-arrow-left-right text-warning"></i> Reschedule Appointment</h3>
    <p class="text-muted">Choose a new available slot from below to swap your current timing.</p>

    <div class="alert alert-warning">
        <strong>Current Appointment:</strong> @Model.Visit_Date.ToString("dd MMM yyyy") at @Model.Visit_Date.ToString("hh:mm tt")
    </div>

    <form asp-action="ConfirmChangeAppointment">
        <input type="hidden" name="currentAppointmentId" value="@Model.AppointmentId" />

        <label class="form-label font-weight-bold">Select New Appointment:</label>
        @if (alternatives != null && alternatives.Any())
        {
            <select name="newAppointmentId" class="select-input" required>
                <option value="">-- Choose an alternative time slot --</option>
                @foreach (var alt in alternatives)
                {
                    <option value="@alt.AppointmentId">@alt.Visit_Date.ToString("dd MMM yyyy") - @alt.Visit_Date.ToString("hh:mm tt")</option>  
                }
            </select>
            <button type="submit" class="btn-submit">Confirm Reschedule</button>
        }
        else
        {
            <div class="text-danger my-3 font-weight-bold">Sorry, there are no other alternative available slots for this doctor right now.</div>
        }
    </form>
    <a asp-action="Details" asp-route-id="@Model.StaffId" class="btn btn-light w-100 mt-2 rounded-3">Go Back</a>
</div>