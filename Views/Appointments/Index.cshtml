@model IEnumerable<Hospital_Management_Project.Models.Appointment>
@{
    ViewData["Title"] = "Appointments Directory";

    // تحديد الأدوار (Roles)
    bool isAdmin = User.IsInRole("Admin");
    bool isPatient = User.IsInRole("Patient");
    bool isStaff = !isAdmin && !isPatient;

    // 1. ترتيب المواعيد بناءً على اسم الدكتور/الممرض ثم بناءً على وقت الزيارة
    var sortedAppointments = Model != null
        ? Model.OrderBy(a => a.Staff != null ? a.Staff.StaffName : "Unassigned").ThenBy(a => a.Visit_Date)
        : Enumerable.Empty<Hospital_Management_Project.Models.Appointment>();
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --primary: #1A76D1;
        --primary-dark: #145db3;
        --primary-light: #e8f2fc;
        --primary-gradient: linear-gradient(135deg, #1A76D1, #3b92ec);
        --bg-page: #f4f8fc;
        --card-bg: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --input-border: #cbd5e1;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --card-shadow: 0 10px 25px -5px rgba(26, 118, 209, 0.08), 0 4px 6px -2px rgba(0,0,0,0.02);
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: var(--bg-page);
        color: var(--text-main);
    }

    .mp-page {
        padding: 40px 20px;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* ... (نفس التنسيقات السابقة بدون تغيير) ... */
    .mp-page-header {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 30px 40px;
        margin-bottom: 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--card-shadow);
        flex-wrap: wrap;
        gap: 20px;
        border-left: 6px solid var(--primary);
    }

    .ph-left h2 {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-main);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .ph-left p {
        color: var(--text-muted);
        font-size: 14px;
        margin: 5px 0 0 0;
    }

    .btn-create {
        background: var(--primary-gradient);
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 14px 28px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all .25s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 10px 20px -5px rgba(26, 118, 209, 0.4);
    }

        .btn-create:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            color: #fff;
        }

    .mp-card {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 30px;
        box-shadow: var(--card-shadow);
        border: 1px solid rgba(26, 118, 209, 0.08);
    }

    .badge-modern {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .bg-light-success {
        background: #ecfdf5;
        color: var(--success);
        border: 1px solid #d1fae5;
    }

    .bg-light-warning {
        background: #fffbeb;
        color: var(--warning);
        border: 1px solid #fde68a;
    }

    .bg-light-danger {
        background: #fef2f2;
        color: var(--danger);
        border: 1px solid #fecaca;
    }

    .bg-light-secondary {
        background: #f1f5f9;
        color: var(--text-muted);
        border: 1px solid #e2e8f0;
    }

    .mp-table-wrap {
        overflow-x: auto;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .mp-table {
        width: 100%;
        border-collapse: collapse;
        white-space: nowrap;
    }

        .mp-table thead th {
            background: #f8fafc;
            color: var(--text-main);
            padding: 16px 20px;
            font-weight: 700;
            font-size: 14px;
            text-align: left;
            border-bottom: 2px solid #e2e8f0;
        }

        .mp-table td {
            padding: 16px 20px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 14px;
        }

    .mp-actions {
        display: flex;
        gap: 6px;
    }

    .mp-btn {
        padding: 8px 14px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
        text-decoration: none;
        border: 1px solid transparent;
    }

    .mp-btn-info {
        background: var(--primary-light);
        color: var(--primary);
    }

        .mp-btn-info:hover {
            background: var(--primary);
            color: white;
        }

    .mp-btn-warning {
        background: #fffbeb;
        color: #d97706;
        border-color: #fde68a;
    }

        .mp-btn-warning:hover {
            background: #f59e0b;
            color: white;
        }

    .mp-btn-danger {
        background: #fef2f2;
        color: var(--danger);
        border-color: #fecaca;
    }

        .mp-btn-danger:hover {
            background: var(--danger);
            color: white;
        }

    .appointments-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
        gap: 20px;
    }

    .appointment-card {
        background: var(--card-bg);
        border-radius: 20px;
        padding: 24px;
        border: 1px solid rgba(26, 118, 209, 0.08);
        box-shadow: var(--card-shadow);
        position: relative;
        transition: transform 0.2s;
    }

        .appointment-card:hover {
            transform: translateY(-3px);
        }

    .card-date-box {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

        .card-date-box i {
            font-size: 20px;
            color: var(--primary);
            background: var(--primary-light);
            padding: 10px;
            border-radius: 12px;
        }

    .card-detail-line {
        font-size: 14px;
        margin-bottom: 10px;
        color: var(--text-muted);
    }

        .card-detail-line strong {
            color: var(--text-main);
        }

    .timeline-dot {
        position: relative;
        padding-left: 20px;
    }

        .timeline-dot::before {
            content: '';
            position: absolute;
            left: 0;
            top: 6px;
            width: 8px;
            height: 8px;
            background-color: var(--primary);
            border-radius: 50%;
        }

    /* ======== التنسيقات الجديدة الخاصة بالـ Pagination ======== */
    .pagination-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 30px;
    }

    .page-btn {
        border: 1px solid var(--input-border);
        background: var(--card-bg);
        color: var(--text-main);
        width: 38px;
        height: 38px;
        border-radius: 10px;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s ease;
    }

        .page-btn:hover:not(:disabled) {
            background: var(--primary-light);
            color: var(--primary);
            border-color: var(--primary);
        }

        .page-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            box-shadow: 0 4px 10px rgba(26, 118, 209, 0.3);
        }

        .page-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
            background: #f8fafc;
        }

    .paginated-item {
        display: none; /* يتم إخفاؤه افتراضياً، وسيقوم الـ JS بإظهاره */
    }
</style>

<div class="mp-page">
    <div class="mp-page-header">
        <div class="ph-left">
            <h2><i class="bi bi-calendar-check-fill" style="color: var(--primary);"></i> Appointments Directory</h2>
            <p>@(isPatient ? "Track and manage your clinical booking sessions" : "View and manage all patient clinical sessions and time slots")</p>
        </div>
        @if (!isPatient)
        {
            <a asp-action="Create" class="btn-create">
                <i class="bi bi-plus-circle-fill"></i> New Appointment
            </a>
        }
    </div>

    @if (!sortedAppointments.Any())
    {
        <div class="mp-card">
            <div class="text-center py-5">
                <i class="bi bi-calendar-x-fill text-muted opacity-50" style="font-size: 54px;"></i>
                <h4 class="mt-3">No Appointments Found</h4>
                <p class="text-muted">There are no scheduled sessions at the moment.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-xl-8 col-lg-7">
                @if (isPatient)
                {
                    <div class="appointments-grid" id="dataContainer">
                        @foreach (var item in sortedAppointments)
                        {
                            <div class="appointment-card paginated-item">
                                <div class="card-date-box">
                                    <i class="bi bi-clock-history"></i>
                                    <div>
                                        <div style="font-weight: 700; font-size: 16px;">@item.Visit_Date.ToString("dd MMMM yyyy")</div>
                                        <div style="font-size: 13px; color: var(--text-muted);">@item.Visit_Date.ToString("hh:mm tt")</div>
                                    </div>
                                </div>

                                <div style="margin-bottom: 16px;">
                                    @if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Available)
                                    {
                                        <span class="badge-modern bg-light-success"><i class="bi bi-check-circle-fill"></i> Available</span>
                                    }
                                    else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Booked)
                                    {
                                        <span class="badge-modern bg-light-warning"><i class="bi bi-bookmark-dash-fill"></i> Booked</span>
                                    }
                                    else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Cancelled)
                                    {
                                        <span class="badge-modern bg-light-danger"><i class="bi bi-x-circle-fill"></i> Cancelled</span>
                                    }
                                </div>

                                <div class="card-detail-line">
                                    <i class="bi bi-chat-left-text-fill me-1"></i> Reason: <strong>@(string.IsNullOrEmpty(item.Reason) ? "N/A" : item.Reason)</strong>
                                </div>
                                <div class="card-detail-line">
                                    <i class="bi bi-heart-pulse-fill me-1"></i> Diagnosis: <strong style="color: var(--primary);">@(string.IsNullOrEmpty(item.Diagnosis) ? "Pending review" : item.Diagnosis)</strong>
                                </div>

                                <hr style="border-top: 1px dashed var(--input-border); margin: 15px 0;" />

                                <div class="mp-actions" style="justify-content: stretch;">
                                    <a asp-action="Details" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-info" style="flex: 1; justify-content: center;">
                                        <i class="bi bi-eye-fill"></i> View Details
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="mp-card">
                        <div class="mp-table-wrap">
                            <table class="mp-table">
                                <thead>
                                    <tr>
                                        <th><i class="bi bi-clock-fill"></i> Visit Date & Time</th>
                                        @if (isAdmin)
                                        {
                                            <th><i class="bi bi-person-badge-fill"></i> Medical Staff</th>
                                            <th><i class="bi bi-person-fill"></i> Patient Name</th>
                                        }
                                        else if (isStaff)
                                        {
                                            <th><i class="bi bi-person-fill"></i> Patient Name</th>
                                        }
                                        <th><i class="bi bi-info-circle-fill"></i> Status</th>
                                        <th><i class="bi bi-question-diamond-fill"></i> Reason</th>
                                        <th><i class="bi bi-heart-pulse-fill"></i> Diagnosis</th>
                                        <th><i class="bi bi-capsules-fill"></i> Medication</th>
                                        <th style="text-align:center;"><i class="bi bi-sliders"></i> Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="dataContainer">
                                    @foreach (var item in sortedAppointments)
                                    {
                                        <tr class="paginated-item">
                                            <td style="font-weight:600; color: var(--text-main);">@item.Visit_Date.ToString("yyyy-MM-dd hh:mm tt")</td>

                                            @if (isAdmin)
                                            {
                                                <td>
                                                    <div class="d-flex flex-column">
                                                        <span class="fw-bold" style="color: var(--primary);">
                                                            @(item.Staff != null ? item.Staff.StaffName : "Unassigned")
                                                        </span>
                                                        @if (item.Staff != null && !string.IsNullOrEmpty(item.Staff.Position))
                                                        {
                                                            <small class="text-muted" style="font-size: 11px;">
                                                                <i class="bi bi-tag-fill me-1"></i>@item.Staff.Position
                                                            </small>
                                                        }
                                                    </div>
                                                </td>
                                                <td class="fw-bold">
                                                    @(item.Patient != null ? $"{item.Patient.FName} {item.Patient.LName}" : "N/A")
                                                </td>
                                            }
                                            else if (isStaff)
                                            {
                                                <td class="fw-bold" style="color: var(--primary);">
                                                    @(item.Patient != null ? $"{item.Patient.FName} {item.Patient.LName}" : "N/A")
                                                </td>
                                            }

                                            <td>
                                                @if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Available)
                                                {
                                                    <span class="badge-modern bg-light-success"><i class="bi bi-check-circle-fill"></i> Available</span>
                                                }
                                                else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Booked)
                                                {
                                                    <span class="badge-modern bg-light-warning"><i class="bi bi-bookmark-dash-fill"></i> Booked</span>
                                                }
                                                else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Cancelled)
                                                {
                                                    <span class="badge-modern bg-light-danger"><i class="bi bi-x-circle-fill"></i> Cancelled</span>
                                                }
                                            </td>
                                            <td>@(string.IsNullOrEmpty(item.Reason) ? "N/A" : item.Reason)</td>
                                            <td><span style="font-weight: 500;">@(string.IsNullOrEmpty(item.Diagnosis) ? "Pending" : item.Diagnosis)</span></td>
                                            <td>@(string.IsNullOrEmpty(item.Medication) ? "None" : item.Medication)</td>
                                            <td>
                                                <div class="mp-actions" style="justify-content: center;">
                                                    <a asp-action="Details" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-info" title="Details"><i class="bi bi-eye-fill"></i></a>
                                                    <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-warning" title="Edit"><i class="bi bi-pencil-square"></i></a>
                                                    <a asp-action="Delete" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-danger" title="Delete"><i class="bi bi-trash-fill"></i></a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <div id="paginationControls" class="pagination-container"></div>
            </div>

            <div class="col-xl-4 col-lg-5">
                <div class="mp-card" style="position: sticky; top: 20px;">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold m-0" style="color: var(--text-main); font-size: 16px;">
                            <i class="bi bi-lightning-auto text-warning me-1"></i> Today's Overview
                        </h5>
                        <span class="badge rounded-pill bg-primary" style="font-size: 12px; padding: 6px 12px;">
                            @sortedAppointments.Count(a => a.Visit_Date.Date == DateTime.Today) Today
                        </span>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        @{
                            var todaysAppointments = sortedAppointments.Where(a => a.Visit_Date.Date == DateTime.Today).Take(5);
                        }

                        @if (todaysAppointments.Any())
                        {
                            @foreach (var app in todaysAppointments)
                            {
                                <div class="d-flex align-items-center justify-content-between p-2 border-bottom pb-3">
                                    <div class="d-flex align-items-center">
                                        <div class="text-center me-3" style="min-width: 65px;">
                                            <div class="fw-bold text-dark m-0" style="font-size: 0.9rem;">@app.Visit_Date.ToString("hh:mm")</div>
                                            <small class="text-muted d-block" style="font-size: 0.75rem; font-weight: 600;">@app.Visit_Date.ToString("tt")</small>
                                        </div>
                                        <div class="timeline-dot" style="border-left: 2px solid #eef5ff; padding-left: 15px;">
                                            <div class="fw-bold text-dark" style="font-size: 0.9rem;">
                                                @(string.IsNullOrEmpty(app.Reason) ? "Clinical Session" : app.Reason)
                                            </div>

                                            @if (isAdmin)
                                            {
                                                <small class="text-primary d-block mt-1" style="font-size: 0.75rem; font-weight: 600;">
                                                    <i class="bi bi-person-badge"></i> Staff: @(app.Staff != null ? app.Staff.StaffName : "Unassigned")
                                                </small>
                                                <small class="text-muted d-block" style="font-size: 0.75rem;">
                                                    <i class="bi bi-person"></i> Patient: @(app.Patient != null ? $"{app.Patient.FName} {app.Patient.LName}" : "N/A")
                                                </small>
                                            }
                                            else if (isStaff)
                                            {
                                                <small class="text-primary d-block mt-1" style="font-size: 0.75rem; font-weight: 600;">
                                                    <i class="bi bi-person"></i> Patient: @(app.Patient != null ? $"{app.Patient.FName} {app.Patient.LName}" : "N/A")
                                                </small>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-calendar2-minus mb-2 fs-3 d-block opacity-50"></i>
                                <small>No appointments scheduled for today.</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const itemsPerPage = 10; // عدد العناصر في كل صفحة
        const items = document.querySelectorAll('.paginated-item');
        const paginationControls = document.getElementById('paginationControls');
        let currentPage = 1;

        if (items.length === 0) return; // لا يوجد عناصر لتقسيمها

        const totalPages = Math.ceil(items.length / itemsPerPage);

        // دالة لعرض العناصر الخاصة بالصفحة المطلوبة فقط
        function displayPage(page) {
            currentPage = page;
            const start = (page - 1) * itemsPerPage;
            const end = start + itemsPerPage;

            items.forEach((item, index) => {
                if (index >= start && index < end) {
                    // إذا كان العنصر صف في جدول نعطيه table-row، أما إذا كان كارت نعطيه block
                    item.style.display = item.tagName.toLowerCase() === 'tr' ? 'table-row' : 'block';
                } else {
                    item.style.display = 'none';
                }
            });

            updatePaginationButtons();
        }

        // دالة لرسم أزرار الصفحات
        function updatePaginationButtons() {
            if (!paginationControls) return;
            paginationControls.innerHTML = '';

            // إذا كانت صفحة واحدة فقط، لا داعي لإظهار الأزرار
            if (totalPages <= 1) return;

            // زر السابق
            const prevBtn = document.createElement('button');
            prevBtn.className = 'page-btn';
            prevBtn.innerHTML = '<i class="bi bi-chevron-left"></i>';
            prevBtn.disabled = currentPage === 1;
            prevBtn.onclick = () => displayPage(currentPage - 1);
            paginationControls.appendChild(prevBtn);

            // أرقام الصفحات
            for (let i = 1; i <= totalPages; i++) {
                const pageBtn = document.createElement('button');
                pageBtn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                pageBtn.innerText = i;
                pageBtn.onclick = () => displayPage(i);
                paginationControls.appendChild(pageBtn);
            }

            // زر التالي
            const nextBtn = document.createElement('button');
            nextBtn.className = 'page-btn';
            nextBtn.innerHTML = '<i class="bi bi-chevron-right"></i>';
            nextBtn.disabled = currentPage === totalPages;
            nextBtn.onclick = () => displayPage(currentPage + 1);
            paginationControls.appendChild(nextBtn);
        }

        // تشغيل العرض للصفحة الأولى عند التحميل
        displayPage(1);
    });
</script>