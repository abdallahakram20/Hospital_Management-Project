@model IEnumerable<Hospital_Management_Project.Models.Appointment>
@{
    ViewData["Title"] = "Appointments Directory";

    // Determine User Roles
    bool isAdmin = User.IsInRole("Admin");
    bool isPatient = User.IsInRole("Patient");
    bool isStaff = !isAdmin && !isPatient;

    // Sort appointments: Future/Active ones first, then past/ended ones at the bottom.
    var sortedAppointments = Model != null
        ? Model.OrderBy(a => a.Visit_Date < DateTime.Now)
               .ThenBy(a => a.Visit_Date)
        : Enumerable.Empty<Hospital_Management_Project.Models.Appointment>();
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght=400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --primary: #1A76D1;
        --primary-dark: #145db3;
        --primary-light: #e8f2fc;
        --primary-gradient: linear-gradient(135deg, #1A76D1, #3b92ec);
        --bg-page: #f4f8fc;
        --card-bg: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --input-border: #cbd5e1;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --card-shadow: 0 10px 25px -5px rgba(26, 118, 209, 0.08), 0 4px 6px -2px rgba(0,0,0,0.02);
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: var(--bg-page);
        color: var(--text-main);
    }

    .mp-page {
        padding: 40px 20px;
        max-width: 1400px;
        margin: 0 auto;
    }

    .mp-page-header {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 30px 40px;
        margin-bottom: 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--card-shadow);
        flex-wrap: wrap;
        gap: 20px;
        border-left: 6px solid var(--primary);
    }

    .ph-left h2 {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-main);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .ph-left p {
        color: var(--text-muted);
        font-size: 14px;
        margin: 5px 0 0 0;
    }

    .btn-create {
        background: var(--primary-gradient);
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 14px 28px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all .25s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 10px 20px -5px rgba(26, 118, 209, 0.4);
    }

        .btn-create:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            color: #fff;
        }

    .appointments-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
    }

    .appointment-card {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 28px;
        border: 1px solid rgba(26, 118, 209, 0.08);
        box-shadow: var(--card-shadow);
        position: relative;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

        .appointment-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 35px -10px rgba(26, 118, 209, 0.15);
        }

    .card-date-box {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 20px;
    }

        .card-date-box i {
            font-size: 22px;
            color: var(--primary);
            background: var(--primary-light);
            padding: 12px;
            border-radius: 16px;
        }

    .badge-modern {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-bottom: 16px;
    }

    .bg-light-success {
        background: #ecfdf5;
        color: var(--success);
        border: 1px solid #d1fae5;
    }

    .bg-light-warning {
        background: #fffbeb;
        color: var(--warning);
        border: 1px solid #fde68a;
    }

    .bg-light-danger {
        background: #fef2f2;
        color: var(--danger);
        border: 1px solid #fecaca;
    }

    .bg-light-secondary {
        background: #f1f5f9;
        color: var(--text-muted);
        border: 1px solid #e2e8f0;
    }

    .card-detail-line {
        font-size: 14px;
        margin-bottom: 12px;
        color: var(--text-muted);
        display: flex;
        align-items: flex-start;
        gap: 8px;
    }

        .card-detail-line i {
            margin-top: 3px;
            color: var(--primary);
        }

        .card-detail-line strong {
            color: var(--text-main);
        }

    .mp-actions {
        display: flex;
        gap: 8px;
        margin-top: 20px;
    }

    .mp-btn {
        padding: 10px 16px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: all 0.2s;
        text-decoration: none;
        flex: 1;
    }

    .mp-btn-info {
        background: var(--primary-light);
        color: var(--primary);
    }

        .mp-btn-info:hover {
            background: var(--primary);
            color: white;
        }

    .mp-btn-warning {
        background: #fffbeb;
        color: #d97706;
        border: 1px solid #fde68a;
    }

        .mp-btn-warning:hover {
            background: #f59e0b;
            color: white;
        }

    .mp-btn-danger {
        background: #fef2f2;
        color: var(--danger);
        border: 1px solid #fecaca;
    }

        .mp-btn-danger:hover {
            background: var(--danger);
            color: white;
        }

    /* 🟢 التعديل هنا: جعل صندوق البحث بعرض الصفحة بالكامل */
    .search-container {
        margin-bottom: 32px;
        width: 100%;
    }

    .search-wrapper {
        position: relative;
        width: 100%;
    }

    .search-input {
        width: 100%;
        padding: 16px 16px 16px 48px;
        border-radius: 16px;
        border: 1px solid var(--input-border);
        background-color: var(--card-bg);
        color: var(--text-main);
        font-size: 14px;
        transition: all 0.25s ease;
    }

        .search-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 4px var(--primary-light);
        }

    .search-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--text-muted);
        font-size: 18px;
    }

    .pagination-container {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 40px;
    }

    .page-btn {
        border: 1px solid var(--input-border);
        background: var(--card-bg);
        color: var(--text-main);
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s;
    }

        .page-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .page-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

    .paginated-item {
        display: none;
    }
</style>

<div class="mp-page">
    <div class="mp-page-header">
        <div class="ph-left">
            <h2><i class="bi bi-calendar-check-fill"></i> Appointments Directory</h2>
            <p>Track and manage your scheduled clinical sessions and slots</p>
        </div>
        @if (!isPatient)
        {
            <a asp-action="Create" class="btn-create">
                <i class="bi bi-plus-circle-fill"></i> New Appointment
            </a>
        }
    </div>

    @if (!sortedAppointments.Any())
    {
        <div style="background: var(--card-bg); border-radius: 24px; padding: 60px; text-center;">
            <i class="bi bi-calendar-x-fill text-muted opacity-50" style="font-size: 54px;"></i>
            <h4 class="mt-3">No Appointments Found</h4>
            <p class="text-muted">There are no scheduled sessions at the moment.</p>
        </div>
    }
    else
    {
        @if (isAdmin || isStaff)
        {
            <div class="search-container">
                <div class="search-wrapper">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" id="appointmentSearch" class="search-input" placeholder="Search by Patient or Staff name..." autocomplete="off" />
                </div>
            </div>
        }

        <div class="appointments-grid" id="dataContainer">
            @foreach (var item in sortedAppointments)
            {
                bool isTimePassed = item.Visit_Date < DateTime.Now;
                string patientFullName = item.Patient != null ? $"{item.Patient.FName} {item.Patient.LName}" : "N/A";
                string staffName = item.Staff != null ? item.Staff.StaffName : "Unassigned";

                <div class="appointment-card paginated-item" data-search-tag="@(patientFullName.ToLower()) @(staffName.ToLower())">
                    <div>
                        <div class="card-date-box">
                            <i class="bi bi-clock-history"></i>
                            <div>
                                <div style="font-weight: 700; font-size: 16px;">@item.Visit_Date.ToString("dd MMMM yyyy")</div>
                                <div style="font-size: 13px; color: var(--text-muted);">@item.Visit_Date.ToString("hh:mm tt")</div>
                            </div>
                        </div>

                        <div>
                            @if (isTimePassed)
                            {
                                <span class="badge-modern bg-light-secondary"><i class="bi bi-hourglass-bottom"></i> Ended</span>
                            }
                            else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Available)
                            {
                                <span class="badge-modern bg-light-success"><i class="bi bi-check-circle-fill"></i> Available</span>
                            }
                            else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Booked)
                            {
                                <span class="badge-modern bg-light-warning"><i class="bi bi-bookmark-dash-fill"></i> Booked</span>
                            }
                            else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Cancelled)
                            {
                                <span class="badge-modern bg-light-danger"><i class="bi bi-x-circle-fill"></i> Cancelled</span>
                            }
                        </div>

                        @if (isAdmin || isStaff)
                        {
                            <div class="card-detail-line">
                                <i class="bi bi-person-fill"></i> Patient: <strong>@patientFullName</strong>
                            </div>
                        }
                        @if (isAdmin)
                        {
                            <div class="card-detail-line">
                                <i class="bi bi-person-badge-fill"></i> Staff: <strong>@staffName</strong>
                            </div>
                        }

                        <div class="card-detail-line">
                            <i class="bi bi-chat-left-text-fill"></i> Reason: <strong>@(string.IsNullOrEmpty(item.Reason) ? "N/A" : item.Reason)</strong>
                        </div>
                        <div class="card-detail-line">
                            <i class="bi bi-heart-pulse-fill"></i> Diagnosis: <strong style="color: var(--primary);">@(string.IsNullOrEmpty(item.Diagnosis) ? "Pending review" : item.Diagnosis)</strong>
                        </div>
                        <div class="card-detail-line">
                            <i class="bi bi-capsules-fill"></i> Medication: <strong>@(string.IsNullOrEmpty(item.Medication) ? "None" : item.Medication)</strong>
                        </div>
                        <div class="card-detail-line">
                            <i class="bi bi-journal-medical"></i> Treatment Plan: <strong>@(string.IsNullOrEmpty(item.Treatment_Plan) ? "N/A" : item.Treatment_Plan)</strong>
                        </div>
                        <div class="card-detail-line">
                            <i class="bi bi-clipboard2-pulse-fill"></i> Common Tests: <strong>@(string.IsNullOrEmpty(item.Common_tests) ? "None" : item.Common_tests)</strong>
                        </div>

                        @if (!string.IsNullOrEmpty(item.Notes))
                        {
                            <div class="card-detail-line mt-2 p-2 rounded" style="background: #fffbeb; font-size: 13px;">
                                <i class="bi bi-sticky-fill text-warning"></i> <span><strong>Notes:</strong> @item.Notes</span>
                            </div>
                        }
                    </div>

                    <div class="mp-actions">
                        <a asp-action="Details" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-info" title="Details">
                            <i class="bi bi-eye-fill"></i> Details
                        </a>

                        @if (isAdmin || isStaff)
                        {
                            <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-warning" title="Edit">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>
                            @if (isAdmin)
                            {
                                <a asp-action="Delete" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-danger" title="Delete">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </a>
                            }
                        }
                        else if (isPatient && !isTimePassed && item.Status == Hospital_Management_Project.Models.AppointmentStatus.Booked)
                        {
                            double hoursRemaining = (item.Visit_Date - DateTime.Now).TotalHours;
                            if (hoursRemaining < 12)
                            {
                                <a href="#" class="mp-btn mp-btn-danger" onclick="alert('Less than 12 hours remaining. Please contact hospital support.'); event.preventDefault();">
                                    <i class="bi bi-x-circle-fill"></i> Cancel
                                </a>
                            }
                            else
                            {
                                <a asp-action="Cancel" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-danger" onclick="return confirm('Cancel this appointment?');">
                                    <i class="bi bi-x-circle-fill"></i> Cancel
                                </a>
                            }
                        }
                    </div>
                </div>
            }
        </div>

        <div id="paginationControls" class="pagination-container"></div>
    }
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const itemsPerPage = 6;
        let items = Array.from(document.querySelectorAll('.paginated-item'));
        const paginationControls = document.getElementById('paginationControls');
        const searchInput = document.getElementById('appointmentSearch');
        let filteredItems = [...items];
        let currentPage = 1;

        if (items.length === 0) return;

        let totalPages = Math.ceil(filteredItems.length / itemsPerPage);

        function displayPage(page) {
            currentPage = page;
            const start = (page - 1) * itemsPerPage;
            const end = start + itemsPerPage;

            items.forEach(item => item.style.display = 'none');

            filteredItems.forEach((item, index) => {
                if (index >= start && index < end) {
                    item.style.display = 'flex';
                }
            });

            updatePaginationButtons();
        }

        function updatePaginationButtons() {
            if (!paginationControls) return;
            paginationControls.innerHTML = '';

            if (totalPages <= 1) return;

            const prevBtn = document.createElement('button');
            prevBtn.className = 'page-btn';
            prevBtn.innerHTML = '<i class="bi bi-chevron-left"></i>';
            prevBtn.disabled = currentPage === 1;
            prevBtn.onclick = () => displayPage(currentPage - 1);
            paginationControls.appendChild(prevBtn);

            for (let i = 1; i <= totalPages; i++) {
                const pageBtn = document.createElement('button');
                pageBtn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
                pageBtn.innerText = i;
                pageBtn.onclick = () => displayPage(i);
                paginationControls.appendChild(pageBtn);
            }

            const nextBtn = document.createElement('button');
            nextBtn.className = 'page-btn';
            nextBtn.innerHTML = '<i class="bi bi-chevron-right"></i>';
            nextBtn.disabled = currentPage === totalPages;
            nextBtn.onclick = () => displayPage(currentPage + 1);
            paginationControls.appendChild(nextBtn);
        }

        if (searchInput) {
            searchInput.addEventListener('input', function (e) {
                const searchTerm = e.target.value.toLowerCase().trim();

                filteredItems = items.filter(item => {
                    const searchTag = item.getAttribute('data-search-tag') || '';
                    return searchTag.includes(searchTerm);
                });

                totalPages = Math.ceil(filteredItems.length / itemsPerPage);
                displayPage(1);
            });
        }

        displayPage(1);
    });
</script>