@model IEnumerable<Hospital_Management_Project.Models.Appointment>
@{
    ViewData["Title"] = "Appointments Directory";
    bool isPatient = User.IsInRole("Patient");
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --primary: #1A76D1;
        --primary-dark: #145db3;
        --primary-light: #e8f2fc;
        --primary-gradient: linear-gradient(135deg, #1A76D1, #3b92ec);
        --bg-page: #f4f8fc;
        --card-bg: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --input-border: #cbd5e1;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --card-shadow: 0 10px 25px -5px rgba(26, 118, 209, 0.08), 0 4px 6px -2px rgba(0,0,0,0.02);
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: var(--bg-page);
        color: var(--text-main);
    }

    .mp-page {
        padding: 40px 20px;
        max-width: 1400px;
        margin: 0 auto;
    }

    /* Header Section */
    .mp-page-header {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 30px 40px;
        margin-bottom: 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--card-shadow);
        flex-wrap: wrap;
        gap: 20px;
        border-left: 6px solid var(--primary);
    }

    .ph-left h2 {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-main);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .ph-left p {
        color: var(--text-muted);
        font-size: 14px;
        margin: 5px 0 0 0;
    }

    .btn-create {
        background: var(--primary-gradient);
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 14px 28px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all .25s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 10px 20px -5px rgba(26, 118, 209, 0.4);
    }

        .btn-create:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            color: #fff;
        }

    .mp-card {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 30px;
        box-shadow: var(--card-shadow);
        border: 1px solid rgba(26, 118, 209, 0.08);
    }

    /* Badges Modernization */
    .badge-modern {
        padding: 6px 14px;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .bg-light-success {
        background: #ecfdf5;
        color: var(--success);
        border: 1px solid #d1fae5;
    }

    .bg-light-warning {
        background: #fffbeb;
        color: var(--warning);
        border: 1px solid #fde68a;
    }

    .bg-light-danger {
        background: #fef2f2;
        color: var(--danger);
        border: 1px solid #fecaca;
    }

    .bg-light-secondary {
        background: #f1f5f9;
        color: var(--text-muted);
        border: 1px solid #e2e8f0;
    }

    /* Table Design for Admin */
    .mp-table-wrap {
        overflow-x: auto;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .mp-table {
        width: 100%;
        border-collapse: collapse;
        white-space: nowrap;
    }

        .mp-table thead th {
            background: #f8fafc;
            color: var(--text-main);
            padding: 16px 20px;
            font-weight: 700;
            font-size: 14px;
            text-align: left;
            border-bottom: 2px solid #e2e8f0;
        }

        .mp-table td {
            padding: 16px 20px;
            border-bottom: 1px solid #f1f5f9;
            font-size: 14px;
        }

    /* Actions Buttons */
    .mp-actions {
        display: flex;
        gap: 6px;
    }

    .mp-btn {
        padding: 8px 14px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
        text-decoration: none;
        border: 1px solid transparent;
    }

    .mp-btn-info {
        background: var(--primary-light);
        color: var(--primary);
    }

        .mp-btn-info:hover {
            background: var(--primary);
            color: white;
        }

    .mp-btn-warning {
        background: #fffbeb;
        color: #d97706;
        border-color: #fde68a;
    }

        .mp-btn-warning:hover {
            background: #f59e0b;
            color: white;
        }

    .mp-btn-danger {
        background: #fef2f2;
        color: var(--danger);
        border-color: #fecaca;
    }

        .mp-btn-danger:hover {
            background: var(--danger);
            color: white;
        }

    /* Patient Cards Grid Mode */
    .appointments-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
        gap: 20px;
    }

    .appointment-card {
        background: var(--card-bg);
        border-radius: 20px;
        padding: 24px;
        border: 1px solid rgba(26, 118, 209, 0.08);
        box-shadow: var(--card-shadow);
        position: relative;
        transition: transform 0.2s;
    }

        .appointment-card:hover {
            transform: translateY(-3px);
        }

    .card-date-box {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

        .card-date-box i {
            font-size: 20px;
            color: var(--primary);
            background: var(--primary-light);
            padding: 10px;
            border-radius: 12px;
        }

    .card-detail-line {
        font-size: 14px;
        margin-bottom: 10px;
        color: var(--text-muted);
    }

        .card-detail-line strong {
            color: var(--text-main);
        }

    /* تايم لاين كارت اليوم */
    .timeline-dot {
        position: relative;
        padding-left: 20px;
    }

        .timeline-dot::before {
            content: '';
            position: absolute;
            left: 0;
            top: 6px;
            width: 8px;
            height: 8px;
            background-color: var(--primary);
            border-radius: 50%;
        }
</style>

<div class="mp-page">
    <div class="mp-page-header">
        <div class="ph-left">
            <h2><i class="bi bi-calendar-check-fill" style="color: var(--primary);"></i> Appointments Directory</h2>
            <p>@(isPatient ? "Track and manage your clinical booking sessions" : "View and manage all patient clinical sessions and time slots")</p>
        </div>
        @if (!isPatient)
        {
            <a asp-action="Create" class="btn-create">
                <i class="bi bi-plus-circle-fill"></i> New Appointment
            </a>
        }
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="mp-card">
            <div class="text-center py-5">
                <i class="bi bi-calendar-x-fill text-muted opacity-50" style="font-size: 54px;"></i>
                <h4 class="mt-3">No Appointments Found</h4>
                <p class="text-muted">There are no scheduled sessions at the moment.</p>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">

            <div class="col-xl-8 col-lg-7">
                @if (isPatient)
                {
                    <div class="appointments-grid">
                        @foreach (var item in Model)
                        {
                            <div class="appointment-card">
                                <div class="card-date-box">
                                    <i class="bi bi-clock-history"></i>
                                    <div>
                                        <div style="font-weight: 700; font-size: 16px;">@item.Visit_Date.ToString("dd MMMM yyyy")</div>
                                        <div style="font-size: 13px; color: var(--text-muted);">@item.Visit_Date.ToString("hh:mm tt")</div>
                                    </div>
                                </div>

                                <div style="margin-bottom: 16px;">
                                    @if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Available)
                                    {
                                        <span class="badge-modern bg-light-success"><i class="bi bi-check-circle-fill"></i> Available</span>
                                    }
                                    else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Booked)
                                    {
                                        <span class="badge-modern bg-light-warning"><i class="bi bi-bookmark-dash-fill"></i> Booked</span>
                                    }
                                    else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Cancelled)
                                    {
                                        <span class="badge-modern bg-light-danger"><i class="bi bi-x-circle-fill"></i> Cancelled</span>
                                    }
                                    else
                                    {
                                        <span class="badge-modern bg-light-secondary">@item.Status</span>
                                    }
                                </div>

                                <div class="card-detail-line">
                                    <i class="bi bi-chat-left-text-fill me-1"></i> Reason: <strong>@(string.IsNullOrEmpty(item.Reason) ? "N/A" : item.Reason)</strong>
                                </div>
                                <div class="card-detail-line">
                                    <i class="bi bi-heart-pulse-fill me-1"></i> Diagnosis: <strong style="color: var(--primary);">@(string.IsNullOrEmpty(item.Diagnosis) ? "Pending doctor review" : item.Diagnosis)</strong>
                                </div>
                                <div class="card-detail-line">
                                    <i class="bi bi-capsules me-1"></i> Medication: <strong>@(string.IsNullOrEmpty(item.Medication) ? "None" : item.Medication)</strong>
                                </div>

                                <hr style="border-top: 1px dashed var(--input-border); margin: 15px 0;" />

                                <div class="mp-actions" style="justify-content: stretch;">
                                    <a asp-action="Details" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-info" style="flex: 1; justify-content: center;">
                                        <i class="bi bi-eye-fill"></i> View Details
                                    </a>

                                    @if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Booked)
                                    {
                                        <form asp-action="CancelAppointment" method="post" style="flex: 1; display:flex;">
                                            <input type="hidden" name="id" value="@item.AppointmentId" />
                                            <button type="submit" class="mp-btn mp-btn-danger" style="width: 100%; justify-content: center;"
                                                    onclick="return confirm('Are you sure you want to cancel this appointment?\n\nNote: Cancellation is not allowed if less than 24 hours remain.');">
                                                <i class="bi bi-x-square-fill"></i> Cancel
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="mp-card">
                        <div class="mp-table-wrap">
                            <table class="mp-table">
                                <thead>
                                    <tr>
                                        <th><i class="bi bi-clock-fill"></i> Visit Date & Time</th>
                                        <th><i class="bi bi-info-circle-fill"></i> Status</th>
                                        <th><i class="bi bi-question-diamond-fill"></i> Reason</th>
                                        <th><i class="bi bi-heart-pulse-fill"></i> Diagnosis</th>
                                        <th><i class="bi bi-capsules-fill"></i> Medication</th>
                                        <th><i class="bi bi-journal-medical"></i> Treatment Plan</th>
                                        <th><i class="bi bi-vials"></i> Common Tests</th>
                                        <th style="text-align:center;"><i class="bi bi-sliders"></i> Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td style="font-weight:600; color: var(--text-main);">@item.Visit_Date.ToString("yyyy-MM-dd hh:mm tt")</td>
                                            <td>
                                                @if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Available)
                                                {
                                                    <span class="badge-modern bg-light-success"><i class="bi bi-check-circle-fill"></i> Available</span>
                                                }
                                                else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Booked)
                                                {
                                                    <span class="badge-modern bg-light-warning"><i class="bi bi-bookmark-dash-fill"></i> Booked</span>
                                                }
                                                else if (item.Status == Hospital_Management_Project.Models.AppointmentStatus.Cancelled)
                                                {
                                                    <span class="badge-modern bg-light-danger"><i class="bi bi-x-circle-fill"></i> Cancelled</span>
                                                }
                                                else
                                                {
                                                    <span class="badge-modern bg-light-secondary">@item.Status</span>
                                                }
                                            </td>
                                            <td>@(string.IsNullOrEmpty(item.Reason) ? "N/A" : item.Reason)</td>
                                            <td><span style="font-weight: 500;">@(string.IsNullOrEmpty(item.Diagnosis) ? "Pending" : item.Diagnosis)</span></td>
                                            <td>@(string.IsNullOrEmpty(item.Medication) ? "None" : item.Medication)</td>
                                            <td>@(string.IsNullOrEmpty(item.Treatment_Plan) ? "None" : item.Treatment_Plan)</td>
                                            <td>@(string.IsNullOrEmpty(item.Common_tests) ? "None" : item.Common_tests)</td>
                                            <td>
                                                <div class="mp-actions" style="justify-content: center;">
                                                    <a asp-action="Details" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-info" title="Details">
                                                        <i class="bi bi-eye-fill"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-warning" title="Edit">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@item.AppointmentId" class="mp-btn mp-btn-danger" title="Delete">
                                                        <i class="bi bi-trash-fill"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>

            <div class="col-xl-4 col-lg-5">
                <div class="mp-card" style="position: sticky; top: 20px;">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold m-0" style="color: var(--text-main); font-size: 16px;">
                            <i class="bi bi-lightning-auto text-warning me-1"></i> Today's Overview
                        </h5>
                        <span class="badge rounded-pill bg-primary" style="font-size: 12px; padding: 6px 12px;">
                            @Model.Count(a => a.Visit_Date.Date == DateTime.Today) Today
                        </span>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        @{
                            var todaysAppointments = Model.Where(a => a.Visit_Date.Date == DateTime.Today).OrderBy(a => a.Visit_Date).Take(5);
                        }

                        @if (todaysAppointments.Any())
                        {
                            @foreach (var app in todaysAppointments)
                            {
                                <div class="d-flex align-items-center justify-content-between p-2 border-bottom pb-3">
                                    <div class="d-flex align-items-center">
                                        <div class="text-center me-3" style="min-width: 65px;">
                                            <div class="fw-bold text-dark m-0" style="font-size: 0.9rem;">@app.Visit_Date.ToString("hh:mm")</div>
                                            <small class="text-muted d-block" style="font-size: 0.75rem; font-weight: 600;">@app.Visit_Date.ToString("tt")</small>
                                        </div>
                                        <div class="timeline-dot" style="border-left: 2px solid #eef5ff; padding-left: 15px;">
                                            <div class="fw-bold text-dark" style="font-size: 0.9rem;">
                                                @(string.IsNullOrEmpty(app.Reason) ? "Clinical Session" : app.Reason)
                                            </div>
                                            <small class="text-muted d-block" style="font-size: 0.8rem;">
                                                @(string.IsNullOrEmpty(app.Diagnosis) ? "General Check" : app.Diagnosis)
                                            </small>
                                        </div>
                                    </div>

                                    @if (app.Status == Hospital_Management_Project.Models.AppointmentStatus.Booked)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2 py-1" style="font-size: 11px;">Booked</span>
                                    }
                                    else if (app.Status == Hospital_Management_Project.Models.AppointmentStatus.Available)
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-2 py-1" style="font-size: 11px;">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill px-2 py-1" style="font-size: 11px;">Cancelled</span>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-calendar2-minus mb-2 fs-3 d-block opacity-50"></i>
                                <small>No appointments scheduled for today.</small>
                            </div>
                        }
                    </div>
                </div>
            </div>

        </div>
    }
</div>

@section Scripts {
    <script>
        (function () {
            if (window.history.pushState) {
                window.history.pushState(null, null, window.location.href);

                window.addEventListener('popstate', function () {
                    window.location.href = '@Url.Action("Index", "Home")';
                });
            }

            // إضافة الـ pageshow المفقود لإجبار المتصفح على التحديث عند الرجوع
            window.addEventListener('pageshow', function (event) {
                if (event.persisted || (typeof window.performance != "undefined" && window.performance.getEntriesByType("navigation")[0]?.type === "back_forward")) {
                    window.location.reload(true);
                }
            });
        })();
    </script>
}