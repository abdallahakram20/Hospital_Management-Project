@{
    ViewData["Title"] = "Home Page";
    Layout = null;
}
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />


<style>
:root {
--primary: #1A76D1;
--primary-dk: #1560ad;
--dark: #2C2D3F;
--muted: #888;
--light-bg: #f9f9f9;
--white: #ffffff;
--shadow-sm: 0 4px 15px rgba(0,0,0,.07);
--shadow-md: 0 8px 30px rgba(0,0,0,.12);
--radius: 6px;
--transition: all .3s ease;
}

* {
margin: 0;
padding: 0;
box-sizing: border-box;
}

body {
font-family: 'Poppins', sans-serif;
font-size: 14px;
color: var(--muted);
background: #fff;
}

a {
text-decoration: none;
color: inherit;
}

/* ── TOPBAR ─────────────────────────────────── */
.topbar {
background: var(--white);
border-bottom: 1px solid #eee;
padding: 10px 0;
}

.topbar .container {
max-width: 1200px;
margin: 0 auto;
padding: 0 24px;
display: flex;
justify-content: space-between;
align-items: center;
flex-wrap: wrap;
gap: 8px;
}

.top-links {
display: flex;
gap: 20px;
list-style: none;
}

.top-links a {
color: var(--dark);
font-size: 13px;
transition: var(--transition);
}

.top-links a:hover {
color: var(--primary);
}

.top-contact {
display: flex;
gap: 22px;
list-style: none;
}

.top-contact li {
color: var(--dark);
font-size: 13px;
}

.top-contact i {
color: var(--primary);
margin-right: 6px;
}

.top-contact a:hover {
color: var(--primary);
}

/* ── LANGUAGE DROPDOWN ──────────────────────── */
.lang-dropdown {
position: relative;
display: inline-block;
}

.lang-dropdown .lang-menu {
position: absolute;
top: 100%;
left: 0;
background: #fff;
border: 1px solid #eee;
border-radius: var(--radius);
box-shadow: var(--shadow-md);
list-style: none;
padding: 8px 0;
min-width: 140px;
opacity: 0;
visibility: hidden;
transform: translateY(10px);
transition: var(--transition);
z-index: 1000;
}

.lang-dropdown:hover .lang-menu {
opacity: 1;
visibility: visible;
transform: translateY(0);
}

.lang-menu li a {
display: flex !important;
align-items: center;
gap: 8px;
padding: 8px 16px;
color: var(--dark) !important;
font-size: 13px;
transition: var(--transition);
}

.lang-menu li a:hover {
background: var(--light-bg);
color: var(--primary) !important;
}

/* إخفاء شريط جوجل الافتراضي للحفاظ على شكل الموقع */
.skiptranslate iframe {
display: none !important;
}

body {
top: 0px !important;
}

#google_translate_element {
display: none !important;
}

/* ── HEADER ─────────────────────────────────── */
.header-inner {
background: var(--white);
box-shadow: 0 2px 10px rgba(0,0,0,.06);
position: sticky;
top: 0;
z-index: 999;
animation: fadeInDown .4s ease;
}

@@keyframes fadeInDown {
from {
opacity: 0;
transform: translateY(-10px);
}
to {
opacity: 1;
transform: translateY(0);
}
}

.header-inner .container {
max-width: 1200px;
margin: 0 auto;
padding: 0 24px;
display: flex;
align-items: center;
justify-content: space-between;
height: 72px;
}

/* Logo */
.logo {
display: flex;
align-items: center;
gap: 8px;
text-decoration: none;
}

.logo-icon {
width: auto;
height: 90px;
background: transparent;
border-radius: 0px;
display: flex;
align-items: center;
justify-content: center;
}

.logo-icon img {
height: 100%;
width: auto;
object-fit: contain;
}

.logo-text {
line-height: 1.2;
}

.logo-text strong {
display: block;
font-size: 15px;
font-weight: 700;
color: var(--dark);
}

.logo-text span {
font-size: 11px;
color: var(--muted);
letter-spacing: .4px;
}

/* Nav */
.main-nav {
display: flex;
align-items: center;
gap: 4px;
list-style: none;
}

.main-nav li {
position: relative;
}

.main-nav a {
display: block;
padding: 24px 14px;
font-size: 14px;
font-weight: 500;
color: var(--dark);
transition: var(--transition);
position: relative;
}

.main-nav a::after {
content: '';
position: absolute;
left: 0;
bottom: 0;
height: 3px;
width: 0%;
background: var(--primary);
border-radius: 3px 3px 0 0;
transition: var(--transition);
}

.main-nav a:hover,
.main-nav a.active {
color: var(--primary);
}

.main-nav a:hover::after,
.main-nav a.active::after {
width: 100%;
}

/* Book btn */
.btn-book {
background: var(--primary);
color: var(--white) !important;
padding: 10px 22px !important;
border-radius: var(--radius);
font-weight: 600;
font-size: 13px;
transition: var(--transition);
white-space: nowrap;
}

.btn-book:hover {
background: var(--primary-dk);
transform: translateY(-1px);
}

.btn-book::after {
display: none !important;
}

/* Logout */
.btn-logout-nav {
background: transparent;
border: 1.5px solid #e55;
color: #e55;
border-radius: var(--radius);
padding: 7px 16px;
font-size: 13px;
font-weight: 600;
cursor: pointer;
font-family: 'Poppins', sans-serif;
transition: var(--transition);
}

.btn-logout-nav:hover {
background: #e55;
color: #fff;
}

/* ── HERO ────────────────────────────────────── */
.hero {
background: linear-gradient(120deg, #e8f4fd 0%, #f5fbff 60%, #d6ecfa 100%);
padding: 1px 0 0;
overflow: hidden;
position: relative;
}

.hero::before {
content: '';
position: absolute;
right: -80px;
top: -60px;
width: 420px;
height: 420px;
border-radius: 50%;
background: rgba(26,118,209,.06);
}

.hero .container {
max-width: 1200px;
margin: 0 auto;
padding: 0 24px;
display: flex;
align-items: flex-end;
gap: 40px;
}

.hero-text {
flex: 1;
padding-bottom: 60px;
}

.hero-text .badge {
display: inline-block;
background: rgba(26,118,209,.1);
color: var(--primary);
font-size: 12px;
font-weight: 600;
padding: 5px 14px;
border-radius: 50px;
margin-bottom: 18px;
letter-spacing: .3px;
}

.hero-text h1 {
font-size: 46px;
font-weight: 700;
line-height: 1.15;
color: var(--dark);
margin-bottom: 16px;
}

.hero-text h1 span {
color: var(--primary);
}

.hero-text p {
font-size: 15px;
color: var(--muted);
max-width: 400px;
line-height: 1.7;
margin-bottom: 32px;
}

.hero-btns {
display: flex;
gap: 14px;
flex-wrap: wrap;
}

.btn-primary {
background: var(--primary);
color: #fff;
padding: 13px 30px;
border-radius: var(--radius);
font-weight: 600;
font-size: 14px;
transition: var(--transition);
display: inline-block;
}

.btn-primary:hover {
background: var(--primary-dk);
color: #fff;
transform: translateY(-2px);
box-shadow: 0 6px 20px rgba(26,118,209,.3);
}

.btn-outline {
background: transparent;
color: var(--dark);
border: 2px solid #ddd;
padding: 11px 28px;
border-radius: var(--radius);
font-weight: 500;
font-size: 14px;
transition: var(--transition);
display: inline-block;
}

.btn-outline:hover {
border-color: var(--primary);
color: var(--primary);
transform: translateY(-2px);
}

/* hero stats strip */
.hero-stats {
display: flex;
gap: 32px;
margin-top: 40px;
}

.hero-stat {
text-align: center;
}

.hero-stat strong {
display: block;
font-size: 26px;
font-weight: 700;
color: var(--primary);
}

.hero-stat span {
font-size: 12px;
color: var(--muted);
}

/* hero image side */
.hero-img {
flex: 0 0 370px;
display: flex;
align-items: flex-end;
justify-content: center;
}

.hero-img-box {
width: 450px;
height: 550px;
background: #c8e3f5;
border-radius: 12px 12px 0 0;
box-shadow: var(--shadow-md);
position: relative;
overflow: hidden;
transform: translateY(150px);
}

.hero-img-box::after {
content: '';
position: absolute;
left: 0;
bottom: 0;
width: 100%;
height: 10px;
background: var(--primary);
}

.hero-img-box img {
width: 100%;
height: 100%;
object-fit: cover;
}

/* ── SCHEDULE CARDS ─────────────────────────── */
.schedule-strip {
background: transparent;
padding: 0;
margin: 0;
}

.schedule-strip .container {
max-width: 1200px;
margin: 0 auto;
padding: 0 24px;
transform: translateY(-40px);
}

.schedule-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 20px;
}

.schedule-card {
background: var(--primary);
border-radius: var(--radius);
padding: 28px 24px;
color: #fff;
position: relative;
overflow: hidden;
cursor: pointer;
transition: var(--transition);
text-decoration: none;
display: block;
}

.schedule-card:hover {
transform: translateY(-5px);
box-shadow: 0 12px 35px rgba(26,118,209,.35);
color: #fff;
}

.schedule-card .sc-icon {
font-size: 60px;
opacity: .15;
position: absolute;
right: -8px;
bottom: -12px;
}

.schedule-card .sc-label {
font-size: 11px;
font-weight: 500;
letter-spacing: .5px;
text-transform: uppercase;
opacity: .8;
margin-bottom: 8px;
display: block;
}

.schedule-card h4 {
font-size: 17px;
font-weight: 600;
margin-bottom: 10px;
}

.schedule-card p {
font-size: 13px;
opacity: .85;
line-height: 1.5;
}

/* ── SECTION HEADER ─────────────────────────── */
section {
padding: 70px 0;
}

.section-header {
text-align: center;
margin-bottom: 48px;
}

.section-header .overline {
font-size: 12px;
font-weight: 600;
letter-spacing: 1px;
color: var(--primary);
text-transform: uppercase;
display: block;
margin-bottom: 10px;
}

.section-header h2 {
font-size: 32px;
font-weight: 700;
color: var(--dark);
position: relative;
display: inline-block;
padding-bottom: 16px;
}

.section-header h2::after {
content: '';
position: absolute;
left: 50%;
transform: translateX(-50%);
bottom: 0;
width: 50px;
height: 3px;
background: var(--primary);
border-radius: 2px;
}

.section-header p {
margin-top: 14px;
max-width: 540px;
margin-left: auto;
margin-right: auto;
}

/* ── DEPARTMENTS ─────────────────────────────── */
.depts {
background: var(--light-bg);
}

.depts .container {
max-width: 1200px;
margin: 0 auto;
padding: 0 24px;
}

.dept-grid {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 24px;
}

.dept-card {
background: var(--white);
border-radius: var(--radius);
padding: 36px 20px 28px;
text-align: center;
box-shadow: var(--shadow-sm);
transition: var(--transition);
cursor: pointer;
display: block;
color: inherit;
}

.dept-card:hover {
transform: translateY(-7px);
box-shadow: var(--shadow-md);
color: inherit;
}

.dept-card:hover .dept-icon-wrap {
background: var(--primary);
border-color: transparent;
}

.dept-card:hover .dept-icon-wrap i {
color: #fff;
}

.dept-icon-wrap {
width: 90px;
height: 90px;
border-radius: 50%;
border: 1px solid #e0e0e0;
display: flex;
align-items: center;
justify-content: center;
margin: 0 auto 20px;
transition: var(--transition);
}

.dept-icon-wrap i {
font-size: 38px;
color: var(--primary);
transition: var(--transition);
}

.dept-card h3 {
font-size: 16px;
font-weight: 600;
color: var(--dark);
margin-bottom: 8px;
}

.dept-card p {
font-size: 13px;
line-height: 1.5;
}

/* ── SERVICES ────────────────────────────────── */
.services .container {
max-width: 1200px;
margin: 0 auto;
padding: 0 24px;
}

.services-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 28px;
}

.service-card {
background: var(--white);
border-radius: var(--radius);
box-shadow: var(--shadow-sm);
overflow: hidden;
transition: var(--transition);
cursor: pointer;
display: block;
color: inherit;
position: relative;
}

.service-card::after {
content: '';
position: absolute;
left: 0;
bottom: 0;
height: 3px;
width: 0%;
background: var(--primary);
transition: var(--transition);
}

.service-card:hover {
transform: translateY(-6px);
box-shadow: var(--shadow-md);
color: inherit;
}

.service-card:hover::after {
width: 100%;
}

.service-img {
height: 140px;
background: linear-gradient(135deg, #c8e3f5 0%, #e8f4fd 100%);
display: flex;
align-items: center;
justify-content: center;
}

.service-img i {
font-size: 52px;
color: var(--primary);
opacity: .6;
}

.service-body {
padding: 22px;
}

.service-body h3 {
font-size: 16px;
font-weight: 600;
color: var(--dark);
margin-bottom: 8px;
}

.service-body p {
font-size: 13px;
line-height: 1.55;
}

/* ── FUN FACTS ───────────────────────────────── */
.fun-facts {
background: var(--primary);
padding: 70px 0;
}

.fun-facts .container {
max-width: 1200px;
margin: 0 auto;
padding: 0 24px;
display: grid;
grid-template-columns: repeat(4,1fr);
gap: 32px;
}

.fact-item {
display: flex;
align-items: center;
gap: 18px;
}

.fact-icon {
width: 66px;
height: 66px;
border-radius: 50%;
border: 2px solid rgba(255,255,255,.4);
display: flex;
align-items: center;
justify-content: center;
flex-shrink: 0;
transition: var(--transition);
}

.fact-item:hover .fact-icon {
background: #fff;
border-color: transparent;
}

.fact-item:hover .fact-icon i {
color: var(--primary);
}

.fact-icon i {
font-size: 26px;
color: #fff;
transition: var(--transition);
}

.fact-content strong {
display: block;
font-size: 28px;
font-weight: 700;
color: #fff;
}

.fact-content span {
font-size: 13px;
color: rgba(255,255,255,.8);
}

/* ── CALL TO ACTION ──────────────────────────── */
.cta-section {
background: linear-gradient(135deg, var(--dark) 0%, #3a3b55 100%);
padding: 80px 0;
}

.cta-section .container {
max-width: 1200px;
margin: 0 auto;
padding: 0 24px;
text-align: center;
}

.cta-section h2 {
font-size: 32px;
font-weight: 700;
color: #fff;
line-height: 1.3;
margin-bottom: 16px;
}

.cta-section p {
color: rgba(255,255,255,.75);
max-width: 500px;
margin: 0 auto 32px;
font-size: 15px;
}

.cta-btns {
display: flex;
gap: 16px;
justify-content: center;
flex-wrap: wrap;
}

.btn-white {
background: #fff;
color: var(--primary);
padding: 13px 32px;
border-radius: var(--radius);
font-weight: 600;
font-size: 14px;
transition: var(--transition);
display: inline-block;
}

.btn-white:hover {
background: var(--primary);
color: #fff;
transform: translateY(-2px);
}

.btn-ghost {
background: transparent;
color: #fff;
border: 2px solid rgba(255,255,255,.5);
padding: 11px 30px;
border-radius: var(--radius);
font-weight: 500;
font-size: 14px;
transition: var(--transition);
display: inline-block;
}

.btn-ghost:hover {
border-color: #fff;
background: rgba(255,255,255,.1);
color: #fff;
transform: translateY(-2px);
}

/* ── FOOTER ──────────────────────────────────── */
.site-footer {
background: var(--primary);
padding: 60px 0 0;
position: relative;
}

.site-footer::before {
content: '';
position: absolute;
left: 0;
top: 0;
width: 100%;
height: 100%;
background: #000;
opacity: .08;
}

.site-footer .container {
max-width: 1200px;
margin: 0 auto;
padding: 0 24px;
position: relative;
z-index: 1;
display: grid;
grid-template-columns: 2fr 1fr 1fr 1.5fr;
gap: 40px;
}

.footer-col h3 {
font-size: 18px;
font-weight: 600;
color: #fff;
margin-bottom: 28px;
padding-bottom: 14px;
position: relative;
}

.footer-col h3::after {
content: '';
position: absolute;
left: 0;
bottom: 0;
width: 40px;
height: 2px;
background: #fff;
}

.footer-col p {
color: rgba(255,255,255,.85);
font-size: 14px;
line-height: 1.7;
}

.footer-links {
list-style: none;
}

.footer-links li {
margin-bottom: 10px;
}

.footer-links a {
color: rgba(255,255,255,.85);
font-size: 14px;
transition: var(--transition);
display: inline-flex;
align-items: center;
gap: 8px;
}

.footer-links a:hover {
color: #fff;
padding-left: 6px;
}

.footer-links a i {
font-size: 11px;
color: #fff;
}

.social-links {
display: flex;
gap: 10px;
margin-top: 20px;
}

.social-links a {
width: 36px;
height: 36px;
border-radius: 50%;
border: 1px solid rgba(255,255,255,.5);
display: flex;
align-items: center;
justify-content: center;
color: #fff;
font-size: 14px;
transition: var(--transition);
}

.social-links a:hover {
background: #fff;
color: var(--primary);
border-color: transparent;
}
/* footer hours */
.hours-list {
list-style: none;
}

.hours-list li {
display: flex;
justify-content: space-between;
color: rgba(255,255,255,.85);
font-size: 13px;
padding: 5px 0;
border-bottom: 1px dashed rgba(255,255,255,.2);
}

.hours-list li:last-child {
border: none;
}
/* footer copyright */
.footer-bottom {
background: rgba(0,0,0,.1);
margin-top: 40px;
padding: 18px 24px;
text-align: center;
position: relative;
z-index: 1;
}

.footer-bottom p {
color: rgba(255,255,255,.75);
font-size: 13px;
}

.footer-bottom a {
color: #fff;
text-decoration: underline;
}

.footer-bottom a:hover {
opacity: .75;
}

/* ── SCROLL UP ───────────────────────────────── */
#scrollUp {
position: fixed;
bottom: 20px;
right: 20px;
width: 44px;
height: 44px;
background: var(--primary);
color: #fff;
border-radius: var(--radius);
display: flex;
align-items: center;
justify-content: center;
font-size: 18px;
box-shadow: 0 4px 14px rgba(26,118,209,.4);
cursor: pointer;
z-index: 9998;
transition: var(--transition);
opacity: 0;
pointer-events: none;
}

#scrollUp.show {
opacity: 1;
pointer-events: all;
}

#scrollUp:hover {
background: var(--dark);
}

/* ── RESPONSIVE ─────────────────────────────── */
@@media (max-width:992px) {
.schedule-grid {
grid-template-columns: repeat(2,1fr);
}

.dept-grid {
grid-template-columns: repeat(2,1fr);
}

.services-grid {
grid-template-columns: repeat(2,1fr);
}

.fun-facts .container {
grid-template-columns: repeat(2,1fr);
}

.site-footer .container {
grid-template-columns: 1fr 1fr;
}

.hero-img {
display: none;
}
}

@@media (max-width:768px) {
.topbar {
display: none;
}

.main-nav {
display: none;
}

.hero-text h1 {
font-size: 32px;
}

.hero {
padding: 50px 0 0;
}

.hero .container {
padding: 0 18px;
}

.schedule-strip .container {
transform: translateY(-20px);
padding: 0 18px;
}

.schedule-grid {
grid-template-columns: 1fr 1fr;
gap: 14px;
}

.dept-grid {
grid-template-columns: 1fr 1fr;
}

.services-grid {
grid-template-columns: 1fr;
}

.fun-facts .container {
grid-template-columns: 1fr 1fr;
}

.site-footer .container {
grid-template-columns: 1fr;
}

.section-header h2 {
font-size: 26px;
}
}
</style>
<div class="topbar">
    <div class="container">
        <ul class="top-links">
            <li><a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a></li>
            <li><a asp-controller="Departments" asp-action="Index">Departments</a></li>
            <li><a asp-controller="Staffs" asp-action="Index">Doctors</a></li>

            <li class="lang-dropdown">
                <a href="javascript:void(0)"><i class="fas fa-globe"></i> Language <i class="fas fa-chevron-down" style="font-size:10px; margin-left:4px;"></i></a>
                <ul class="lang-menu">
                    <li><a href="javascript:void(0)" onclick="changeLanguage('en', 'en')">🇬🇧 English</a></li>
                    <li><a href="javascript:void(0)" onclick="changeLanguage('en', 'ar')">🇪🇬 العربية</a></li>
                    <li><a href="javascript:void(0)" onclick="changeLanguage('en', 'fr')">🇫🇷 Français</a></li>
                    <li><a href="javascript:void(0)" onclick="changeLanguage('en', 'de')">🇩🇪 Deutsch</a></li>
                </ul>
            </li>
        </ul>
        <ul class="top-contact">
            <li><i class="fas fa-phone"></i> Emergency: 122</li>
            <li><i class="fas fa-clock"></i> Mon–Sat: 08:00 – 20:00</li>
        </ul>
    </div>
</div>

<div class="header-inner">
    <div class="container">
        <a asp-controller="Home" asp-action="Index" class="logo">
            <div class="logo-icon">
                <img src="~/images/logo/LOGO.png" alt="CarePlus Logo" style="width: 100%; height: 100%; object-fit: contain;" />
            </div>
        </a>

