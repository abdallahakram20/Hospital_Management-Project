<div id="google_translate_element"></div>

<script type="text/javascript" src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
<script type="text/javascript">
    function googleTranslateElementInit() {
        new google.translate.TranslateElement({
            pageLanguage: 'en',
            includedLanguages: 'en,ar,fr,de',
            autoDisplay: false
        }, 'google_translate_element');
    }

    function changeLanguage(sourceLang, targetLang) {
        var cookieValue = '/' + sourceLang + '/' + targetLang;
        document.cookie = "googtrans=" + cookieValue + "; path=/";
        document.cookie = "googtrans=" + cookieValue + "; domain=" + window.location.hostname + "; path=/";

        var selectElement = document.querySelector('.goog-te-combo');
        if (selectElement) {
            selectElement.value = targetLang;
            selectElement.dispatchEvent(new Event('change'));
        } else {
            window.location.reload();
        }
    }

    window.addEventListener('scroll', function() {
        var scrollBtn = document.getElementById('scrollUp');
        if(scrollBtn) {
            scrollBtn.classList.toggle('show', window.scrollY > 300);
        }
    });
</script>

        <script>
        (function () {
            if (window.history.pushState) {
                window.history.pushState(null, null, window.location.href);
                
                window.addEventListener('popstate', function () {
                    window.location.href = '/Home/Index'; // التوجيه المباشر للرئيسية
                });
            }

            window.addEventListener('pageshow', function (event) {
                if (event.persisted || (typeof window.performance != "undefined" && window.performance.getEntriesByType("navigation")[0]?.type === "back_forward")) {
                    window.location.reload(true);
                }
            });
        })();
    </script>