@model Hospital_Management_Project.Models.LoginView

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CarePlus</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
            @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');

            body {
                margin: 0;
                font-family: 'DM Sans', sans-serif;
                background: url('@Url.Content("~/images/Background/Gemini_Generated_Image_4x8ac34x8ac34x8a.png")') no-repeat center center fixed;
                background-size: cover;
                height: 100vh;
                overflow: hidden;
            }

            .login-page-wrapper {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100vh;
                background-color: rgba(10, 25, 49, 0.4);
                backdrop-filter: blur(8px);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
                z-index: 9999;
                overflow-y: auto;
            }

            /* 🌟 تم تحديد الارتفاع بدقة هنا لمنع تمدد الكارت نهائياً 🌟 */
            .login-container {
                background: rgba(255, 255, 255, 0.96);
                border-radius: 24px;
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
                display: flex;
                flex-direction: row;
                max-width: 850px;
                width: 100%;
                height: 520px; /* الارتفاع أصبح ثابتاً وموحداً */
                overflow: hidden;
            }

            .login-left {
                padding: 30px 35px 20px 35px;
                width: 50%;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                background-color: #ffffff;
                height: 100%;
            }

            .login-right {
                width: 50%;
                background: radial-gradient(circle at center, rgba(0, 86, 210, 0.9) 0%, rgba(0, 60, 163, 0.95) 100%);
                display: flex;
                align-items: center;
                justify-content: center;
                position: relative;
                height: 100%;
            }

            /* 🌟 تظبيط مساحة التاب وحمايتها من التمدد المفاجئ 🌟 */
            .tab-content {
                flex-grow: 1;
                display: flex;
                flex-direction: column;
                justify-content: center;
                overflow-y: auto; /* إضافة سكول داخلي خفي وسلس جداً عند الحاجة فقط */
                padding-right: 2px;
            }

                .tab-content::-webkit-scrollbar {
                    width: 4px;
                }

                .tab-content::-webkit-scrollbar-thumb {
                    background: #E2E8F0;
                    border-radius: 10px;
                }

            .brand-title {
                color: #0A1931;
                font-family: 'Playfair Display', serif;
                font-weight: 700;
                font-size: 26px;
                margin-bottom: 2px;
                text-align: center;
            }

            .brand-subtitle {
                color: #0056D2;
                font-size: 13px;
                text-align: center;
                margin-bottom: 15px;
                font-weight: 600;
            }

            .nav-pills {
                background: #F0F4FA;
                border-radius: 50px;
                padding: 4px;
                margin-bottom: 15px;
                border-bottom: none;
            }

                .nav-pills .nav-link {
                    color: #657795;
                    border-radius: 50px;
                    padding: 8px 12px;
                    font-weight: 600;
                    font-size: 13px;
                    transition: all 0.3s ease;
                }

                    .nav-pills .nav-link.active {
                        background-color: #ffffff;
                        color: #0056D2;
                        box-shadow: 0 4px 12px rgba(0, 86, 210, 0.15);
                        font-weight: 700;
                        border: none;
                    }

            .form-label-custom {
                font-size: 12px;
                font-weight: 600;
                color: #4A5568;
                margin-bottom: 4px;
            }

            .custom-input {
                border: 1px solid #E2E8F0;
                border-radius: 12px;
                padding: 9px 14px;
                background-color: #F8FAFC;
                color: #0A1931;
                font-size: 13px;
                box-shadow: none !important;
                transition: all 0.3s ease;
            }

                .custom-input::placeholder {
                    color: #94A3B8;
                }

                .custom-input:focus {
                    border-color: #0056D2;
                    background-color: #ffffff;
                    color: #0A1931;
                    box-shadow: 0 0 0 4px rgba(0, 86, 210, 0.15) !important;
                }

            .toggle-password {
                right: 15px !important;
                top: 31px !important;
                color: #94A3B8 !important;
                transition: color 0.2s;
            }

                .toggle-password:hover {
                    color: #0056D2 !important;
                }

            .btn-custom {
                background-color: #0056D2;
                color: #ffffff;
                border-radius: 50px;
                font-weight: 600;
                font-size: 14px;
                padding: 10px;
                border: none;
                transition: all 0.2s ease;
                margin-bottom: 2px;
                box-shadow: 0 4px 14px rgba(0, 86, 210, 0.3);
            }

                .btn-custom:hover {
                    background-color: #0043A8;
                    transform: translateY(-2px);
                    color: #ffffff;
                    box-shadow: 0 6px 20px rgba(0, 86, 210, 0.4);
                }

            .register-container {
                text-align: center;
                margin-top: 8px;
                padding-top: 8px;
                border-top: 1px dashed #E2E8F0;
            }

            .register-text {
                font-size: 11.5px;
                color: #657795;
                margin-bottom: 4px;
            }

            .btn-register-outline {
                background-color: transparent;
                color: #0056D2;
                border: 2px solid #0056D2;
                border-radius: 50px;
                font-weight: 600;
                font-size: 12.5px;
                padding: 6px 16px;
                transition: all 0.2s ease;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                width: 100%;
            }

                .btn-register-outline:hover {
                    background-color: #0056D2;
                    color: #ffffff;
                    transform: translateY(-1px);
                    box-shadow: 0 4px 12px rgba(0, 86, 210, 0.2);
                }

            .options-row {
                font-size: 12px;
                color: #657795;
                margin-top: 8px;
                margin-bottom: 12px;
                align-items: center;
            }

                .options-row a {
                    color: #0056D2;
                    text-decoration: none;
                    font-weight: 600;
                }

                    .options-row a:hover {
                        text-decoration: underline;
                    }

                .options-row input[type="checkbox"] {
                    accent-color: #0056D2;
                    width: 14px;
                    height: 14px;
                    cursor: pointer;
                    vertical-align: middle;
                    margin-right: 4px;
                }

            .alert-custom {
                background-color: #EDF4FF;
                border-radius: 12px;
                padding: 10px;
                color: #1E3A8A;
                font-size: 11.5px;
                display: flex;
                align-items: flex-start;
                gap: 10px;
                border-left: 4px solid #0056D2;
                margin-top: 10px;
            }

                .alert-custom i {
                    color: #0056D2;
                }

            .circle-graphic-wrapper {
                position: relative;
                width: 260px;
                height: 260px;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .circle-track {
                position: absolute;
                width: 220px;
                height: 220px;
                border: 2px dashed rgba(255, 255, 255, 0.3);
                border-radius: 50%;
                animation: spin 40s linear infinite;
            }

            @@keyframes spin {
                100% {
                    transform: rotate(360deg);
                }
            }

            .center-circle {
                position: relative;
                width: 130px;
                height: 130px;
                background: #ffffff;
                border: 5px solid #EDF4FF;
                border-radius: 50%;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                z-index: 10;
                box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            }

                .center-circle h3 {
                    color: #0A1931;
                    margin: 0;
                    font-family: 'Playfair Display', serif;
                    font-weight: 700;
                    font-size: 18px;
                }

                .center-circle p {
                    color: #0056D2;
                    margin: 0;
                    font-size: 10px;
                    font-weight: 600;
                }

            .node {
                position: absolute;
                width: 36px;
                height: 36px;
                background: #ffffff;
                color: #0056D2;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 16px;
                z-index: 5;
                box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            }

            .node-1 {
                top: 0;
                left: 50%;
                transform: translate(-50%, -50%);
            }

            .node-2 {
                top: 14.6%;
                left: 85.3%;
                transform: translate(-50%, -50%);
            }

            .node-3 {
                top: 50%;
                left: 100%;
                transform: translate(-50%, -50%);
            }

            .node-4 {
                top: 85.3%;
                left: 85.3%;
                transform: translate(-50%, -50%);
            }

            .node-5 {
                top: 100%;
                left: 50%;
                transform: translate(-50%, -50%);
            }

            .node-6 {
                top: 85.3%;
                left: 14.6%;
                transform: translate(-50%, -50%);
            }

            .node-7 {
                top: 50%;
                left: 0;
                transform: translate(-50%, -50%);
            }

            .node-8 {
                top: 14.6%;
                left: 14.6%;
                transform: translate(-50%, -50%);
            }

            .bottom-buildings {
                position: absolute;
                bottom: 0;
                left: 0;
                width: 100%;
                height: 40px;
                background-image: url('data:image/svg+xml;utf8,<svg opacity="0.15" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 20"><rect x="5" y="10" width="8" height="10" fill="%23ffffff"/><rect x="18" y="5" width="12" height="15" fill="%23ffffff"/><rect x="35" y="12" width="10" height="8" fill="%23ffffff"/><rect x="50" y="8" width="12" height="12" fill="%23ffffff"/><rect x="68" y="3" width="15" height="17" fill="%23ffffff"/><rect x="88" y="11" width="8" height="9" fill="%23ffffff"/></svg>');
                background-repeat: repeat-x;
                background-position: bottom;
                background-size: 150px;
            }

            @@media (max-width: 768px) {
                .login-container {
                    flex-direction: column;
                    height: auto;
                    max-height: 90vh;
                    overflow-y: auto;
                }

                .login-left, .login-right {
                    width: 100%;
                    height: auto;
                }

                .login-left {
                    padding: 30px 20px;
                }

                .login-right {
                    display: none;
                }
            }
    </style>
</head>
<body>

    <div class="login-page-wrapper">
        <div class="login-container">

            <div class="login-left">
                <div>
                    <h2 class="brand-title">CarePlus</h2>
                    <p class="brand-subtitle">Medical Service</p>

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <ul class="nav nav-pills nav-justified" id="loginTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model?.UserType != "Patient" ? "active" : "")"
                                    id="staff-tab" data-bs-toggle="pill" data-bs-target="#staffLogin" type="button" role="tab" aria-controls="staffLogin" aria-selected="@(Model?.UserType != "Patient" ? "true" : "false")">
                                Staff Member
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model?.UserType == "Patient" ? "active" : "")"
                                    id="patient-tab" data-bs-toggle="pill" data-bs-target="#patientLogin" type="button" role="tab" aria-controls="patientLogin" aria-selected="@(Model?.UserType == "Patient" ? "true" : "false")">
                                Patient
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <div class="tab-pane fade @(Model?.UserType != "Patient" ? "show active" : "")" id="staffLogin" role="tabpanel" aria-labelledby="staff-tab">
                            <form asp-controller="Account" asp-action="Login" method="post">
                                <input type="hidden" name="UserType" value="Staff" />

                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label-custom">Staff Email Address</label>
                                    <input asp-for="Email" id="staffEmail" class="form-control custom-input" placeholder="staffmember@careplus.com" required
                                           pattern="^[^]+@@careplus\.com$"
                                           title="Only @@careplus.com email addresses are accepted" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                    <div id="emailDomainHint" class="text-danger small mt-1" style="display:none;">
                                        <i class="bi bi-exclamation-circle-fill"></i> Email must end with <strong>@@careplus.com</strong>
                                    </div>
                                </div>

                                <div class="mb-3 position-relative">
                                    <label asp-for="Password" class="form-label-custom">Password</label>
                                    <input asp-for="Password" type="password" class="form-control custom-input" placeholder="••••••••" required />
                                    <i class="bi bi-eye-slash position-absolute toggle-password" style="cursor: pointer;"></i>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>

                                <div class="d-flex justify-content-between options-row">
                                    <div>
                                        <input type="checkbox" id="rememberStaff" />
                                        <label for="rememberStaff">Remember me</label>
                                    </div>
                                    <a asp-controller="Account" asp-action="ForgotPassword" asp-route-userType="Staff">Forgot Password?</a>
                                </div>

                                <button type="submit" class="btn btn-custom w-100">Login</button>
                            </form>
                        </div>

                        <div class="tab-pane fade @(Model?.UserType == "Patient" ? "show active" : "")" id="patientLogin" role="tabpanel" aria-labelledby="patient-tab">
                            <form asp-controller="Account" asp-action="Login" method="post">
                                <input type="hidden" name="UserType" value="Patient" />

                                <div class="mb-3">
                                    <label asp-for="UserName" class="form-label-custom">Patient Username</label>
                                    <input asp-for="UserName" class="form-control custom-input" placeholder="username" required />
                                    <span asp-validation-for="UserName" class="text-danger small"></span>
                                </div>

                                <div class="mb-3 position-relative">
                                    <label asp-for="Password" class="form-label-custom">Password</label>
                                    <input asp-for="Password" type="password" class="form-control custom-input" placeholder="••••••••" required />
                                    <i class="bi bi-eye-slash position-absolute toggle-password" style="cursor: pointer;"></i>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>

                                <div class="d-flex justify-content-between options-row">
                                    <div>
                                        <input type="checkbox" id="rememberPatient" />
                                        <label for="rememberPatient">Remember me</label>
                                    </div>
                                    <a asp-controller="Account" asp-action="ForgotPassword" asp-route-userType="Patient">Forgot Password?</a>
                                </div>

                                <button type="submit" class="btn btn-custom w-100">Login</button>
                            </form>

                            <div class="register-container">
                                <p class="register-text">New patient without credentials?</p>
                                <a asp-controller="Patients" asp-action="Create" class="btn-register-outline">
                                    <i class="bi bi-person-plus-fill"></i> Create Account Here
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert-custom">
                    <i class="bi bi-info-circle-fill fs-6"></i>
                    <div>
                        <strong>Security Update:</strong> Need first login help? Contact admin.
                    </div>
                </div>

            </div>

            <div class="login-right">
                <div class="circle-graphic-wrapper">
                    <div class="circle-track"></div>
                    <div class="center-circle">
                        <h3>CarePlus</h3>
                        <p>Medical Service</p>
                    </div>
                    <div class="node node-1"><i class="bi bi-person"></i></div>
                    <div class="node node-2"><i class="bi bi-thermometer-half"></i></div>
                    <div class="node node-3"><i class="bi bi-heart-pulse"></i></div>
                    <div class="node node-4"><i class="bi bi-clipboard2-pulse"></i></div>
                    <div class="node node-5"><i class="bi bi-capsule"></i></div>
                    <div class="node node-6"><i class="bi bi-activity"></i></div>
                    <div class="node node-7"><i class="bi bi-bandaid"></i></div>
                    <div class="node node-8"><i class="bi bi-file-medical"></i></div>
                </div>
                <div class="bottom-buildings"></div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
        const togglePasswordIcons = document.querySelectorAll('.toggle-password');

        togglePasswordIcons.forEach(function (icon) {
        icon.addEventListener('click', function () {
        const input = this.parentElement.querySelector('input');
        if (input.type === 'password') {
        input.type = 'text';
        this.classList.remove('bi-eye-slash');
        this.classList.add('bi-eye');
        } else {
        input.type = 'password';
        this.classList.remove('bi-eye');
        this.classList.add('bi-eye-slash');
        }
        });
        });

        const staffEmailInput = document.getElementById('staffEmail');
        const emailDomainHint = document.getElementById('emailDomainHint');

        if (staffEmailInput) {
        staffEmailInput.addEventListener('input', function () {
        const val = this.value.trim().toLowerCase();
        if (val.length > 0 && !val.endsWith('@@careplus.com')) {
        emailDomainHint.style.display = 'block';
        this.classList.add('is-invalid');
        } else {
        emailDomainHint.style.display = 'none';
        this.classList.remove('is-invalid');
        }
        });

        staffEmailInput.closest('form').addEventListener('submit', function (e) {
        const val = staffEmailInput.value.trim().toLowerCase();
        if (!val.endsWith('@@careplus.com')) {
        e.preventDefault();
        emailDomainHint.style.display = 'block';
        staffEmailInput.classList.add('is-invalid');
        staffEmailInput.focus();
        }
        });
        }
        });
    </script>
</body>
</html>