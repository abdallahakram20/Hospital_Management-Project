@model Hospital_Management_Project.Models.LoginView

@{
    ViewData["Title"] = "Login";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-dark text-white text-center p-4">
                    <h3>Hospital Portal</h3>
                    <p class="mb-0 small">Welcome! Please identify yourself</p>
                </div>
                
                <div class="card-body p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <ul class="nav nav-pills nav-justified mb-4" id="loginTabs" role="tablist">
                        <li class="nav-item">
                            <button class="nav-link @(Model?.UserType != "Patient" ? "active" : "")"
                                    id="staff-tab" data-bs-toggle="pill" data-bs-target="#staffLogin" type="button">
                                Staff Member
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(Model?.UserType == "Patient" ? "active" : "")"
                                    id="patient-tab" data-bs-toggle="pill" data-bs-target="#patientLogin" type="button">
                                Patient
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content">
                        <div class="tab-pane fade @(Model?.UserType != "Patient" ? "show active" : "")" id="staffLogin">
                            <form asp-controller="Account" asp-action="Login" method="post">
                                <input type="hidden" name="UserType" value="Staff" />
                                
                                <div class="form-floating mb-3">
                                    <input asp-for="Email" class="form-control" placeholder="Email" required />
                                    <label asp-for="Email">Staff Email Address</label>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                                
                                <div class="form-floating mb-3">
                                    <input asp-for="Password" type="password" class="form-control" placeholder="Password" required />
                                    <label asp-for="Password">Password</label>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                                
                                <button type="submit" class="btn btn-primary w-100 py-2">Login as Staff</button>
                                
                                <div class="text-center mt-3">
                                    <p class="small text-muted mb-0">Note: Use your registered hospital email.</p>
                                </div>
                            </form>
                        </div>

                        <div class="tab-pane fade @(Model?.UserType == "Patient" ? "show active" : "")" id="patientLogin">
                            <form asp-controller="Account" asp-action="Login" method="post">
                                <input type="hidden" name="UserType" value="Patient" />
                                
                                <div class="form-floating mb-3">
                                    <input asp-for="UserName" class="form-control" placeholder="Username" required />
                                    <label asp-for="UserName">Patient Username</label>
                                    <span asp-validation-for="UserName" class="text-danger small"></span>
                                </div>
                                
                                <div class="form-floating mb-3">
                                    <input asp-for="Password" type="password" class="form-control" placeholder="Password" required />
                                    <label asp-for="Password">Password</label>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                                
                                <button type="submit" class="btn btn-success w-100 py-2">Login as Patient</button>
                                
                                <div class="d-flex justify-content-between mt-3">
                                    <a asp-controller="Patients" asp-action="Create" class="small text-decoration-none fw-bold">New Patient? Register</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="mt-4 p-3 bg-light border rounded">
                <p class="small text-secondary mb-0 text-center">
                    <i class="bi bi-info-circle"></i>
                    Security Update: If this is your first login after the update, please contact the admin to reset your password with the new encryption.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}