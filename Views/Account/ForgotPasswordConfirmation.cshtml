@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Forgot Password Confirmation";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
            body {
                margin: 0;
                font-family: 'Poppins', sans-serif;
                /* خلفية ناعمة متناسقة مع تدرج الـ Layout الأساسي */
                background-color: #f3f8ff;
                background-image: radial-gradient(circle at 10% 20%, #e2eeff 0%, transparent 40%), radial-gradient(circle at 90% 80%, #cbdfff 0%, transparent 40%);
                background-attachment: fixed;
                min-height: 100vh;
            }

            .wrapper {
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
                box-sizing: border-box;
            }

            .confirmation-card {
                background: #ffffff;
                border-radius: 24px;
                padding: 50px;
                width: 100%;
                max-width: 480px;
                text-align: center;
                /* شادو ناعم جداً وبدون حواف حادة */
                box-shadow: 0 12px 40px rgba(21, 101, 192, 0.06);
                border: 1px solid rgba(21, 101, 192, 0.05);
            }

            /* دائرة الأيقونة بالأزرق السماوي المريح */
            .icon-circle {
                width: 80px;
                height: 80px;
                background: #eef4ff;
                color: #2563eb;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 38px;
                margin: 0 auto 24px;
            }

            .title {
                color: #1e293b;
                font-size: 26px;
                font-weight: 700;
                margin-bottom: 12px;
            }

            .message {
                color: #64748b;
                font-size: 15px;
                line-height: 1.6;
                margin-bottom: 25px;
            }

            /* الزر الرئيسي باللون الأزرق الخاص بالـ Layout */
            .btn-custom {
                background-color: #1565c0;
                color: #ffffff;
                border-radius: 50px;
                font-weight: 600;
                font-size: 15px;
                padding: 12px 35px;
                text-decoration: none;
                display: inline-block;
                transition: all 0.2s ease;
                box-shadow: 0 4px 12px rgba(21, 101, 192, 0.2);
            }

                .btn-custom:hover {
                    background-color: #0d47a1;
                    transform: translateY(-2px);
                    box-shadow: 0 6px 15px rgba(21, 101, 192, 0.3);
                    color: #ffffff;
                }

            /* بوكس التيست الداخلي المطور ليناسب التصميم الطبي الجديد */
            .testing-box {
                background-color: #f8fafc;
                border: 1px dashed #cbd5e1;
                border-radius: 16px;
                padding: 20px;
                margin-bottom: 30px;
            }

            .testing-text {
                color: #475569;
                font-size: 13.5px;
                line-height: 1.5;
                margin-top: 0;
                margin-bottom: 15px;
            }

            .btn-testing {
                background-color: #1e293b;
                color: #ffffff;
                padding: 10px 24px;
                border-radius: 50px;
                text-decoration: none;
                font-size: 13px;
                font-weight: 600;
                display: inline-block;
                transition: all 0.2s ease;
            }

                .btn-testing:hover {
                    background-color: #0f172a;
                    transform: translateY(-1px);
                    color: #ffffff;
                }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class="confirmation-card">
            <div class="icon-circle">
                <i class="bi bi-envelope-check-fill"></i>
            </div>
            <h2 class="title">Check Your Inbox</h2>
            <p class="message">
                @ViewBag.Message
            </p>

            @if (ViewBag.ResetLink != null)
            {
                <div class="testing-box">
                    <p class="testing-text">
                        <strong style="color: #ef4444;"><i class="bi bi-bug-fill"></i> [For Testing Only]</strong> <br />
                        Since email integration is not active yet, you can use this link to proceed:
                    </p>
                    <a href="@ViewBag.ResetLink" class="btn-testing">
                        Reset My Password
                    </a>
                </div>
            }

            <a asp-controller="Account" asp-action="Login" class="btn-custom">Return to Login</a>
        </div>
    </div>
</body>
</html>