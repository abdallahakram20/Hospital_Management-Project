@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Forgot Password";
    var userType = ViewBag.UserType as string ?? "Staff";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            body {
                margin: 0;
                font-family: 'Poppins', sans-serif;
            }

            /* الـ Wrapper بالخلفية المتدرجة الطبية الناعمة المتناسقة مع الـ Layout */
            .login-page-wrapper {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100vh;
                background-color: #f3f8ff;
                background-image: radial-gradient(circle at 15% 20%, #e2eeff 0%, transparent 45%), radial-gradient(circle at 85% 80%, #cbdfff 0%, transparent 45%);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
                z-index: 9999;
                box-sizing: border-box;
            }

            /* الكارد بالشادو الأزرق المريح الناعم */
            .reset-container {
                background: #ffffff;
                border-radius: 24px;
                box-shadow: 0 12px 40px rgba(21, 101, 192, 0.06);
                border: 1px solid rgba(21, 101, 192, 0.05);
                padding: 50px;
                max-width: 450px;
                width: 100%;
            }

            .brand-title {
                color: #1e293b;
                font-weight: 700;
                font-size: 32px;
                margin-bottom: 4px;
                text-align: center;
            }

            .brand-subtitle {
                color: #64748b;
                font-size: 15px;
                font-weight: 500;
                text-align: center;
                margin-bottom: 30px;
            }

            .form-label-custom {
                font-size: 13.5px;
                font-weight: 600;
                color: #475569;
                margin-bottom: 8px;
                display: block;
            }

            /* حقل الإدخال الأزرق المطور */
            .custom-input {
                border: 1px solid #cbd5e1;
                border-radius: 12px;
                padding: 12px 15px;
                background-color: #ffffff;
                color: #1e293b;
                font-size: 14px;
                box-shadow: none !important;
                transition: all 0.3s ease;
                width: 100%;
                box-sizing: border-box;
            }

                .custom-input:focus {
                    border-color: #2563eb;
                    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1) !important;
                    outline: none;
                }

            /* الزر الرئيسي الأزرق الملكي الخاص بالـ Layout */
            .btn-custom {
                background-color: #1565c0;
                color: #ffffff;
                border-radius: 50px;
                font-weight: 600;
                font-size: 15px;
                padding: 14px;
                border: none;
                transition: all 0.2s ease;
                width: 100%;
                margin-top: 20px;
                box-shadow: 0 4px 12px rgba(21, 101, 192, 0.2);
                cursor: pointer;
            }

                .btn-custom:hover {
                    background-color: #0d47a1;
                    transform: translateY(-2px);
                    box-shadow: 0 6px 15px rgba(21, 101, 192, 0.3);
                    color: #ffffff;
                }

            /* لينك العودة بستايل متناسق مع درجات الأزرق */
            .back-link {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 6px;
                width: 100%;
                text-align: center;
                margin-top: 22px;
                color: #2563eb;
                font-weight: 600;
                text-decoration: none;
                font-size: 14px;
                transition: color 0.2s ease;
            }

                .back-link:hover {
                    color: #1d4ed8;
                    text-decoration: underline;
                }
        
            .alert-danger-custom {
                background-color: #fef2f2;
                border: 1px solid #fee2e2;
                color: #ef4444;
                border-radius: 12px;
                padding: 12px;
                font-size: 13.5px;
            }
    </style>
</head>
<body>

    <div class="login-page-wrapper">
        <div class="reset-container">
            <h2 class="brand-title">CarePlus</h2>
            <p class="brand-subtitle">Reset @userType Password</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-danger-custom mb-3">
                    @Html.ValidationSummary(false, "", new { @class = "text-danger p-0 m-0", style = "list-style-type: none;" })
                </div>
            }

            <form asp-controller="Account" asp-action="ForgotPassword" method="post">
                <input type="hidden" name="userType" value="@userType" />

                <div class="mb-2">
                    @if (userType == "Staff")
                    {
                        <label class="form-label-custom">Enter your registered Email</label>
                        <input type="email" name="identifier" class="custom-input" placeholder="staffmember@careplus.com" required />
                    }
                    else
                    {
                        <label class="form-label-custom">Enter your Patient Username</label>
                        <input type="text" name="identifier" class="custom-input" placeholder="e.g. abdallah" required />
                    }
                </div>

                <button type="submit" class="btn-custom">Send Reset Link</button>
            </form>

            <a asp-controller="Account" asp-action="Login" class="back-link">
                <i class="bi bi-arrow-left"></i> Back to Login
            </a>
        </div>
    </div>

</body>
</html>