@{
    ViewData["Title"] = "Forgot Password";

    var userType = ViewBag.UserType as string ?? "Staff";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');

    body {
        margin: 0;
        font-family: 'DM Sans', sans-serif;
    }

    .login-page-wrapper {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background-color: #dff0f3;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        z-index: 9999;
    }

    .reset-container {
        background: #ffffff;
        border-radius: 24px;
        box-shadow: 0 8px 32px rgba(59,191,191,0.08);
        padding: 50px;
        max-width: 450px;
        width: 100%;
    }

    .brand-title {
        color: #1a2e35;
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: 32px;
        margin-bottom: 5px;
        text-align: center;
    }

    .brand-subtitle {
        color: #5a7a82;
        font-size: 15px;
        text-align: center;
        margin-bottom: 30px;
    }

    .form-label-custom {
        font-size: 13px;
        font-weight: 600;
        color: #5a7a82;
        margin-bottom: 8px;
        display: block;
    }

    .custom-input {
        border: 1px solid #dce4e6;
        border-radius: 12px;
        padding: 12px 15px;
        background-color: #ffffff;
        color: #1a2e35;
        font-size: 14px;
        box-shadow: none !important;
        transition: all 0.3s ease;
        width: 100%;
    }

        .custom-input:focus {
            border-color: #3BBFBF;
            box-shadow: 0 0 0 4px rgba(59,191,191,0.1) !important;
            outline: none;
        }

    .btn-custom {
        background-color: #3BBFBF;
        color: #ffffff;
        border-radius: 50px;
        font-weight: 600;
        font-size: 15px;
        padding: 14px;
        border: none;
        transition: all 0.2s ease;
        width: 100%;
        margin-top: 20px;
    }

        .btn-custom:hover {
            background-color: #2aa0a0;
            transform: translateY(-2px);
            color: #ffffff;
        }

    .back-link {
        display: block;
        text-align: center;
        margin-top: 20px;
        color: #3BBFBF;
        font-weight: 600;
        text-decoration: none;
        font-size: 14px;
    }

        .back-link:hover {
            text-decoration: underline;
        }
</style>

<div class="login-page-wrapper">
    <div class="reset-container">
        <h2 class="brand-title">CarePlus</h2>
        <p class="brand-subtitle">Reset @userType Password</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger small mb-3">
                @Html.ValidationSummary(false, "", new { @class = "text-danger" })
            </div>
        }

        <form asp-controller="Account" asp-action="ForgotPassword" method="post">
            <input type="hidden" name="userType" value="@userType" />

            <div class="mb-4">
                @if (userType == "Staff")
                {
                    <label class="form-label-custom">Enter your registered Email</label>
                    <input type="email" name="identifier" class="custom-input" placeholder="staffmember@careplus.com" required />
                }
                else
                {
                    <label class="form-label-custom">Enter your Patient Username</label>
                    <input type="text" name="identifier" class="custom-input" placeholder="e.g. abdallah" required />
                }
            </div>

            <button type="submit" class="btn-custom">Send Reset Link</button>
        </form>

        <a asp-controller="Account" asp-action="Login" class="back-link">
            <i class="bi bi-arrow-left"></i> Back to Login
        </a>
    </div>
</div>