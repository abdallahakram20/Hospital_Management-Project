@{
    ViewData["Title"] = "Reset Password";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');

    body {
        margin: 0;
        font-family: 'DM Sans', sans-serif;
        background-color: #dff0f3;
    }

    .page-wrapper {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .reset-card {
        background: #ffffff;
        border-radius: 24px;
        padding: 50px;
        max-width: 450px;
        width: 100%;
        box-shadow: 0 8px 32px rgba(59,191,191,0.08);
    }

    .brand-title {
        color: #1a2e35;
        font-family: 'Playfair Display', serif;
        font-weight: 700;
        font-size: 32px;
        margin-bottom: 5px;
        text-align: center;
    }

    .brand-subtitle {
        color: #5a7a82;
        font-size: 14px;
        text-align: center;
        margin-bottom: 30px;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #5a7a82;
        margin-bottom: 8px;
        display: block;
    }

    .custom-input {
        border: 1px solid #dce4e6;
        border-radius: 12px;
        padding: 12px 15px;
        width: 100%;
        transition: 0.3s;
        margin-bottom: 20px;
        outline: none;
    }

        .custom-input:focus {
            border-color: #3BBFBF;
            box-shadow: 0 0 0 4px rgba(59,191,191,0.1);
        }

    .btn-submit {
        background-color: #3BBFBF;
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 14px;
        width: 100%;
        font-weight: 600;
        cursor: pointer;
        transition: 0.2s;
        margin-top: 10px;
    }

        .btn-submit:hover {
            background-color: #2aa0a0;
            transform: translateY(-2px);
        }
</style>

<div class="page-wrapper">
    <div class="reset-card">
        <h2 class="brand-title">New Password</h2>
        <p class="brand-subtitle">Set a strong password for your account</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" style="color: #dc3545; font-size: 13px; margin-bottom: 20px;">
                @Html.ValidationSummary(false)
            </div>
        }

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" name="identifier" value="@ViewBag.Identifier" />
            <input type="hidden" name="userType" value="@ViewBag.UserType" />

            <label class="form-label">New Password</label>
            <input type="password" name="newPassword" class="custom-input" placeholder="••••••••" required />

            <label class="form-label">Confirm New Password</label>
            <input type="password" name="confirmPassword" class="custom-input" placeholder="••••••••" required />

            <button type="submit" class="btn-submit">Update Password</button>
        </form>
    </div>
</div>