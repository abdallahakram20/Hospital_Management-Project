@using Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"]</title>
    <!-- استدعاء خط Poppins المتناسق مع الهوية الجديدة -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            body {
                margin: 0;
                font-family: 'Poppins', sans-serif;
            }

            /* الخلفية المتدرجة الطبية المريحة المتناسقة مع الـ Layout والصفحات السابقة */
            .page-wrapper {
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100vh;
                background-color: #f3f8ff;
                background-image: radial-gradient(circle at 15% 20%, #e2eeff 0%, transparent 45%), radial-gradient(circle at 85% 80%, #cbdfff 0%, transparent 45%);
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 20px;
                z-index: 9999;
                box-sizing: border-box;
            }

            /* الكارد بالشادو الأزرق الناعم وبدون الحواف الحادة */
            .reset-card {
                background: #ffffff;
                border-radius: 24px;
                box-shadow: 0 12px 40px rgba(21, 101, 192, 0.06);
                border: 1px solid rgba(21, 101, 192, 0.05);
                padding: 50px;
                max-width: 450px;
                width: 100%;
            }

            .brand-title {
                color: #1e293b;
                font-weight: 700;
                font-size: 32px;
                margin-bottom: 5px;
                text-align: center;
            }

            .brand-subtitle {
                color: #64748b;
                font-size: 14px;
                font-weight: 500;
                text-align: center;
                margin-bottom: 30px;
            }

            .form-label-custom {
                font-size: 13.5px;
                font-weight: 600;
                color: #475569;
                margin-bottom: 8px;
                display: block;
            }

            /* حقول الإدخال الزرقاء المحدثة */
            .custom-input {
                border: 1px solid #cbd5e1;
                border-radius: 12px;
                padding: 12px 15px;
                width: 100%;
                font-size: 14px;
                transition: all 0.3s ease;
                margin-bottom: 20px;
                outline: none;
                box-sizing: border-box;
                background-color: #ffffff;
                color: #1e293b;
            }

                .custom-input:focus {
                    border-color: #2563eb;
                    box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1) !important;
                }

            /* الزر الرئيسي باللون الأزرق المعتمد للبروجيكت */
            .btn-submit {
                background-color: #1565c0;
                color: #ffffff;
                border: none;
                border-radius: 50px;
                padding: 14px;
                width: 100%;
                font-weight: 600;
                font-size: 15px;
                cursor: pointer;
                transition: all 0.2s ease;
                margin-top: 10px;
                box-shadow: 0 4px 12px rgba(21, 101, 192, 0.2);
            }

                .btn-submit:hover {
                    background-color: #0d47a1;
                    transform: translateY(-2px);
                    box-shadow: 0 6px 15px rgba(21, 101, 192, 0.3);
                    color: #ffffff;
                }

            /* تحسين صندوق أخطاء الـ Validation */
            .alert-danger-custom {
                background-color: #fef2f2;
                border: 1px solid #fee2e2;
                color: #ef4444;
                border-radius: 12px;
                padding: 12px;
                font-size: 13.5px;
            }
    </style>
</head>
<body>

    <div class="page-wrapper">
        <div class="reset-card">
            <h2 class="brand-title">New Password</h2>
            <p class="brand-subtitle">Set a strong password for your account</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-danger-custom mb-4">
                    @Html.ValidationSummary(false, "", new { @class = "text-danger p-0 m-0", style = "list-style-type: none;" })
                </div>
            }

            <form asp-action="ResetPassword" method="post">
                <input type="hidden" name="identifier" value="@ViewBag.Identifier" />
                <input type="hidden" name="userType" value="@ViewBag.UserType" />

                <label class="form-label-custom">New Password</label>
                <input type="password" name="newPassword" class="custom-input" placeholder="••••••••" required />

                <label class="form-label-custom">Confirm New Password</label>
                <input type="password" name="confirmPassword" class="custom-input" placeholder="••••••••" required />

                <button type="submit" class="btn-submit">Update Password</button>
            </form>
        </div>
    </div>

</body>
</html>