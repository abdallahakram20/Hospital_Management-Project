@{
    ViewData["Title"] = "Access Denied";
}

<div class="container text-center" style="margin-top: 100px;">
    <div class="card shadow p-5 border-danger mx-auto" style="max-width: 600px;">
        <h1 class="text-danger" style="font-size: 72px;">
            <i class="bi bi-shield-x"></i>
        </h1>
        <h2 class="text-danger mt-3">Access Denied</h2>
        <p class="text-muted mt-3">
            Sorry, your current account does not have the required permissions to view or access this page.
        </p>
        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4">Back to Home</a>
        </div>
    </div>
</div>