@{
    ViewData["Title"] = "Access Denied";
}

<style>

    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');

    .access-denied-wrapper {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 150px); 
        font-family: 'DM Sans', sans-serif;
        padding: 20px;
        background-color: #dff0f3;
    }

    .access-denied-card {
        background: #ffffff;
        border-radius: 24px; 
        padding: 48px 40px;
        text-align: center;
        max-width: 480px;
        width: 100%;
        box-shadow: 0 8px 32px rgba(59,191,191,0.08); 
        border-top: 4px solid #e65c5c; 
        transition: transform 0.3s ease;
    }

        .access-denied-card:hover {
            transform: translateY(-4px);
        }

    .ad-icon {
        width: 80px;
        height: 80px;
        background: rgba(230, 92, 92, 0.08); 
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
    }

        .ad-icon svg {
            width: 40px;
            height: 40px;
        }

    .ad-title {
        font-family: 'Playfair Display', serif; 
        font-size: 32px;
        font-weight: 700;
        color: #1a2e35; 
        margin-bottom: 12px;
    }

    .ad-text {
        font-size: 15px;
        color: #5a7a82; 
        line-height: 1.6;
        margin-bottom: 32px;
    }

    .ad-btn {
        background: #3BBFBF; 
        color: #fff;
        border: none;
        border-radius: 50px; =
        padding: 12px 32px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.2s, transform 0.15s;
        display: inline-block;
    }

        .ad-btn:hover {
            background: #2aa0a0; =
            transform: translateY(-2px);
            color: #fff;
        }
</style>

<div class="access-denied-wrapper">
    <div class="access-denied-card">
        <div class="ad-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 22C12 22 20 18 20 12V5L12 2L4 5V12C4 18 12 22 12 22Z" stroke="#e65c5c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M15 9L9 15" stroke="#e65c5c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M9 9L15 15" stroke="#e65c5c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </div>

        <h2 class="ad-title">Access Denied</h2>
        <p class="ad-text">
            Sorry, your current account does not have the required permissions to view or access this page.
        </p>

        <div>
            <a asp-controller="Home" asp-action="Index" class="ad-btn">Back to Home</a>
        </div>
    </div>
</div>