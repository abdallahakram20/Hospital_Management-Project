@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied - CarePlus</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.css">
    
    <style>
            body {
                background-color: #f3f8ff;
                /* خلفية بتدرجات دائرية زرقاء ناعمة متناسقة مع باقي الموقع */
                background-image: radial-gradient(circle at 10% 20%, #d1e3ff 0%, transparent 40%), radial-gradient(circle at 90% 80%, #cbdfff 0%, transparent 45%);
                background-attachment: fixed;
                min-height: 100vh;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                color: #1e293b;
                display: flex;
                flex-direction: column;
                justify-content: space-between;
            }

            .navbar-custom {
                background: rgba(255, 255, 255, 0.8);
                backdrop-filter: blur(10px);
                border-bottom: 1px solid rgba(0, 82, 204, 0.08);
                padding: 15px 0;
            }

            .user-welcome {
                font-weight: 600;
                color: #0052cc;
                font-size: 1.1rem;
            }

            .error-container {
                display: flex;
                align-items: center;
                justify-content: center;
                flex-grow: 1;
                padding: 40px 20px;
            }

            .error-card {
                background: rgba(255, 255, 255, 0.9);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                /* استبدال الحافة الحمراء بحافة زرقاء ملكية أنيقة فوق الكارت */
                border-top: 6px solid #0052cc;
                border-left: 1px solid rgba(255, 255, 255, 0.7);
                border-right: 1px solid rgba(255, 255, 255, 0.7);
                border-bottom: 1px solid rgba(255, 255, 255, 0.7);
                border-radius: 24px;
                box-shadow: 0 20px 40px rgba(0, 82, 204, 0.05);
                max-width: 550px;
                width: 100%;
                padding: 45px 35px;
                text-align: center;
            }

            /* أيقونة القفل والحماية بدرجات الأزرق بدلاً من الأحمر */
            .icon-box {
                width: 90px;
                height: 90px;
                background-color: #eef5ff;
                color: #0052cc;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                font-size: 2.5rem;
                margin-bottom: 25px;
                border: 2px solid #b4d3ff;
                box-shadow: 0 10px 20px rgba(0, 82, 204, 0.05);
            }

            .error-title {
                color: #0a1931;
                font-weight: 800;
                font-size: 2.2rem;
                margin-bottom: 15px;
                letter-spacing: -0.5px;
            }

            .error-message {
                color: #64748b;
                font-size: 1.05rem;
                line-height: 1.6;
                margin-bottom: 35px;
            }

            /* زرار العودة للأزرق النظيف التفاعلي */
            .btn-back {
                background-color: #0052cc;
                color: #ffffff;
                font-weight: 600;
                padding: 12px 35px;
                border-radius: 12px;
                border: none;
                transition: all 0.2s ease;
                box-shadow: 0 8px 20px rgba(0, 82, 204, 0.15);
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 8px;
            }

                .btn-back:hover {
                    background-color: #0041a3;
                    color: #ffffff;
                    transform: translateY(-2px);
                    box-shadow: 0 12px 25px rgba(0, 82, 204, 0.25);
                }

            footer {
                padding: 20px 0;
                border-top: 1px solid rgba(0, 82, 204, 0.05);
                background: rgba(255, 255, 255, 0.5);
                font-size: 0.85rem;
                color: #64748b;
            }
    </style>
</head>
<body>

    <nav class="navbar-custom">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="fw-bold text-dark" style="font-size: 1.2rem;">
                <i class="bi bi-heart-pulse-fill text-primary me-2"></i>CarePlus
            </div>
            <div class="user-welcome">
                <i class="bi bi-person-circle me-1"></i> Welcome, @User.Identity.Name
            </div>
        </div>
    </nav>

    <div class="error-container">
        <div class="error-card">
            <div class="icon-box">
                <i class="bi bi-shield-lock"></i>
            </div>
            <h1 class="error-title">Access Denied</h1>
            <p class="error-message">
                Sorry, your current account does not have the required permissions to view or access this page.
            </p>
            <a href="@Url.Action("Index", "Departments")" class="btn btn-back">
                <i class="bi bi-arrow-left"></i> Back to Home
            </a>
        </div>
    </div>

    <footer class="text-center">
        <div class="container d-flex justify-content-between align-items-center">
            <div>© 2026 CarePlus Hospital. All rights reserved.</div>
            <div class="d-flex gap-3">
                <a href="#" class="text-muted text-decoration-none">Privacy Policy</a>
                <a href="#" class="text-muted text-decoration-none">Terms of Service</a>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>