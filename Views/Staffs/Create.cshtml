@model Hospital_Management_Project.Models.Staff
@{
    ViewData["Title"] = "Add New Staff";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">

<style>
    :root {
        --primary: #1A76D1;
        --primary-dark: #145db3;
        --primary-light: #e8f2fc;
        --primary-gradient: linear-gradient(135deg, #1A76D1, #3b92ec);
        --bg-page: #f4f8fc;
        --card-bg: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --input-bg: #f8fafc;
        --input-border: #cbd5e1;
        --card-shadow: 0 10px 25px -5px rgba(26, 118, 209, 0.08), 0 4px 6px -2px rgba(0,0,0,0.02);
    }

    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: var(--bg-page);
        color: var(--text-main);
    }

    .page-container {
        padding: 40px 20px;
        max-width: 900px;
        margin: 0 auto;
    }

    .page-header {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 25px 40px;
        margin-bottom: 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: var(--card-shadow);
        border-left: 6px solid var(--primary);
    }

    .header-text h2 {
        font-size: 26px;
        font-weight: 700;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .btn-back {
        background: var(--bg-page);
        color: var(--text-main);
        border: 1px solid var(--input-border);
        border-radius: 12px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: all .2s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back:hover {
            background: #fff;
            border-color: var(--primary);
            color: var(--primary);
        }

    .form-card {
        background: var(--card-bg);
        border-radius: 24px;
        padding: 40px;
        box-shadow: var(--card-shadow);
        border: 1px solid rgba(26, 118, 209, 0.08);
        position: relative;
        overflow: hidden;
    }

        .form-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background: var(--primary-gradient);
        }

    .custom-label {
        font-size: 14px;
        font-weight: 600;
        color: var(--text-main);
        margin-bottom: 8px;
        display: block;
    }

    .form-control-custom {
        width: 100%;
        background: var(--input-bg);
        border: 1.5px solid var(--input-border);
        border-radius: 12px;
        padding: 12px 18px;
        font-size: 15px;
        color: var(--text-main);
        transition: all 0.3s ease;
    }

        .form-control-custom:focus {
            border-color: var(--primary);
            background: #fff;
            outline: none;
            box-shadow: 0 0 0 4px var(--primary-light);
        }

    .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
    }

    .full-width {
        grid-column: span 2;
    }

    .btn-save {
        background: var(--primary-gradient);
        color: #fff;
        border: none;
        border-radius: 14px;
        padding: 16px 32px;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        width: 100%;
        margin-top: 20px;
        transition: all 0.3s ease;
        box-shadow: 0 10px 20px -5px rgba(26, 118, 209, 0.4);
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 25px -5px rgba(26, 118, 209, 0.5);
        }

    .upload-box {
        border: 2px dashed var(--input-border);
        border-radius: 12px;
        padding: 25px;
        text-align: center;
        background: var(--input-bg);
        cursor: pointer;
        transition: all 0.3s;
    }

        .upload-box:hover {
            border-color: var(--primary);
            background: var(--primary-light);
        }

    /* منطقة التحكم الخاصة بقص الصورة */
    .crop-wrapper {
        display: none;
        max-width: 100%;
        max-height: 380px;
        background-color: #000;
        border-radius: 16px;
        overflow: hidden;
        margin-top: 20px;
        box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
    }

        .crop-wrapper img {
            display: block;
            max-width: 100%;
        }

    /* جعل جايد القص دائري ليناسب أبعاد الـ Avatar في المشروع */
    .cropper-view-box, .cropper-face {
        border-radius: 50%;
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .full-width {
            grid-column: span 1;
        }
    }
</style>

<div class="page-container">
    <div class="page-header">
        <div class="header-text">
            <h2><i class="bi bi-person-plus-fill" style="color: var(--primary);"></i> Add New Staff</h2>
            <p style="color: var(--text-muted); margin-top: 5px; font-size: 14px;">Fill in the details to register a new healthcare professional</p>
        </div>
        <a asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="form-card">
        <form id="createStaffForm" asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Fname" class="custom-label">First Name</label>
                    <input asp-for="Fname" class="form-control-custom" placeholder="Enter first name" />
                    <span asp-validation-for="Fname" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Lname" class="custom-label">Last Name</label>
                    <input asp-for="Lname" class="form-control-custom" placeholder="Enter last name" />
                    <span asp-validation-for="Lname" class="text-danger small"></span>
                </div>

                <div class="form-group full-width">
                    <label asp-for="Email" class="custom-label">Email Address</label>
                    <input asp-for="Email" class="form-control-custom" placeholder="staffmember@careplus.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-group full-width">
                    <label asp-for="Password" class="custom-label">Password</label>
                    <input asp-for="Password" type="password" class="form-control-custom" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Position" class="custom-label">Position / Role</label>
                    <input asp-for="Position" class="form-control-custom" placeholder="e.g. Doctor, Nurse" />
                    <span asp-validation-for="Position" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DepartmentId" class="custom-label">Department</label>
                    <select asp-for="DepartmentId" class="form-control-custom" asp-items="ViewBag.DepartmentId">
                        <option value="">-- Select Department --</option>
                    </select>
                    <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                </div>

                <div class="form-group full-width">
                    <label class="custom-label">Profile Picture (Adjust to Fit Face)</label>
                    <div class="upload-box" onclick="document.getElementById('imageInput').click();">
                        <i class="bi bi-cloud-arrow-up fs-2 text-primary"></i>
                        <p class="mb-0 mt-2 text-muted" id="uploadStatusText">Click to upload or drag and drop</p>
                        <input type="file" id="imageInput" name="ImageFile" accept="image/*" style="display:none;" />
                    </div>

                    <div class="crop-wrapper" id="cropWrapper">
                        <img id="imageToCrop" src="" alt="Crop Work Area">
                    </div>
                </div>
            </div>

            <button type="submit" class="btn-save">
                <i class="bi bi-check-circle-fill"></i> Save Staff Member
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>

    <script>
        let cropper;
        const imageInput = document.getElementById('imageInput');
        const imageToCrop = document.getElementById('imageToCrop');
        const cropWrapper = document.getElementById('cropWrapper');
        const uploadStatusText = document.getElementById('uploadStatusText');
        const form = document.getElementById('createStaffForm');

        // 1. عند اختيار صورة: تشغيل محرك القص وتغيير حالة صندوق الرفع
        imageInput.addEventListener('change', function (e) {
        const files = e.target.files;
        if (files && files.length > 0) {
        const file = files[0];

        // تحديث نص الـ Upload Box
        uploadStatusText.innerText = "Selected: " + file.name + " (Adjust below)";
        uploadStatusText.style.color = "var(--primary)";

        const reader = new FileReader();
        reader.onload = function (event) {
        if (cropper) {
        cropper.destroy(); // تدمير الـ Cropper القديم لو اختار صورة تانية
        }

        imageToCrop.src = event.target.result;
        cropWrapper.style.display = 'block'; // إظهار مساحة القص

        // بناء كائن الـ Cropper بإعدادات دائرية متساوية الأبعاد لوش موحد
        cropper = new Cropper(imageToCrop, {
        aspectRatio: 1, // نسبة ثابتة 1:1
        viewMode: 1,
        background: false,
        autoCropArea: 0.8
        });
        };
        reader.readAsDataURL(file);
        }
        });

        // 2. اعتراض عملية الـ Submit وضغط وقص الصورة وإرسالها بالـ Fetch لضمان استقرار الإرسال $100\%$
        form.addEventListener('submit', function (e) {
        if (!cropper) return; // لو مرفعش صورة، سيب الـ Form يسيف من غيرها ويعتمد الـ UI-Avatar الافتراضي

        e.preventDefault(); // إيقاف الحفظ العادي

        // تحويل الجزء المقصوص لملف مضغوط وواضح بدقة ممتازة
        cropper.getCroppedCanvas({ width: 400, height: 400 }).toBlob(function (blob) {

        // تجميع كل بيانات الحقول من الـ Form يدوياً
        const formData = new FormData(form);

        // تنظيف الملف الأصلي الضخم غير المقصوص
        formData.delete("ImageFile");

        // إرفاق الصورة المقصوصة المحددة للوجه والجاهزة تماماً
        formData.append("ImageFile", blob, "new_staff_avatar.jpg");

        // الإرسال للسيرفر عبر الـ Fetch API الآمن والمستقر
        fetch(form.action, {
        method: 'POST',
        body: formData
        })
        .then(response => {
        if (response.ok || response.redirected) {
        // عند نجاح العملية وتخزين الموظف بالصورة المقصوصة يتم تحويله للقائمة الرئيسية فوراً
        window.location.href = '@Url.Action("Index")';
        } else {
        alert("There was an issue saving the cropped image. Please check your controller setup.");
        }
        })
        .catch(err => console.error("Error submitting cropped image:", err));

        }, 'image/jpeg', 0.9); // صيغة JPEG وجودة 90%
        });
    </script>
}