@{
    ViewData["Title"] = "Change Password";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --primary-main: #0052cc;
        --primary-button: #1a73e8;
        --primary-light: #eef5ff;
        --text-dark: #0a1931;
        --text-main: #1e293b;
        --text-muted: #64748b;
    }

    body {
        background-color: #f3f8ff;
        background-image: radial-gradient(circle at 5% 15%, #d1e3ff 0%, transparent 35%), radial-gradient(circle at 95% 25%, #dae7ff 0%, transparent 30%);
        background-attachment: fixed;
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-main);
    }

    .bg-glow-form {
        position: absolute;
        width: 450px;
        height: 450px;
        background: radial-gradient(circle, rgba(195, 219, 255, 0.8) 0%, rgba(255,255,255,0) 70%);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        z-index: 0;
        pointer-events: none;
        filter: blur(30px);
    }

    .custom-glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0, 82, 204, 0.05);
        position: relative;
        z-index: 1;
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 16px;
        border: 1px solid #cbd5e1;
        background: rgba(255, 255, 255, 0.7);
        transition: all 0.2s ease;
    }

        .form-control:focus {
            border-color: var(--primary-main);
            box-shadow: 0 0 0 4px rgba(0, 82, 204, 0.15);
            background: #fff;
        }

    .btn-submit {
        background-color: var(--primary-button) !important;
        color: #fff !important;
        border: none;
        border-radius: 12px;
        padding: 12px;
        font-weight: 500;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px rgba(26, 115, 232, 0.2);
    }

        .btn-submit:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(26, 115, 232, 0.3);
        }

    .btn-cancel {
        border: 1px solid #cbd5e1;
        background-color: #fff;
        color: var(--text-muted);
        border-radius: 12px;
        padding: 12px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

        .btn-cancel:hover {
            background-color: #f8fafc;
            color: var(--text-dark);
        }
</style>

<div class="container d-flex justify-content-center align-items-center position-relative" style="min-height: 85vh;">
    <div class="bg-glow-form"></div>

    <div class="card custom-glass-card p-4 p-md-5 w-100" style="max-width: 500px;">
        <div class="text-center mb-4">
            <div class="d-inline-flex p-3 rounded-circle mb-3" style="background: var(--primary-light); color: var(--primary-main);">
                <i class="bi bi-shield-lock-fill fs-2"></i>
            </div>
            <h3 class="fw-bold text-dark mb-1">Update Password</h3>
            <p class="text-muted small">Ensure your hospital account stays safe and secure</p>
        </div>

        <!-- 💡 Notice: Form submits without a strict MVC strongly-typed model 💡 -->
        <form asp-action="ChangePassword" method="post">

            <!-- Custom error message placeholder injected from controller if needed -->
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert alert-danger small p-2 border-0 rounded-3 mb-3">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.ErrorMessage
                </div>
            }

            <!-- Pass the target staff identity seamlessly using ViewBag -->
            <input type="hidden" name="staffId" value="@ViewBag.StaffId" />

            <div class="mb-3">
                <label class="form-label fw-semibold text-dark small">Current Password</label>
                <input type="password" name="currentPassword" class="form-control" placeholder="••••••••" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold text-dark small">New Password</label>
                <input type="password" name="newPassword" class="form-control" placeholder="••••••••" required minlength="6" />
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold text-dark small">Confirm New Password</label>
                <input type="password" name="confirmPassword" class="form-control" placeholder="••••••••" required />
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-submit">
                    <i class="bi bi-check-circle-fill me-2"></i> Save Changes
                </button>
                <a asp-action="Index" class="btn btn-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>