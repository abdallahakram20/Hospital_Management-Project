@model IEnumerable<Hospital_Management_Project.Models.Staff>

@{
    ViewData["Title"] = "Staff Directory";
    bool isPatient = User.IsInRole("Patient");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        /* الألوان الرسمية المتطابقة مع الديزاين الأول */
        --primary-main: #0052cc;
        --primary-button: #1a73e8;
        --primary-light: #eef5ff;
        --text-dark: #0a1931;
        --text-main: #1e293b;
        --text-muted: #64748b;
    }

    body {
        background-color: #f3f8ff;
        background-image: 
            radial-gradient(circle at 5% 15%, #d1e3ff 0%, transparent 35%),
            radial-gradient(circle at 95% 25%, #dae7ff 0%, transparent 30%),
            radial-gradient(circle at 85% 80%, #cbdfff 0%, transparent 40%),
            radial-gradient(circle at 10% 85%, #e2eeff 0%, transparent 35%);
        background-attachment: fixed;
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-main);
        overflow-x: hidden;
    }

    /* تأثيرات التوهج بالخلفية */
    .bg-glow-1 {
        position: absolute;
        width: 500px;
        height: 500px;
        background: radial-gradient(circle, rgba(195, 219, 255, 0.7) 0%, rgba(255,255,255,0) 70%);
        top: -100px;
        right: -150px;
        z-index: 0;
        pointer-events: none;
        filter: blur(20px);
    }

    .bg-glow-2 {
        position: absolute;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(204, 224, 255, 0.6) 0%, rgba(255,255,255,0) 70%);
        bottom: -50px;
        left: -150px;
        z-index: 0;
        pointer-events: none;
        filter: blur(20px);
    }

    .page-container {
        padding: 48px 20px;
        max-width: 1300px;
        margin: 0 auto;
        position: relative;
    }

    /* الكارت الزجاجي الموحد (Glassmorphism) */
    .custom-glass-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 24px;
        box-shadow: 0 15px 35px rgba(0, 82, 204, 0.03);
        position: relative;
        z-index: 1;
    }

    /* الهيدر المتناسق */
    .page-header {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.8);
        padding: 40px;
        margin-bottom: 32px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 12px 30px rgba(0, 82, 204, 0.02);
        flex-wrap: wrap;
        gap: 20px;
        position: relative;
        z-index: 1;
    }

    .header-text h2 {
        font-size: 2.2rem;
        font-weight: 850;
        color: var(--text-dark);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .header-text p {
        color: var(--text-muted);
        font-size: 1.05rem;
        margin: 6px 0 0 0;
    }

    /* زرار الإضافة بنفس الستايل المعتمد */
    .btn-create {
        background-color: var(--primary-button) !important;
        color: #fff !important;
        border: none;
        border-radius: 12px;
        padding: 12px 24px;
        font-size: 0.95rem;
        font-weight: 500;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(26, 115, 232, 0.2);
    }

    .btn-create:hover {
        opacity: 0.9;
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(26, 115, 232, 0.3);
    }

    /* الجريد والكروت للـ Staff */
    .staff-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
        position: relative;
        z-index: 1;
    }

    .staff-card {
        padding: 32px 24px 24px;
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }

    .staff-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(0, 82, 204, 0.06);
        border-color: rgba(0, 82, 204, 0.2);
    }

    /* الصورة الرمزية والدائرة */
    .staff-avatar-img {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 18px;
        box-shadow: 0 8px 20px rgba(0, 82, 204, 0.1);
        border: 4px solid #fff;
        outline: 2px solid var(--primary-light);
        transition: transform 0.3s ease, outline-color 0.3s ease;
        background-color: var(--primary-light);
    }

    .staff-card:hover .staff-avatar-img {
        transform: scale(1.04);
        outline-color: var(--primary-main);
    }

    .staff-name {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 8px 0;
    }

    /* البادج المعتمد للـ Position (متناسق مع الـ floor-badge) */
    .staff-role {
        display: inline-block;
        background-color: var(--primary-light);
        color: var(--primary-main);
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        border: none;
        margin-bottom: 20px;
    }

    /* منطقة البيانات تفصيلية */
    .staff-info {
        width: 100%;
        text-align: left;
        padding-top: 18px;
        margin-bottom: 24px;
        border-top: 1px dashed rgba(0, 82, 204, 0.15);
    }

    .info-line {
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.9rem;
        color: var(--text-main);
        margin-bottom: 12px;
    }

    .info-line i {
        color: var(--primary-main);
        font-size: 1rem;
        background: rgba(0, 82, 204, 0.05);
        padding: 6px;
        border-radius: 8px;
        width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    /* زراير التحكم داخل الكارت */
    .action-btns {
        display: flex;
        gap: 8px;
        width: 100%;
        margin-top: auto;
    }

    .btn-action {
        flex: 1;
        border-radius: 12px;
        padding: 9px 0;
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        transition: all .2s ease;
        display: inline-flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
    }

    /* تفاصيل (متطابق مع تفاصيل الـ Departments) */
    .btn-details {
        border: 1px solid #b4d3ff;
        background-color: #fff;
        color: var(--primary-main);
    }

    .btn-details:hover {
        background-color: var(--primary-main);
        color: #fff;
        border-color: var(--primary-main);
    }

    /* تعديل */
    .btn-edit {
        background-color: #fff;
        color: #eab308;
        border: 1px solid #fef08a;
    }

    .btn-edit:hover {
        background-color: #eab308;
        color: #fff;
        border-color: #eab308;
    }

    /* حذف */
    .btn-delete {
        background-color: #fff;
        color: #ef4444;
        border: 1px solid #fee2e2;
    }

    .btn-delete:hover {
        background-color: #ef4444;
        color: #fff;
        border-color: #ef4444;
    }

    /* الشاشات الفاضية */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        grid-column: 1 / -1;
    }

    .empty-state i {
        font-size: 64px;
        color: var(--primary-main);
        opacity: 0.3;
        margin-bottom: 16px;
        display: block;
    }

    .empty-state h4 {
        color: var(--text-dark);
        font-weight: 700;
        margin-bottom: 8px;
    }

    @@media (max-width: 768px) {
        .staff-grid {
            grid-template-columns: 1fr;
        }
        .page-header {
            flex-direction: column;
            align-items: flex-start;
            padding: 30px;
        }
    }
</style>

<div class="container py-5 position-relative">
    <div class="bg-glow-1"></div>

    <div class="page-header shadow-sm">
        <div class="header-text">
            <h2><i class="bi bi-people-fill" style="color: var(--primary-main);"></i> Staff Directory</h2>
            <p>@(isPatient ? "View our certified medical specialists and doctors" : "Manage all hospital staff and healthcare professionals")</p>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn-create">
                <i class="bi bi-person-plus-fill"></i> Add New Staff
            </a>
        }
    </div>

    <div class="staff-grid">
        <div class="bg-glow-2"></div>

        @if (!Model.Any())
        {
            <div class="card border-0 custom-glass-card empty-state">
                <i class="bi bi-person-x-fill"></i>
                <h4>No Medical Staff Found</h4>
                <p class="text-muted m-0">There are no active records available at the moment.</p>
            </div>
        }
        else
        {
            int displayedCount = 0;

            @foreach (var item in Model)
            {
                if (isPatient && !string.Equals(item.Position, "Doctor", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                displayedCount++;
                
                <div class="card border-0 custom-glass-card staff-card">
                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <img src="~/images/staff/@item.ImagePath"
                             asp-append-version="true"
                             class="staff-avatar-img"
                             alt="@item.Fname @item.Lname"
                             onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@item.Fname+@item.Lname&background=eef5ff&color=0052cc&bold=true&size=150';" />
                    }
                    else
                    {
                        <img src="https://ui-avatars.com/api/?name=@item.Fname+@item.Lname&background=eef5ff&color=0052cc&bold=true&size=150"
                             class="staff-avatar-img"
                             alt="@item.Fname @item.Lname" />
                    }

                    <h3 class="staff-name">@item.Fname @item.Lname</h3>

                    <div class="staff-role">
                        <i class="bi bi-award-fill me-1"></i> @item.Position
                    </div>

                    <div class="staff-info">
                        <div class="info-line" title="Department">
                            <i class="bi bi-building-fill"></i>
                            <span>@(item.Department?.DeptName ?? "No Department Assigned")</span>
                        </div>

                        @if (!isPatient)
                        {
                            <div class="info-line" title="Email Address">
                                <i class="bi bi-envelope-fill"></i>
                                <span style="word-break: break-all;">@item.Email</span>
                            </div>
                        }
                        else
                        {
                            <div class="info-line" title="Status">
                                <i class="bi bi-check-circle-fill" style="color: #10b981;"></i>
                                <span class="text-success fw-medium">Active & Available</span>
                            </div>
                        }
                    </div>

                    <div class="action-btns">
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.StaffId" class="btn-action btn-edit" title="Edit Profile">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                        }

                        <a asp-action="Details" asp-route-id="@item.StaffId" class="btn-action btn-details" style="@(!User.IsInRole("Admin") ? "width: 100%;" : "")" title="View Details">
                            <i class="bi bi-eye"></i> Details
                        </a>

                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Delete" asp-route-id="@item.StaffId" class="btn-action btn-delete" title="Delete Account">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        }
                    </div>
                </div>
            }

            if (displayedCount == 0)
            {
                <div class="card border-0 custom-glass-card empty-state">
                    <i class="bi bi-person-x-fill"></i>
                    <h4>No Active Doctors Available</h4>
                    <p class="text-muted m-0">There are no healthcare specialists listed at this time.</p>
                </div>
            }
        }
    </div>

    <footer class="d-flex justify-content-between align-items-center mt-5 pt-3 text-muted small border-top" style="position: relative; z-index: 2;">
        <div>© 2026 Medicare Hospital. All rights reserved.</div>
        <div class="d-flex gap-3">
            <a href="#" class="text-muted text-decoration-none">Privacy Policy</a>
            <a href="#" class="text-muted text-decoration-none">Terms of Service</a>
        </div>
    </footer>
</div>